<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
                xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
                xmlns:g="http://base.google.com/ns/1.0" xmlns:xls="http://www.w3.org/1999/XSL/Transform">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" cdata-section-elements="g:id g:title g:description g:google_product_category g:product_type link g:mobile_link g:image_link g:additional_image_link g:availability g:price g:sale_price g:gtin g:mpn g:brand g:size g:item_group_id g:condition g:shipping_weight g:custom_label_0"/>
    
    <xsl:variable name="lower" select= "'aąbcćdeęfghijklłmnoópqrsśtuvwxyzżź'"/>
    <xsl:variable name="upper" select= "'AĄBCĆDEĘFGHIJKLŁMNOÓPQRSŚTUVWXYZŻŹ'"/>
    
    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <xsl:element name="channel">
                <xsl:for-each select="offer/products/*">
                    
                    <xsl:variable name="activeSizesCount" select="count(iaiext:sizes/iaiext:size[iaiext:stock/@quantity &gt; 4])"/>
                    
                    <xsl:variable name="totalSizesCount" select="count(iaiext:sizes/iaiext:size)"/>
                    
                    <xsl:for-each select="iaiext:sizes/iaiext:size[iaiext:stock/@quantity &gt; 0]">
                        
                        <xsl:sort select="number(@size_name)" data-type="number" order="ascending"/>
                        
                        <xsl:if test="position() = 1">
                            
                            <xsl:variable name="isPants" select="contains(translate(../../description/name, $upper, $lower), 'spodnie')"/>
                            <xsl:variable name="isUniversal" select="$totalSizesCount = 1 and @id = 95 and iaiext:stock/@quantity &gt; 4"/>
                            
                            <xsl:variable name="isStandardRulePants" select="@id = 3 or @id = 4 or @id = 5 or @id = 6 or @id = 7"/>
                            
                            <xsl:if test="(../../description/name and ../../description/name != '') 
                                          and ((../../price/@gross &gt; 0) or (../../iaiext:pricecomparator_price/iaiext:site/@gross &gt; 0) or (iaiext:price/@gross &gt; 0))
                                                                                                                                                            and (
                                                                                                                                                            $isUniversal
                                                                                                                                                            or
                                                                                                                                                            (
                                                                                                                                                            ( (not($isPants) or $isStandardRulePants) and $activeSizesCount &gt;= 2 )
                                                                                                 
                                                                                                 or
                                                                                                 
                                                                                                 ( ($isPants and not($isStandardRulePants)) and 
                                                                                                 (
                                                                                                 (($totalSizesCount = 4 or $totalSizesCount = 5) and $activeSizesCount &gt;= 2)
                                                                                                       or
                                                                                                       ($totalSizesCount &gt; 5 and $activeSizesCount &gt;= 3)
                                                                                )
                                                                                )
                                                                                )
                                                                                )">
                                
                                <xsl:element name="item">
                                    <xsl:element name="g:id"><xsl:value-of select="../../@id"/></xsl:element>
                                    <xsl:element name="g:title">
                                        <xsl:variable name="product_name" select="concat(substring(../../description/name/.,1,1), translate(substring(../../description/name/.,2), $upper, $lower))"/>
                                        <xsl:choose>
                                            <xsl:when test="../../description/name/@type = 'marketplace_site_name'">	
                                                <xsl:value-of select="normalize-space(substring($product_name, 0,100))"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="normalize-space(substring($product_name, 0,100))"/>	
                                            </xsl:otherwise>
                                        </xsl:choose>								
                                    </xsl:element>							
                                    <xsl:for-each select="../../description">
                                        <xsl:element name="description">
                                            <xsl:choose>
                                                <xsl:when test="short_desc != ''">
                                                    <xsl:value-of select="concat(substring(short_desc/.,1,1), translate(substring(short_desc/.,2), $upper, $lower))"/>
                                                </xsl:when>
                                                <xsl:when test="long_desc != ''">
                                                    <xsl:value-of select="substring(concat(substring(long_desc/.,1,1), translate(substring(long_desc/.,2), $upper, $lower)), 0,5000)"/>
                                                </xsl:when>
                                                <xsl:otherwise>
                                                    <xsl:value-of select="concat(substring(name/.,1,1), translate(substring(name/.,2), $upper, $lower))"/>
                                                </xsl:otherwise>
                                            </xsl:choose>
                                        </xsl:element>
                                    </xsl:for-each>
                                    <xsl:variable name="sizeID" select="@id"/>
                                    <xsl:variable name="urlProduct" select="../../card/@url"/>
                                    <xsl:variable name="link" select="substring-before($urlProduct,'.html')"/>
                                    <xsl:variable name="link0001" select="substring-before($link,'/product-')"/>
                                    <xsl:variable name="link0002" select="substring-after($urlProduct,'/product')"/>
                                    <xsl:variable name="link0003" select="substring-before($link0002,'.')"/>
                                    <xsl:variable name="link0004" select="substring-after($link0002,'.')"/>
                                    <xsl:variable name="urlProductMobile" select="../../card/@iaiext:url_mobile"/>
                                    <xsl:variable name="mlink" select="substring-before($urlProductMobile,'.html')"/>
                                    <xsl:variable name="link0011" select="substring-before($mlink,'/product-')"/>
                                    <xsl:variable name="link0012" select="substring-after($urlProductMobile,'/product')"/>
                                    <xsl:variable name="link0013" select="substring-before($link0012,'.')"/>
                                    <xsl:variable name="link0014" select="substring-after($link0012,'.')"/>
                                    <xsl:choose>
                                        <xsl:when test="../../card/@iaiext:url_mobile">
                                            <xsl:element name="link">
                                                <xsl:value-of select="$link0001"/><xsl:text>/product</xsl:text><xsl:value-of select="$link0003"/><xsl:text>.</xsl:text><xsl:value-of select="$link0004"/>
                                            </xsl:element>
                                            <xsl:element name="g:mobile_link">
                                                <xsl:value-of select="$link0011"/><xsl:text>/product</xsl:text><xsl:value-of select="$link0013"/><xsl:text>.</xsl:text><xsl:value-of select="$link0014"/>
                                            </xsl:element>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:element name="link">
                                                <xsl:value-of select="$link0001"/><xsl:text>/product</xsl:text><xsl:value-of select="$link0003"/><xsl:text>.</xsl:text><xsl:value-of select="$link0004"/>
                                            </xsl:element>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                    <xsl:choose>
                                        <xsl:when test="../../images/large">
                                            <xsl:for-each select="../../images/large/image">
                                                <xsl:choose>
                                                    <xsl:when test="position() = '1'">
                                                        <xsl:element name="g:image_link">
                                                            <xsl:value-of select="@url"/>
                                                        </xsl:element>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:if test="position() &lt;= 10">
                                                            <xsl:element name="g:additional_image_link">
                                                                <xsl:value-of select="@url"/>
                                                            </xsl:element>
                                                        </xsl:if>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:for-each>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:element name="g:image_link">
                                                <xsl:variable name="image_link" select="../../card/@url"/>
                                                <xsl:variable name="no_image"><![CDATA[/eng_il-default-1.png]]></xsl:variable>
                                                <xsl:value-of select="substring-before($image_link,'/product-')"/><xsl:value-of select="$no_image"/>									
                                            </xsl:element>						
                                        </xsl:otherwise>
                                    </xsl:choose>
                                    <xsl:choose>
                                        <xsl:when test="../../producer/@name = 'producent niezdefiniowany'">	
                                            <![CDATA[Producent niezdefiniowany]]>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:element name="g:brand">
                                                <xsl:value-of select="../../producer/@name"/>
                                            </xsl:element>							
                                        </xsl:otherwise>
                                    </xsl:choose>
                                    <xsl:choose>
                                        <xsl:when test="(../../@iaiext:producer_code_standard = 'ISBN10' or ../../@iaiext:producer_code_standard = 'ISBN13') and (@code_producer and not(@code_producer=''))">										
                                            <xsl:element name="g:gtin">
                                                <xsl:value-of select="normalize-space(@code_producer)"/> 									
                                            </xsl:element>
                                        </xsl:when>	
                                        <xsl:when test="(../../@iaiext:producer_code_standard = 'GTIN8' or ../../@iaiext:producer_code_standard = 'GTIN13' or ../../@iaiext:producer_code_standard = 'GTIN14') and (@code_producer and not(@code_producer=''))">										
                                            <xsl:element name="g:gtin">
                                                <xsl:value-of select="normalize-space(@code_producer)"/> 									
                                            </xsl:element>	
                                        </xsl:when>
                                        <xsl:when test="(../../@iaiext:producer_code_standard = 'GTIN12' or ../../@iaiext:producer_code_standard = 'UPCE') and (@code_producer and not(@code_producer=''))">										
                                            <xsl:element name="g:gtin">
                                                <xsl:value-of select="normalize-space(@code_producer)"/> 									
                                            </xsl:element>																																
                                        </xsl:when>
                                        <xsl:when test="(../../@iaiext:producer_code_standard = 'MPN') and (@code_producer and not(@code_producer=''))">										
                                            <xsl:element name="g:mpn">
                                                <xsl:value-of select="normalize-space(@code_producer)"/> 									
                                            </xsl:element>														
                                        </xsl:when>
                                        <xsl:when test="(../../@iaiext:producer_code_standard = 'OTHER') and (@code_producer and not(@code_producer=''))">										
                                            <xsl:element name="g:gtin">
                                                <xsl:value-of select="normalize-space(@code_producer)"/> 									
                                            </xsl:element>														
                                        </xsl:when>							
                                        <xsl:otherwise>
                                            <xsl:element name="g:gtin">
                                                <xsl:variable name="code_on_card" select="../../@code_producer"/>
                                                <xsl:choose>
                                                    <xsl:when test="@code_producer and not(@code_producer='')">
                                                        <xsl:value-of select="normalize-space(@code_producer)"/>
                                                    </xsl:when>
                                                    <xsl:when test="@code_external and not(@code_external='')">
                                                        <xsl:value-of select="normalize-space(@code_external)"/>
                                                    </xsl:when>
                                                    <xsl:when test="$code_on_card and not($code_on_card='')">
                                                        <xsl:value-of select="normalize-space($code_on_card)"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:value-of select="normalize-space(@code)"/>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:element>		
                                        </xsl:otherwise>
                                    </xsl:choose>
                                    <xsl:variable name="condition_new"><![CDATA[new]]></xsl:variable>
                                    <xsl:variable name="condition_refurbished"><![CDATA[refurbished]]></xsl:variable>
                                    <xsl:variable name="condition_used"><![CDATA[used]]></xsl:variable>
                                    <xsl:choose>
                                        <xsl:when test="../../parameters/parameter[@iaiext:context_id = 'CONTEXT_STATE']">
                                            <xsl:for-each select="../../parameters/parameter">
                                                <xsl:choose>
                                                    <xsl:when test="value[@iaiext:context_id = 'CONTEXT_STATE_USED']">
                                                        <xsl:element name="g:condition">
                                                            <xsl:value-of select="$condition_used"/>
                                                        </xsl:element>
                                                    </xsl:when>
                                                    <xsl:when
                                                        test="value[@iaiext:context_id = 'CONTEXT_STATE_REFURBISHED_BY_PRODUCER']">
                                                        <xsl:element name="g:condition">
                                                            <xsl:value-of select="$condition_refurbished"/>
                                                        </xsl:element>
                                                    </xsl:when>
                                                    <xsl:when
                                                        test="value[@iaiext:context_id = 'CONTEXT_STATE_REFURBISHED_BY_SELLER']">
                                                        <xsl:element name="g:condition">
                                                            <xsl:value-of select="$condition_refurbished"/>
                                                        </xsl:element>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:element name="g:condition">
                                                            <xsl:value-of select="$condition_new"/>
                                                        </xsl:element>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:for-each>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:element name="g:condition">
                                                <xsl:value-of select="$condition_new"/>
                                            </xsl:element>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                    <xsl:element name="g:availability">
                                        <xsl:variable name="unit" select="../../iaiext:delivery_time/@unit"/>
                                        <xsl:variable name="days" select="../../iaiext:delivery_time/@value"/>	
                                        <xsl:variable name="instock"><![CDATA[in stock]]></xsl:variable>
                                        <xsl:variable name="preorder"><![CDATA[preorder]]></xsl:variable>
                                        <xsl:variable name="outofstock"><![CDATA[out of stock]]></xsl:variable>
                                        <xsl:variable name="availablefororder"><![CDATA[available for order]]></xsl:variable>								
                                        
                                        <xsl:choose>
                                            <xsl:when test="iaiext:stock/@quantity &gt; 0">
                                                <xsl:value-of select="$instock"/>
                                            </xsl:when>
                                            <xsl:when test="iaiext:stock/@id = 0">
                                                <xsl:choose>
                                                    <xsl:when test="($unit = 'day' and $days &lt;= 3) or ($unit = 'hour' and $days &lt;= 72) or ($unit = 'minute' and $days &lt;= 4320)">
                                                        <xsl:value-of select="$instock"/>
                                                    </xsl:when>
                                                    <xsl:when test="($unit = 'day' and $days &gt; 3) or ($unit = 'hour' and $days &gt; 72) or ($unit = 'minute' and $days &gt; 4320)">
                                                        <xsl:value-of select="$availablefororder"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:value-of select="$outofstock"/>								
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:when test="iaiext:stock/@id = -2">
                                                <xsl:value-of select="$preorder"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="$outofstock"/>	
                                            </xsl:otherwise>
                                        </xsl:choose>							
                                    </xsl:element>
                                    
                                    <xsl:variable name="cenaP" select="../../iaiext:pricecomparator_price/iaiext:site/@gross"/>
                                    <xsl:variable name="cenaS" select="iaiext:price/@gross"/>
                                    <xsl:variable name="cenaB" select="../../price/@gross"/>
                                    <xsl:variable name="cenaN" select="../../iaiext:promotion/iaiext:price/@normal_price"/>
                                    
                                    <xsl:variable name="computedPrice">
                                        <xsl:choose>
                                            <xsl:when test="iaiext:strikethrough_retail_price/@gross">
                                                <xsl:value-of select="iaiext:strikethrough_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:choose>
                                                    <xsl:when test="($cenaP != $cenaB) and $cenaP != '' and $cenaP &gt; 0">
                                                        <xsl:value-of select="$cenaP"/>
                                                    </xsl:when>
                                                    <xsl:when test="not($cenaS) or $cenaS = '0'">
                                                        <xsl:value-of select="$cenaB"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:value-of select="$cenaS"/>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:variable>
                                    
                                    <xsl:variable name="computedSalePrice">
                                        <xsl:choose>
                                            <xsl:when test="../../iaiext:promotion/iaiext:price/@normal_price != ''">
                                                <xsl:choose>
                                                    <xsl:when test="($cenaN != '' and $cenaN &gt; $cenaP) or ($cenaN != '' and ($cenaN &gt; $cenaS) and ($cenaN &gt; $cenaB))">
                                                        <xsl:value-of select="$cenaN"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:choose>
                                                            <xsl:when test="($cenaP != $cenaB) and $cenaP != '' and $cenaP &gt; 0">
                                                                <xsl:value-of select="$cenaP"/>
                                                            </xsl:when>
                                                            <xsl:when test="not($cenaS) or $cenaS = '0'">
                                                                <xsl:value-of select="$cenaB"/>
                                                            </xsl:when>
                                                            <xsl:otherwise>
                                                                <xsl:value-of select="$cenaS"/>
                                                            </xsl:otherwise>
                                                        </xsl:choose>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:choose>
                                                    <xsl:when test="($cenaP != $cenaB) and $cenaP != '' and $cenaP &gt; 0">
                                                        <xsl:value-of select="$cenaP"/>
                                                    </xsl:when>
                                                    <xsl:when test="not($cenaS) or $cenaS = '0'">
                                                        <xsl:value-of select="$cenaB"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:value-of select="$cenaS"/>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:variable>
                                    
                                    <xsl:variable name="finalPrice">
                                        <xsl:choose>
                                            <xsl:when test="$computedPrice &gt;= $computedSalePrice">
                                                <xsl:value-of select="$computedPrice"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="$computedSalePrice"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:variable>
                                    
                                    <xsl:variable name="finalSalePrice">
                                        <xsl:choose>
                                            <xsl:when test="$computedPrice &gt;= $computedSalePrice">
                                                <xsl:value-of select="$computedSalePrice"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="$computedPrice"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:variable>
                                    
                                    <xsl:element name="g:price">
                                        <xsl:value-of select="$finalPrice"/><xsl:text> PLN</xsl:text>
                                    </xsl:element>
                                    
                                    <xsl:if test="$finalSalePrice != $finalPrice">
                                        <xsl:element name="g:sale_price">
                                            <xsl:value-of select="$finalSalePrice"/><xsl:text> PLN</xsl:text>
                                        </xsl:element>
                                    </xsl:if>
                                    
                                    <xsl:if test="../../iaiext:omnibus_price_retail/iaiext:site/@gross > 0">
                                        <g:custom_label_0>
                                            <xsl:value-of select="../../iaiext:omnibus_price_retail/iaiext:site/@gross"/>
                                            <xsl:text><![CDATA[ ]]></xsl:text>
                                            <xsl:value-of select="../../@currency"/>    
                                        </g:custom_label_0>
                                    </xsl:if>

                                    <xsl:for-each select="../../iaiext:price_compare_categories/iaiext:price_comparison">							
                                        <xsl:element name="g:google_product_category">
                                            <xsl:value-of select="@category"/>
                                        </xsl:element>
                                    </xsl:for-each>
                                    <xsl:variable name="kier"><![CDATA[ > ]]></xsl:variable>
                                    <xsl:choose>
                                        <xsl:when test="../../iaiext:navigation/iaiext:site/iaiext:menu/iaiext:item/@textid != ''">
                                            <xsl:for-each select="../../iaiext:navigation/iaiext:site/iaiext:menu/iaiext:item">
                                                <xsl:if test="position() &lt;= 5">
                                                    <xsl:element name="g:product_type">
                                                        <xsl:variable name="menu" select="normalize-space(@textid)"/>
                                                        <xsl:variable name="menu1" select="substring-before($menu, '\')"/>
                                                        <xsl:variable name="menu11" select="substring-after($menu, '\')"/>
                                                        <xsl:variable name="menu2" select="substring-before($menu11, '\')"/>
                                                        <xsl:variable name="menu22" select="substring-after($menu11, '\')"/>
                                                        <xsl:variable name="menu3" select="substring-before($menu22, '\')"/>										
                                                        <xsl:variable name="menu33" select="substring-after($menu22, '\')"/>
                                                        <xsl:variable name="menu4" select="substring-before($menu33, '\')"/>
                                                        <xsl:variable name="menu44" select="substring-after($menu33, '\')"/>	
                                                        <xsl:variable name="menu5" select="substring-before($menu44, '\')"/>
                                                        <xsl:variable name="menu55" select="substring-after($menu44, '\')"/>
                                                        <xsl:variable name="menu6" select="substring-before($menu55, '\')"/>
                                                        <xsl:variable name="menu66" select="substring-after($menu55, '\')"/>
                                                        <xsl:variable name="menu7" select="substring-before($menu66, '\')"/>
                                                        <xsl:variable name="menu77" select="substring-after($menu66, '\')"/>	
                                                        <xsl:variable name="menu8" select="substring-before($menu77, '\')"/>
                                                        <xsl:if test="$menu1=''"><xsl:value-of select="$menu"/></xsl:if>
                                                        <xsl:if test="$menu1 !=''"><xsl:value-of select="$menu1"/></xsl:if>
                                                        <xsl:if test="($menu11 !='' or $menu2 !='')"><xsl:value-of select="$kier"/></xsl:if>
                                                        <xsl:if test="$menu2 !=''"><xsl:value-of select="$menu2"/></xsl:if>
                                                        <xsl:if test="$menu11 !='' and $menu2=''"><xsl:value-of select="$menu11"/></xsl:if>
                                                        <xsl:if test="($menu22 !='' or $menu3 !='')"><xsl:value-of select="$kier"/></xsl:if>
                                                        <xsl:if test="$menu3 !=''"><xsl:value-of select="$menu3"/></xsl:if>
                                                        <xsl:if test="$menu22 !='' and $menu3=''"><xsl:value-of select="$menu22"/></xsl:if>
                                                        <xsl:if test="($menu33 !='' or $menu4 !='')"><xsl:value-of select="$kier"/></xsl:if>
                                                        <xsl:if test="$menu4 !=''"><xsl:value-of select="$menu4"/></xsl:if>
                                                        <xsl:if test="$menu33 !='' and $menu4=''"><xsl:value-of select="$menu33"/></xsl:if>
                                                        <xsl:if test="($menu44 !='' or $menu5 !='')"><xsl:value-of select="$kier"/></xsl:if>	
                                                        <xsl:if test="$menu5 !=''"><xsl:value-of select="$menu5"/></xsl:if>
                                                        <xsl:if test="$menu44 !='' and $menu5=''"><xsl:value-of select="$menu44"/></xsl:if>
                                                        <xsl:if test="($menu55 !='' or $menu6 !='')"><xsl:value-of select="$kier"/></xsl:if>
                                                        <xsl:if test="$menu6 !=''"><xsl:value-of select="$menu6"/></xsl:if>
                                                        <xsl:if test="$menu55 !='' and $menu6=''"><xsl:value-of select="$menu55"/></xsl:if>
                                                        <xsl:if test="($menu66 !='' or $menu7 !='')"><xsl:value-of select="$kier"/></xsl:if>
                                                        <xsl:if test="$menu7 !=''"><xsl:value-of select="$menu7"/></xsl:if>
                                                        <xsl:if test="$menu66 !='' and $menu7=''"><xsl:value-of select="$menu66"/></xsl:if>
                                                        <xsl:if test="($menu77 !='' or $menu8 !='')"><xsl:value-of select="$kier"/></xsl:if>
                                                        <xsl:if test="$menu8 !=''"><xsl:value-of select="$menu8"/></xsl:if>
                                                        <xsl:if test="$menu77 !='' and $menu8=''"><xsl:value-of select="$menu77"/></xsl:if>																
                                                    </xsl:element>
                                                </xsl:if>
                                            </xsl:for-each>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:element name="g:product_type">
                                                <xsl:choose>
                                                    <xsl:when test="contains(../../category/@name, '*')">	
                                                        <xsl:value-of select="substring-after(../../category/@name, '*')"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:variable name="category" select="normalize-space(../../category/@name)"/>
                                                        <xsl:variable name="cat1" select="substring-before($category, '/')"/>
                                                        <xsl:variable name="cat11" select="substring-after($category, '/')"/>
                                                        <xsl:variable name="cat2" select="substring-before($cat11, '/')"/>
                                                        <xsl:variable name="cat22" select="substring-after($cat11, '/')"/>
                                                        <xsl:variable name="cat3" select="substring-before($cat22, '/')"/>										
                                                        <xsl:variable name="cat33" select="substring-after($cat22, '/')"/>
                                                        <xsl:variable name="cat4" select="substring-before($cat33, '/')"/>
                                                        <xsl:variable name="cat44" select="substring-after($cat33, '/')"/>	
                                                        <xsl:variable name="cat5" select="substring-before($cat44, '/')"/>
                                                        <xsl:variable name="cat55" select="substring-after($cat44, '/')"/>
                                                        <xsl:variable name="cat6" select="substring-before($cat55, '/')"/>
