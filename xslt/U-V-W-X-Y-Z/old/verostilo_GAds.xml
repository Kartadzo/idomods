<xsl:stylesheet version="1.0"
                xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
                xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
                xmlns:php="http://php.net/xsl">
  <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />
  
  <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
  <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
  <!-- długoś opisu -->
  <xsl:variable name='dlugosc_opisu'>1200</xsl:variable>
  <!-- słowa formatowane do pisanych z dużej litery w tytule -->
  <xsl:variable name="corrected" select="'GRATIS'"/>
  <!-- kwoty stawek wysyłek do ustalenia -->
  <xsl:variable name='Kwota_za_darmo_wysylka'>5.00</xsl:variable>
  <xsl:variable name='Kwota_za_darmo_wysylka_large'>5.00</xsl:variable>
  <xsl:variable name="Kwota_wysylki">0.00</xsl:variable>
  <xsl:variable name="Kwota_wysylki_large">0.00</xsl:variable>
  
  <xsl:template match="/">
    <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
      <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
      <channel>
        <title>Verostilo.com</title>
        <link>https://verostilo.com/</link>
        <description>Produkty ze sklepu https://verostilo.com/</description>
        
        <xsl:for-each select="/offer/products/product">
          <xsl:for-each select="sizes/size">
            <item>
              <!--Unikalny identyfikator produktu  -->
              <g:id>
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:value-of select="@code"/>
                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
              </g:id>
              
              <!-- 20.01.2026 MD -->
              <xsl:choose>
                <xsl:when test="../../iaiext:last_purchase_price/@gross 
                                and ../../iaiext:last_purchase_price/@gross > 0">
                  <xsl:element name="g:cost_of_goods_sold">
                    <xsl:value-of select="../../iaiext:last_purchase_price/@gross" />
                    <xsl:text><![CDATA[ ]]></xsl:text>
                    <xsl:value-of select="../../@currency" />
                  </xsl:element>
                </xsl:when>
                <xsl:when test="../../iaiext:price_minimal/iaiext:site/@gross != '' 
                                and ../../iaiext:price_minimal/iaiext:site/@gross > 0">
                  <xsl:element name="g:cost_of_goods_sold">
                    <xsl:value-of select="../../iaiext:price_minimal/iaiext:site/@gross" />
                    <xsl:text><![CDATA[ ]]></xsl:text>
                    <xsl:value-of select="../../@currency" />  
                  </xsl:element>                  
                </xsl:when>
              </xsl:choose>
              
              <!-- Tytuł -->
              <g:title>
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:call-template name="wordFormat">
                  <xsl:with-param name="text" select="../../description/name/." tunnel="yes"/>
                </xsl:call-template>
                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
              </g:title>
              <!-- Opis -->
              <!-- short descr -->
              <xsl:variable name="from_parameters_raw">
                <xsl:for-each select="../../parameters/parameter[@hide = 'n' and value/@name != '']">
                  <xsl:text>&#xa;</xsl:text>
                  <xsl:value-of select="@name"/>
                  <xsl:text>: </xsl:text>
                  <xsl:for-each select="value">
                    <xsl:value-of select="@name"/>
                    <xsl:text>; </xsl:text>
                  </xsl:for-each>
                </xsl:for-each>
              </xsl:variable>
              <xsl:variable name="from_parameters">
                <xsl:choose>
                  <xsl:when test="$from_parameters_raw != ''">
                    <xsl:call-template name="tokenize">
                      <xsl:with-param name="text" select="substring($from_parameters_raw, 1, 600)"/>
                      <xsl:with-param name="delimeter" select="' '"/>
                    </xsl:call-template>
                  </xsl:when>
                  <xsl:otherwise>
                    <xsl:text></xsl:text>
                  </xsl:otherwise>
                </xsl:choose>
              </xsl:variable>
              <g:description>
                <xsl:choose>
                  <xsl:when test="../../description/short_desc = '' and ../../description/long_desc = ''">
                    <!-- nie jest git bo nie ma opisów  -->
                    <xsl:if test="$from_parameters != ''">
                      <xsl:value-of select="../../description/name"/>
                      <xsl:value-of select="$from_parameters"/>
                    </xsl:if>
                  </xsl:when>
                  <xsl:when test="../../description/short_desc = ''">
                    <xsl:variable name = "returned_value_without_html">
                      <xsl:call-template name="strip-tags">
                        <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                      </xsl:call-template>
                    </xsl:variable>
                    <xsl:variable name="returned_value_x_char" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                    <xsl:variable name="value_cut">
                      <xsl:call-template name="tokenize">
                        <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                      </xsl:call-template>
                    </xsl:variable>
                    <xsl:variable name="last_char" select="substring($returned_value_x_char, string-length($returned_value_x_char), 1)"/>
                    <xsl:choose>
                      <xsl:when test="$last_char != '.'">
                        <!-- chodzi oto ze nie ma przed kropka nic  -->
                        <xsl:choose>
                          <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut)) = ''">
                            <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="$returned_value_x_char"/>
                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; 600 and $from_parameters != ''">
                              <xsl:text>&#xa;</xsl:text>
                              <xsl:value-of select="../../description/name"/>
                              <xsl:value-of select="$from_parameters"/>
                            </xsl:if>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                          </xsl:when>
                          <xsl:otherwise>
                            <!-- jest przed kropka text -->
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))"/>
                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; 600 and $from_parameters != ''">
                              <xsl:text>&#xa;</xsl:text>
                              <xsl:value-of select="../../description/name"/>
                              <xsl:value-of select="$from_parameters"/>
                            </xsl:if>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                          </xsl:otherwise>
                        </xsl:choose>
                      </xsl:when>
                      <xsl:otherwise>
                        <!-- Mamy kropke na koncu i jest git -->
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="$returned_value_x_char"/>
                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; 600 and $from_parameters != ''">
                          <xsl:text>&#xa;</xsl:text>
                          <xsl:value-of select="../../description/name"/>
                          <xsl:value-of select="$from_parameters"/>
                        </xsl:if>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                      </xsl:otherwise>
                    </xsl:choose>
                  </xsl:when>
                  <xsl:otherwise>
                    <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                    <!-- załóżmy -->
                    <xsl:choose>
                      <xsl:when test="string-length(../../description/short_desc) > 300">
                        <!-- jest git bo ma wiecej niz  -->
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="../../description/short_desc"/>
                        <xsl:if test="string-length(../../description/short_desc) &lt; 600 and $from_parameters != ''">
                          <xsl:text>&#xa;</xsl:text>
                          <xsl:value-of select="../../description/name"/>
                          <xsl:value-of select="$from_parameters"/>
                        </xsl:if>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                      </xsl:when>
                      <xsl:otherwise>
                        <xsl:variable name = "returned_value_without_html">
                          <xsl:call-template name="strip-tags">
                            <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                          </xsl:call-template>
                        </xsl:variable>
                        <xsl:variable name="returned_value_x_char" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                        <xsl:variable name="value_cut">
                          <xsl:call-template name="tokenize">
                            <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                          </xsl:call-template>
                        </xsl:variable>
                        <xsl:variable name="last_char" select="substring($returned_value_x_char, string-length($returned_value_x_char), 1)"/>
                        <xsl:choose>
                          <xsl:when test="$last_char != '.'">
                            <!-- chodzi oto ze nie ma przed kropka nic  -->
                            <xsl:choose>
                              <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut)) = ''">
                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="$returned_value_x_char"/>
                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                  <xsl:text>&#xa;</xsl:text>
                                  <xsl:value-of select="../../description/name"/>
                                  <xsl:value-of select="$from_parameters"/>
                                </xsl:if>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                              </xsl:when>
                              <xsl:otherwise>
                                <!-- jest przed kropka text -->
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))"/>
                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; 600 and $from_parameters != ''">
                                  <xsl:text>&#xa;</xsl:text>
                                  <xsl:value-of select="../../description/name"/>
                                  <xsl:value-of select="$from_parameters"/>
                                </xsl:if>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                              </xsl:otherwise>
                            </xsl:choose>
                          </xsl:when>
                          <xsl:otherwise>
                            <!-- Mamy kropke na koncu i jest git -->
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="$returned_value_x_char"/>
                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; 600 and $from_parameters != ''">
                              <xsl:text>&#xa;</xsl:text>
                              <xsl:value-of select="../../description/name"/>
                              <xsl:value-of select="$from_parameters"/>
                            </xsl:if>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                          </xsl:otherwise>
                        </xsl:choose>
                      </xsl:otherwise>
                    </xsl:choose>
                  </xsl:otherwise>
                </xsl:choose>
              </g:description>
              <!-- g product type -->
              <xsl:for-each select="../../iaiext:navigation/iaiext:site[1]/iaiext:menu">
                <xsl:for-each select="iaiext:item[position() &lt; 10]">
                  <g:product_type>
                    <!-- <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> -->
                    <xsl:value-of select="translate(@textid,'\','&gt;')"/>
                    <!-- <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> -->
                  </g:product_type>
                </xsl:for-each>
              </xsl:for-each>
              <!-- link do produktu -->
              <!-- WYMAGANY: Link do produktu -->
              <!-- pl zzamienic na jezyk ktory bedziemy realizować -->
              <g:link>
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                <xsl:text disable-output-escaping="yes">.googleshoppingpl.html]]&gt;</xsl:text>
              </g:link>
              <!-- display ads link -->
              <!-- to samo pl zamienic na jezyk ktory bedziemy obslugiwac -->
              <g:display_ads_link>
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                <xsl:text disable-output-escaping="yes">.googleshoppingpl.html]]&gt;</xsl:text>
              </g:display_ads_link>
              <!-- mobile link -->
              <g:mobile_link>
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                <xsl:text disable-output-escaping="yes">.googleshoppingpl.html]]&gt;</xsl:text>
              </g:mobile_link>
              
              <xsl:choose>
                <xsl:when test="../../images/icons/auction_icon/@url">
                  <g:image_link>
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                    <xsl:value-of select="../../images/icons/auction_icon/@url"></xsl:value-of>
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                  </g:image_link>
                  <xsl:for-each select="../../images/large/image[position() &lt; 5]">
                    <g:additional_image_link>
                      <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                      <xsl:value-of select="@url"/>
                      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </g:additional_image_link>
                  </xsl:for-each>
                </xsl:when>
                <xsl:otherwise>
                  <xsl:variable name="vLowest">
                    <xsl:for-each select="../../images/large/image/@iaiext:priority">
                      <xsl:sort data-type="number"/>
                      <xsl:if test="position()=1">
                        <xsl:value-of select="."/>
                      </xsl:if>
                    </xsl:for-each>
                  </xsl:variable>
                  
                  <xsl:for-each select="../../images/large/image[position() &lt; 5]">
                    <xsl:choose>
                      <xsl:when test="@iaiext:priority = number($vLowest)">
                        <g:image_link>
                          <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                          <xsl:value-of select="@url"/>
                          <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </g:image_link>
                      </xsl:when>
                      <xsl:otherwise>
                        <g:additional_image_link>
                          <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                          <xsl:value-of select="@url"/>
                          <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </g:additional_image_link>
                      </xsl:otherwise>
                    </xsl:choose>
                  </xsl:for-each>
                </xsl:otherwise>
              </xsl:choose>
              
              <!-- 2026-05-11 MD -->
              <xsl:for-each select="../../attachments/file[@attachment_file_type = 'video']">
                <xsl:choose>
                  <xsl:when test="@url != ''">
                    <xsl:element name="g:video_link">
                      <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                      <xsl:value-of select="@url" />
                      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </xsl:element>
                  </xsl:when>
                </xsl:choose>
              </xsl:for-each> 
              
              <!-- stan -->
              <g:condition>
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[new]]&gt;</xsl:text>
              </g:condition>
              <!-- Dostępność -->
              <g:availability>
                <xsl:choose>
                  <xsl:when test="@available = 'on_order'">
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                  </xsl:when>
                  <xsl:when test="@available = 'in_stock'">
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                  </xsl:when>
                  <xsl:otherwise>
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[out of stock]]&gt;</xsl:text>
                  </xsl:otherwise>
                </xsl:choose>
              </g:availability>
              <xsl:variable name="cena_serwis">
                <xsl:choose>
                  <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                    <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site/@gross"/>
                  </xsl:when>
                  <xsl:otherwise>
                    <xsl:text>0</xsl:text>
                  </xsl:otherwise>
                </xsl:choose>
              </xsl:variable>
              <xsl:variable name="mainPrice">
                <xsl:choose>
                  <xsl:when test="../../strikethrough_retail_price and  ../../strikethrough_retail_price/@gross > 0 and
                                  ../../strikethrough_retail_price/@gross > price/@gross and 
                                  price/@gross = ../../price/@gross and 
                                  ../../strikethrough_retail_price/@gross > $cena_serwis">
                    <xsl:choose>
                      <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                        <xsl:value-of select="../../strikethrough_retail_price/@gross"/>
                      </xsl:when>
                      <xsl:otherwise>
                        <xsl:value-of select="price/@gross"/>
                      </xsl:otherwise>
                    </xsl:choose>
                  </xsl:when>
                  <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and ../../price/@gross = price/@gross">
                    <xsl:choose>
                      <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                      </xsl:when>
                      <xsl:otherwise>
                        <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                      </xsl:otherwise>
                    </xsl:choose>
                  </xsl:when>
                  <xsl:when test="price/@gross">
                    <xsl:choose>
                      <xsl:when test="price/@gross != ../../price/@gross and
                                      ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                        <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                      </xsl:when>
                      <xsl:when test="price/@gross = ../../price/@gross and
                                      ../../promotion/price/normal_retail_price/@gross > price/@gross">
                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                      </xsl:when>
                      <xsl:otherwise>
                        <xsl:value-of select="price/@gross"/>
                      </xsl:otherwise>
                    </xsl:choose>
                  </xsl:when>
                </xsl:choose>
              </xsl:variable>
              <g:price>
                <xsl:value-of select="$mainPrice"/>
                <xsl:text><![CDATA[ ]]></xsl:text>
                <xsl:value-of select="../../@currency"/>
              </g:price>
              <xsl:choose>
                <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka">
                  <g:shipping>
                    <g:price>
                      <xsl:text><![CDATA[0 ]]></xsl:text>
                      <xsl:value-of select="../../@currency"/>
                    </g:price>
                    <g:country>PL</g:country>
                  </g:shipping>
                </xsl:when>
                <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka_large">
                  <g:shipping>
                    <g:price>
                      <xsl:value-of select="$Kwota_wysylki_large"/>
                      <xsl:text><![CDATA[ ]]></xsl:text>
                      <xsl:value-of select="../../@currency"/>
                    </g:price>
                    <g:country>PL</g:country>
                  </g:shipping>
                </xsl:when>
                <xsl:otherwise>
                  <g:shipping>
                    <g:price>
                      <xsl:value-of select="$Kwota_wysylki"/>
                      <xsl:text><![CDATA[ ]]></xsl:text>
                      <xsl:value-of select="../../@currency"/>
                    </g:price>
                    <g:country>PL</g:country>
                  </g:shipping>
                </xsl:otherwise>
              </xsl:choose>
              <!-- produkcja -->
              <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
              <xsl:if test="../../promotion/price/normal_retail_price or ../../strikethrough_retail_price">
                <xsl:choose>
                  <xsl:when test = "
                              (../../strikethrough_retail_price and ../../strikethrough_retail_price/@gross > price/@gross) or
                              (../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross) or
                              (../../promotion/price/normal_retail_price and ../../price/@gross != price/@gross and 
                              ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross)">
                    <g:sale_price>
                      <xsl:value-of select="price/@gross"/>
                      <xsl:text><![CDATA[ ]]></xsl:text>
                      <xsl:value-of select="../../@currency"/>
                    </g:sale_price>
                  </xsl:when>
                </xsl:choose>
              </xsl:if>
              <!--Versja 2.0  -->
              <xsl:choose>
                <xsl:when test="@code_producer and @code_producer!=''">
                  <!-- mamy kod producenta -->
                  <!-- format-number(@code_on_card, '#')" -->
                  <xsl:variable name="code_producer_variable">
                    <xsl:value-of select="@code_producer"></xsl:value-of>
                  </xsl:variable>
                  <xsl:variable name="kod_producer" select="substring-after($code_producer_variable, substring-before($code_producer_variable, substring(translate($code_producer_variable, '0', ''), 1, 1)))">
                  </xsl:variable>
                  
                  <xsl:choose>
                    <xsl:when test="string-length($kod_producer) = '14' or string-length($kod_producer) = '13' or string-length($kod_producer) = '12' or string-length($kod_producer) = '8'">
                      <g:gtin>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="$kod_producer"/>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                      </g:gtin>
                    </xsl:when>
                    <xsl:otherwise>
                      <g:mpn>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="$kod_producer"/>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                      </g:mpn>
                    </xsl:otherwise>
                  </xsl:choose>
                </xsl:when>
                <xsl:otherwise>
                  <xsl:variable name="code_producer_variable2">
                    <xsl:value-of select="../../@code_on_card"></xsl:value-of>
                  </xsl:variable>
                  <xsl:variable name="code_on_card" select="substring-after($code_producer_variable2, substring-before($code_producer_variable2, substring(translate($code_producer_variable2, '0', ''), 1, 1)))"></xsl:variable>
                  <!-- tutaj uzyjemy code on card -->
                  
                  <xsl:choose>
                    <xsl:when test="string-length($code_on_card) = '14' or string-length($code_on_card) = '13' or string-length($code_on_card) = '12' or string-length($code_on_card) = '8'">
                      <g:gtin>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="$code_on_card"/>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                      </g:gtin>
                    </xsl:when>
                    <xsl:otherwise>
                      <g:mpn>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
