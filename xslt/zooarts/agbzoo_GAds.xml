<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml" xmlns:php="http://php.net/xsl">
  <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />
  <xsl:template match="/">
  <rss xmlns:g="http://base.google.com/ns/1.0"  version="2.0">
    <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
    <channel>
      <title>AgbZoo.co.uk/</title>
		  <link>https://agbzoo.co.uk/</link>
		  <description>Produkty ze sklepu https://agbzoo.co.uk/</description>
        <xsl:for-each select="/offer/products/product">
          <xsl:for-each select="sizes/size">
            <item>
              <xsl:variable name='Kwota_za_darmo_wysylka'>38.00</xsl:variable>
              <xsl:variable name="Kwota_wysylki">2.98</xsl:variable>
              <xsl:variable name="Kwota_wysylki_large">2.98</xsl:variable>
              <xsl:variable name='Kwota_za_darmo_wysylka_large'>5.00</xsl:variable>
              <!--Unikalny identyfikator produktu  -->
              <g:id> 
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>    
                <xsl:value-of select="@code"></xsl:value-of>   
                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
              </g:id>

              <xsl:choose>
                <!-- kiedy hurtowa cena detaliczna -->
                  <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                    <xsl:choose>
                      <!-- kiedy cena promocyjna jest wieksza niz cena dla serwisu zewnetrznego -->
                      <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                        <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="../../promotion/price/normal_retail_price/@gross"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                        <!-- zaczyna sie dostawa -->
                        <xsl:choose>
                          <xsl:when test="../../promotion/price/normal_retail_price/@gross >= $Kwota_za_darmo_wysylka">
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:text>0<![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:when>
                          <xsl:when test="../../romotion/price/normal_retail_price/@gross >= $Kwota_za_darmo_wysylka_large">
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:when>
                          <xsl:otherwise>
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki_large"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:otherwise>
                        </xsl:choose>
                        <!-- koniec dostawy -->
                      </xsl:when>
                      <!-- inaczej bierze cena dla serwisu zewnetrznego -->
                      <xsl:otherwise>
                        <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                        <!-- początek dostawy -->
                        <xsl:choose>
                          <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross >= $Kwota_za_darmo_wysylka">
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:text>0<![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:when>
                          <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross >= $Kwota_za_darmo_wysylka_large">
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:when>
                          <xsl:otherwise>
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki_large"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:otherwise>
                        </xsl:choose>
                        <!-- koniec dostawy -->
                      </xsl:otherwise>
                    </xsl:choose>
                  </xsl:when>
                  <!-- kiedy nie wystepuje hurtowa cena detaliczna -->
                  <xsl:when test="../../price/@gross">
                    <xsl:choose>
                      <!-- kiedy promocyjna bedzie wieksza  -->
                      <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../price/@gross">
                        <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="../../promotion/price/normal_retail_price/@gross"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                        <!-- poczatek dostawy -->
                        <xsl:choose>
                          <xsl:when test="../../promotion/price/normal_retail_price/@gross >= $Kwota_za_darmo_wysylka">
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:text>0<![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:when>
                          <xsl:when test="../../promotion/price/normal_retail_price/@gross >= $Kwota_za_darmo_wysylka_large">
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:when>
                          <xsl:otherwise>
                            <g:shipping>
                              <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki_large"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                              <g:country>GB</g:country>
                            </g:shipping>
                          </xsl:otherwise>
                        </xsl:choose>
                        <!-- koniec dostawy -->
                      </xsl:when>
                      <xsl:otherwise>
                      <!-- bierzemy normalna price/gorss -->
                      <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="../../price/@gross"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                      <!-- poczatek dostawy -->
                      <xsl:choose>
                        <xsl:when test="../../price/@gross >= $Kwota_za_darmo_wysylka">
                          <g:shipping>
                            <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:text>0<![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                            <g:country>GB</g:country>
                          </g:shipping>
                        </xsl:when>
                        <xsl:when test="../../price/@gross >= $Kwota_za_darmo_wysylka_large">
                          <g:shipping>
                            <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                            <g:country>GB</g:country>
                          </g:shipping>
                        </xsl:when>
                        <xsl:otherwise>
                          <g:shipping>
                            <g:price><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$Kwota_wysylki_large"></xsl:value-of><xsl:text><![CDATA[ ]]></xsl:text><xsl:value-of select="../../@currency"/>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:price>
                            <g:country>GB</g:country>
                          </g:shipping>
                        </xsl:otherwise>
                      </xsl:choose>
                      <!-- koniec dostawy -->
                    </xsl:otherwise>
                  </xsl:choose>
                </xsl:when>
              </xsl:choose>

              <!-- waga sizes/size/@weight-->                      
              <xsl:variable name="value_of_weight" select="@weight"></xsl:variable>                     
              <xsl:variable name="value_of_weight_to_kg" select="$value_of_weight div 1000"></xsl:variable>

              <xsl:variable name="to_3_point_after_decimal" select="format-number($value_of_weight_to_kg , '#.00000')"></xsl:variable>
              <xsl:variable name="after_dots" select="substring-after($to_3_point_after_decimal,'.')"></xsl:variable>
              <!-- ruszyc przecinek do lewej dwa razy bo aby dwa miejsca bedziemy zostawiac -->
              <xsl:variable name="move_decimal_to_left_2_point" select="$after_dots div 1000"></xsl:variable>
              <!-- tutaj pobieram wartosc 3 miejsca po przecinku i sprawdzam czy trzeba zaokraglic druga liczbe czy nie -->
              <xsl:variable name="value_if_round" select="substring-after($move_decimal_to_left_2_point,'.')"></xsl:variable>
              <!-- wartosci po pierwszej cyfrze after decimal -->
              <xsl:variable name="current_second_and_more_decimal_value" select="substring-after(($value_of_weight_to_kg)*10,'.')"></xsl:variable>

              <xsl:choose>
                <xsl:when test="$current_second_and_more_decimal_value != '' and $value_if_round != ''">
                  <xsl:variable name="real_second_number_after_decimal" select="substring-before(($current_second_and_more_decimal_value)div10,'.')"></xsl:variable>
                  <xsl:variable name="real_first_number_after_decimal" select="substring-after(substring-before($value_of_weight_to_kg *10,'.')div 10,'.')"></xsl:variable>

                  <xsl:choose>
                    <xsl:when test="$real_second_number_after_decimal = '0' and $real_first_number_after_decimal = ''">
                      <g:shipping_weight>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>
                        <xsl:text disable-output-escaping="yes">.01 kg]]&gt;</xsl:text>
                      </g:shipping_weight>
                    </xsl:when>
                    <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal != '9' and $real_first_number_after_decimal=''">
                      <g:shipping_weight>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>
                        <xsl:text disable-output-escaping="yes">.1 kg]]&gt;</xsl:text>
                      </g:shipping_weight>
                    </xsl:when>
                    <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal != '9' and $real_first_number_after_decimal!=''">
                      <g:shipping_weight>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal +1"></xsl:value-of>
                        <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                      </g:shipping_weight>
                    </xsl:when>
                    <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal = '9'">
                      <g:shipping_weight>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="ceiling($value_of_weight_to_kg)"></xsl:value-of>
                        <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                      </g:shipping_weight>
                    </xsl:when>
                    <xsl:otherwise>
                      <xsl:choose>
                        <xsl:when test="$real_first_number_after_decimal = ''">
                          <g:shipping_weight>
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.0<xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of>
                            <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                          </g:shipping_weight>
                          <xsl:if test="../../parameters/parameter[@name='Weight']/value/@name > 0">
                            <g:unit_pricing_measure>
                              <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                              <xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.0<xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of>
                              <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                            </g:unit_pricing_measure>
                            <g:unit_pricing_base_measure>
                              <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 kg]]&gt;</xsl:text>
                            </g:unit_pricing_base_measure>
                          </xsl:if>
                        </xsl:when>
                        <xsl:otherwise>
                          <g:shipping_weight>
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal"></xsl:value-of>
                            <xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of>
                            <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                          </g:shipping_weight>
                          <xsl:if test="../../parameters/parameter[@name='Weight']/value/@name > 0">
                            <g:unit_pricing_measure>
                              <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                              <xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal"></xsl:value-of>
                              <xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of>
                              <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                            </g:unit_pricing_measure>
                            <g:unit_pricing_base_measure>
                              <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 kg]]&gt;</xsl:text>
                            </g:unit_pricing_base_measure>
                          </xsl:if>
                        </xsl:otherwise>
                      </xsl:choose>
                    </xsl:otherwise>
                  </xsl:choose>
                </xsl:when>
                <xsl:otherwise>
                  <xsl:variable name="read_value_to_two_decimal_point" select="format-number($value_of_weight_to_kg , '#.00')"></xsl:variable>
                  <xsl:choose>
                    <xsl:when test="substring-before($read_value_to_two_decimal_point, '.') = ''">
                      <g:shipping_weight>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[0</xsl:text>
                        <xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of>
                        <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                      </g:shipping_weight>
                      <xsl:if test="../../parameters/parameter[@name='Weight']/value/@name > 0">
                        <g:unit_pricing_measure>
                          <xsl:text disable-output-escaping="yes">&lt;![CDATA[0</xsl:text>
                          <xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of>
                          <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                        </g:unit_pricing_measure>
                        <g:unit_pricing_base_measure>
                          <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 kg]]&gt;</xsl:text>
                        </g:unit_pricing_base_measure>
                      </xsl:if>
                    </xsl:when>
                    <xsl:otherwise>
                      <g:shipping_weight>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of>
                        <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                      </g:shipping_weight>
                      <xsl:if test="../../parameters/parameter[@name='Weight']/value/@name > 0">
                        <g:unit_pricing_measure>
                          <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                          <xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of>
                          <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                        </g:unit_pricing_measure>
                        <g:unit_pricing_base_measure>
                          <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 kg]]&gt;</xsl:text>
                        </g:unit_pricing_base_measure>
                      </xsl:if>
                    </xsl:otherwise>
                  </xsl:choose>
                </xsl:otherwise>
              </xsl:choose>
            </item>
          </xsl:for-each>
        </xsl:for-each>
      </channel>
    </rss>
  </xsl:template>
</xsl:stylesheet>