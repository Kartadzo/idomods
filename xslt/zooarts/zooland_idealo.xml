                                            <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_600_char), $value_cut))"/>
                                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_600_char), $value_cut))) &lt; 400 and $from_parameters != ''">
