                                        <xsl:value-of select="normalize-space(translate($tempInfoOGratisie,concat($upperLetters,$lowerLetters),''))"/>
                                    </xsl:when>
                                    <xsl:when test="contains(substring-after(../../description/name/., '+'),'4x') and contains(translate(../../description/name/.,$upperLetters,$lowerLetters),'gratis')">
                                        <xsl:variable name='infoOGratisie'>
                                            <xsl:value-of select="substring-after(../../description/name/., '+')"/>
                                        </xsl:variable>
                                        <xsl:variable name='tempInfoOGratisie'>
                                            <xsl:value-of select="substring-before($infoOGratisie, 'x')"/>
                                        </xsl:variable>
                                        <xsl:value-of select="normalize-space(translate($tempInfoOGratisie,concat($upperLetters,$lowerLetters),''))"/>
                                    </xsl:when>
                                    <xsl:when test="contains(substring-after(../../description/name/., '+'),'3x') and contains(translate(../../description/name/.,$upperLetters,$lowerLetters),'gratis')">
                                        <xsl:variable name='infoOGratisie'>
                                            <xsl:value-of select="substring-after(../../description/name/., '+')"/>
                                        </xsl:variable>
                                        <xsl:variable name='tempInfoOGratisie'>
                                            <xsl:value-of select="substring-before($infoOGratisie, 'x')"/>
                                        </xsl:variable>
                                        <xsl:value-of select="normalize-space(translate($tempInfoOGratisie,concat($upperLetters,$lowerLetters),''))"/>
                                    </xsl:when>
                                    <xsl:when test="contains(substring-after(../../description/name/., '+'),'2x')">
                                        <xsl:variable name='infoOGratisie'>
                                            <xsl:value-of select="substring-after(../../description/name/., '+')"/>
                                        </xsl:variable>
                                        <xsl:variable name='tempInfoOGratisie'>
                                            <xsl:value-of select="substring-before($infoOGratisie, 'x')"/>
                                        </xsl:variable>
                                        <xsl:value-of select="normalize-space(translate($tempInfoOGratisie,concat($upperLetters,$lowerLetters),''))"/>
                                    </xsl:when>
                                    <xsl:when test="count(../../iaiext:bundled[@type='specified']/product) > 1">
                                        <xsl:text>1</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text>0</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>0</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="count(../../iaiext:bundled[@type='specified']/product) >= 1 and format-number(sum(../../iaiext:bundled/product/@quantity)-$throwGratis, '#') > 1">
                            <xsl:value-of select="format-number(sum(../../iaiext:bundled/product/@quantity)-$throwGratis, '#')"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:text>1</xsl:text>
                        </xsl:otherwise>
                    </xsl:choose>
                </QUANTITY>
                <!-- CENA ZA KG -->

                <xsl:if test="../../parameters/parameter[@name='Gewicht']/value/@name &gt; 0">
                <xsl:choose>                                     
                    <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                        <xsl:choose>  
                            <xsl:when test="../../iaiext:promotion/iaiext:price/@normal_price &gt; ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                    <BASEPRICE><xsl:value-of select="format-number(../../iaiext:promotion/iaiext:price/@normal_price div ../../parameters/parameter[@name='Gewicht']/value/@name div 0.001, '#.00')"/>
                                        <xsl:text><![CDATA[ EUR/Kg]]></xsl:text></BASEPRICE>
                            </xsl:when>
                            <xsl:otherwise> 
                                <xsl:for-each select="../../iaiext:pricecomparator_price/iaiext:site[1]">
                                    <BASEPRICE><xsl:value-of select="format-number(@gross div ../../parameters/parameter[@name='Gewicht']/value/@name div 0.001, '#.00')"/>
                                        <xsl:text><![CDATA[ EUR/Kg]]></xsl:text></BASEPRICE>
                                </xsl:for-each> 
                            </xsl:otherwise>  
                        </xsl:choose>
                    </xsl:when>
                    <xsl:when test="iaiext:price/@gross">
                        <xsl:choose>  
                            <xsl:when test="../../iaiext:promotion/iaiext:price/@normal_price &gt; iaiext:price/@gross">
                                    <BASEPRICE><xsl:value-of select="format-number(../../iaiext:promotion/iaiext:price/@normal_price div ../../parameters/parameter[@name='Gewicht']/value/@name div 0.001, '#.00')"/>
                                        <xsl:text><![CDATA[ EUR/Kg]]></xsl:text></BASEPRICE>
                            </xsl:when>
                            <xsl:otherwise> 
                                <BASEPRICE><xsl:value-of select="format-number(iaiext:price/@gross div ../../parameters/parameter[@name='Gewicht']/value/@name div 0.001, '#.00')"/>
                                    <xsl:text><![CDATA[ EUR/Kg]]></xsl:text></BASEPRICE> 
                            </xsl:otherwise>  
                        </xsl:choose>                        
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:choose>  
                            <xsl:when test="../../iaiext:promotion/iaiext:price/@normal_price &gt; ../../price/@gross">
                                    <BASEPRICE><xsl:value-of select="format-number(../../iaiext:promotion/iaiext:price/@normal_price div ../../parameters/parameter[@name='Gewicht']/value/@name div 0.001, '#.00')"/>
                                        <xsl:text><![CDATA[ EUR/Kg]]></xsl:text></BASEPRICE>
                            </xsl:when>
                            <xsl:otherwise> 
                                <BASEPRICE><xsl:value-of select="format-number(../../price/@gross div ../../parameters/parameter[@name='Gewicht']/value/@name div 0.001, '#.00')"/>
                                    <xsl:text><![CDATA[ EUR/Kg]]></xsl:text></BASEPRICE> 
                            </xsl:otherwise>  
                        </xsl:choose> 
                        
                    </xsl:otherwise>
                </xsl:choose>
                </xsl:if>

                 <!--  IDALO KUP TERAZ -->
                    <xsl:if test="../../parameters/parameter[@name='idealo']/value/@name &gt; 0">
                    <FULFILLMENTTYPE>Parcel_Service</FULFILLMENTTYPE>

                        <xsl:choose>
                            <xsl:when test="iaiext:stock/@quantity &lt; 0 or not(number(iaiext:stock/@quantity) = iaiext:stock/@quantity)"><CHECKOUTLIMITPERPERIOD>100</CHECKOUTLIMITPERPERIOD></xsl:when>
                            <xsl:otherwise>
                                <CHECKOUTLIMITPERPERIOD><xsl:value-of select="iaiext:stock/@quantity"/></CHECKOUTLIMITPERPERIOD>
                            </xsl:otherwise>
                        </xsl:choose>
      
                    </xsl:if> 
            </ARTICLE>

            </xsl:for-each>
        </xsl:for-each>

    </LIST>
  </xsl:template>
  <xsl:template name="strip-tags">
      <xsl:param name="text" />
      <xsl:param name="depth" select="0" />
      <xsl:choose>
          <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
              <xsl:value-of select="substring-before($text, '&lt;')" />
              <xsl:call-template name="strip-tags">
                  <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                  <xsl:with-param name="depth" select="$depth + 1" />
              </xsl:call-template>
          </xsl:when>
          <xsl:otherwise>
              <xsl:value-of select="normalize-space($text)" tunnel="true"/>
          </xsl:otherwise>
      </xsl:choose>
  </xsl:template>


  <xsl:template name="tokenize">
    <xsl:param name="text"/>
    <xsl:param name="delimiter" select="'.'"/>
    <xsl:choose>
      <xsl:when test="contains($text, $delimiter)">
        <xsl:call-template name="tokenize">
          <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
        </xsl:call-template>
      </xsl:when>
      <xsl:otherwise>
        <xsl:value-of select="$text"/>
      </xsl:otherwise>
    </xsl:choose>
  </xsl:template>
</xsl:stylesheet>