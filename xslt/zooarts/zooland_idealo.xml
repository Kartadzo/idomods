                                    <xsl:variable name="value_cut">
                                        <xsl:call-template name="tokenize">
                                            <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,600)"/>
                                        </xsl:call-template>
                                    </xsl:variable>
                                    <xsl:variable name="last_char" select="substring($returned_value_600_char, string-length($returned_value_600_char), 1)"/>
                                    <xsl:choose>
                                        <xsl:when test="$last_char != '.'">
