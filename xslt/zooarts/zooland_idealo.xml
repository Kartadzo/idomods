                            <xsl:variable name="returned_value_600_char" select="substring(normalize-space($returned_value_without_html),1,600)"/>
                            <xsl:variable name="value_cut">
                                <xsl:call-template name="tokenize">
                                    <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,600)"/>
                                </xsl:call-template>
                            </xsl:variable>
                            <xsl:variable name="last_char" select="substring($returned_value_600_char, string-length($returned_value_600_char), 1)"/>
                            <xsl:choose>
                                <xsl:when test="$last_char != '.'">
                                    <!-- chodzi oto ze nie ma przed kropka nic  -->
                                    <xsl:choose>
                                        <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_600_char), $value_cut)) = ''">
                                            <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="$returned_value_600_char"/>
                                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_600_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                <xsl:text>&#xa;</xsl:text>
                                                <xsl:value-of select="../../description/name"/>
                                                <xsl:value-of select="$from_parameters"/>
                                            </xsl:if>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </xsl:when>
