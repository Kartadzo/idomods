<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'ŁÓŻKO/STÓŁ/KRZESŁO/FOTEL/ŁAWA/REGAŁ'"/>
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='Kwota_za_darmo_wysylka'>45.00</xsl:variable>
    <xsl:variable name='Kwota_za_darmo_wysylka_large'>5.00</xsl:variable>
    <xsl:variable name="Kwota_wysylki">5.90</xsl:variable>
    <xsl:variable name="Kwota_wysylki_large">5.90</xsl:variable>

    <xsl:template match="/">
        <mywebstore>
            <created_at>
                <xsl:value-of select="/offer/@generated"/>
            </created_at>
            <products>
                <xsl:for-each select="/offer/products/product">
                    <product>
                        <!--Unikalny identyfikator produktu  -->
                        <id>
                            <xsl:value-of select="@id"/>
                        </id>
                        <!-- Tytuł -->
                        <name>
                            <xsl:call-template name="wordFormat">
                                <xsl:with-param name="text" select="description/name/." tunnel="yes"/>
                            </xsl:call-template>
                        </name>
                        <!-- Opis -->
                        <!-- short descr -->
                        <xsl:variable name="from_parameters_raw">
                            <xsl:for-each select="parameters/parameter[@hide = 'n' and value/@name != '']">
                                <xsl:text>&#xa;</xsl:text>
                                <xsl:value-of select="@name"/>
                                <xsl:text>: </xsl:text>
                                <xsl:for-each select="value">
                                    <xsl:value-of select="@name"/>
                                    <xsl:text>; </xsl:text>
                                </xsl:for-each>
                            </xsl:for-each>
                        </xsl:variable>
                        <xsl:variable name="from_parameters">
                            <xsl:choose>
                                <xsl:when test="$from_parameters_raw != ''">
                                    <xsl:call-template name="tokenize">
                                        <xsl:with-param name="text" select="substring($from_parameters_raw, 1, 600)"/>
                                        <xsl:with-param name="delimeter" select="' '"/>
                                    </xsl:call-template>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:text></xsl:text>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:variable>
                        <description>
                            <xsl:choose>
                                <xsl:when test="description/short_desc = '' and description/long_desc = ''">
                                    <!-- nie jest git bo nie ma opisów  -->
                                    <xsl:if test="$from_parameters != ''">
                                        <xsl:value-of select="description/name"/>
                                        <xsl:value-of select="$from_parameters"/>
                                    </xsl:if>
                                </xsl:when>
                                <xsl:when test="description/short_desc = ''">
                                    <xsl:variable name = "returned_value_without_html">
                                        <xsl:call-template name="strip-tags">
                                            <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                                        </xsl:call-template>
                                    </xsl:variable>
                                    <xsl:variable name="returned_value_1500_char" select="substring(normalize-space($returned_value_without_html),1,1500)"/>
                                    <xsl:variable name="value_cut">
                                        <xsl:call-template name="tokenize">
                                            <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,1500)"/>
                                        </xsl:call-template>
                                    </xsl:variable>
                                    <xsl:variable name="last_char" select="substring($returned_value_1500_char, string-length($returned_value_1500_char), 1)"/>
                                    <xsl:choose>
                                        <xsl:when test="$last_char != '.'">
                                            <!-- chodzi oto ze nie ma przed kropka nic  -->
                                            <xsl:choose>
                                                <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut)) = ''">
                                                    <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                    <xsl:value-of select="$returned_value_1500_char"/>
                                                    <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                        <xsl:text>&#xa;</xsl:text>
                                                        <xsl:value-of select="description/name"/>
                                                        <xsl:value-of select="$from_parameters"/>
                                                    </xsl:if>
                                                </xsl:when>
                                                <xsl:otherwise>
                                                    <!-- jest przed kropka text -->
                                                    <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))"/>
                                                    <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                        <xsl:text>&#xa;</xsl:text>
                                                        <xsl:value-of select="description/name"/>
                                                        <xsl:value-of select="$from_parameters"/>
                                                    </xsl:if>
                                                </xsl:otherwise>
                                            </xsl:choose>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <!-- Mamy kropke na koncu i jest git -->
                                            <xsl:value-of select="$returned_value_1500_char"/>
                                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                <xsl:text>&#xa;</xsl:text>
                                                <xsl:value-of select="description/name"/>
                                                <xsl:value-of select="$from_parameters"/>
                                            </xsl:if>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:when>
                                <xsl:otherwise>
                                    <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                    <!-- załóżmy -->
                                    <xsl:choose>
                                        <xsl:when test="string-length(description/short_desc) > 200">
                                            <!-- jest git bo ma wiecej niz  -->
                                            <xsl:value-of select="description/short_desc"/>
                                            <xsl:if test="string-length(description/short_desc) &lt; 400 and $from_parameters != ''">
                                                <xsl:text>&#xa;</xsl:text>
                                                <xsl:value-of select="description/name"/>
                                                <xsl:value-of select="$from_parameters"/>
                                            </xsl:if>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:variable name = "returned_value_without_html">
                                                <xsl:call-template name="strip-tags">
                                                    <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                                                </xsl:call-template>
                                            </xsl:variable>
                                            <xsl:variable name="returned_value_1500_char" select="substring(normalize-space($returned_value_without_html),1,1500)"/>
                                            <xsl:variable name="value_cut">
                                                <xsl:call-template name="tokenize">
                                                    <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,1500)"/>
                                                </xsl:call-template>
                                            </xsl:variable>
                                            <xsl:variable name="last_char" select="substring($returned_value_1500_char, string-length($returned_value_1500_char), 1)"/>
                                            <xsl:choose>
                                                <xsl:when test="$last_char != '.'">
                                                    <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                    <xsl:choose>
                                                        <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut)) = ''">
                                                            <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                            <xsl:value-of select="$returned_value_1500_char"/>
                                                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                <xsl:text>&#xa;</xsl:text>
                                                                <xsl:value-of select="description/name"/>
                                                                <xsl:value-of select="$from_parameters"/>
                                                            </xsl:if>
                                                        </xsl:when>
                                                        <xsl:otherwise>
                                                            <!-- jest przed kropka text -->
                                                            <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))"/>
                                                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                <xsl:text>&#xa;</xsl:text>
                                                                <xsl:value-of select="description/name"/>
                                                                <xsl:value-of select="$from_parameters"/>
                                                            </xsl:if>
                                                        </xsl:otherwise>
                                                    </xsl:choose>
                                                </xsl:when>
                                                <xsl:otherwise>
                                                    <!-- Mamy kropke na koncu i jest git -->
                                                    <xsl:value-of select="$returned_value_1500_char"/>
                                                    <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_1500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                        <xsl:text>&#xa;</xsl:text>
                                                        <xsl:value-of select="description/name"/>
                                                        <xsl:value-of select="$from_parameters"/>
                                                    </xsl:if>
                                                </xsl:otherwise>
                                            </xsl:choose>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:otherwise>
                            </xsl:choose>
                        </description>
                        <!-- product type -->
                        <xsl:for-each select="iaiext:navigation/iaiext:site[1]/iaiext:menu">
                            <xsl:for-each select="iaiext:item[position() &lt; 10]">
                                <category>
                                    <!-- <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> -->
                                    <xsl:value-of select="translate(@textid,'\','&gt;')"/>
                                    <!-- <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> -->
                                </category>
                            </xsl:for-each>
                        </xsl:for-each>
                        <!-- link do produktu -->
                        <!-- WYMAGANY: Link do produktu -->
                        <!-- pl zzamienic na jezyk ktory bedziemy realizować -->
                        <link>
                            <xsl:value-of select="substring-before(card/@url, '.feed')"/>
                            <xsl:text>.skroutzgr.html</xsl:text>
                        </link>
                        <xsl:variable name="vLowest">
                            <xsl:for-each select="images/large/image/@iaiext:priority">
                                <xsl:sort data-type="number"/>
                                <xsl:if test="position()=1">
                                    <xsl:value-of select="."/>
                                </xsl:if>
                            </xsl:for-each>
                        </xsl:variable>
                        <xsl:for-each select="images/large/image[position() &lt; 10]">
                            <xsl:choose>
                                <xsl:when test="@iaiext:priority = number($vLowest)">
                                    <image>
                                        <xsl:value-of select="@url"/>
                                    </image>
                                </xsl:when>
                                <xsl:otherwise>
                                    <additionalimage>
                                        <xsl:value-of select="@url"/>
                                    </additionalimage>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:for-each>

                        <!-- Dostępność -->
                        <instock>
                            <xsl:choose>
                                <xsl:when test="sizes/size[@available='on_order']/@available = 'on_order'">
                                    <xsl:text>Y</xsl:text>
                                </xsl:when>
                                <xsl:when test="sizes/size[@available='in_stock']/@available = 'in_stock'">
                                    <xsl:text>Y</xsl:text>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:text>N</xsl:text>
                                </xsl:otherwise>
                            </xsl:choose>
                        </instock>
                        <availability>
                            <xsl:choose>
                                <xsl:when test="sizes/size[@available='on_order']/@available = 'on_order'">
                                    <xsl:text>Available from 4 to 10 days</xsl:text>
                                </xsl:when>
                                <xsl:when test="sizes/size[@available='in_stock']/@available = 'in_stock'">
                                    <xsl:text>Available from 4 to 10 days</xsl:text>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:text>Delivery up to 30 days</xsl:text>
                                </xsl:otherwise>
                            </xsl:choose>
                        </availability>
                        <quantity>
                            <xsl:choose>
                                <xsl:when test="sum(sizes/size/stock/@quantity) = 0 and sizes/size/stock[1]/@quantity != '-1' and sizes/size/stock[2]/@quantity != '-1'">
                                    <xsl:text>0</xsl:text>
                                </xsl:when>
                                <xsl:when test="sizes/size/stock[1]/@quantity = '-1' or sizes/size/stock[2]/@quantity = '-1'">
                                    <xsl:text>9999</xsl:text>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:value-of select="sum(sizes/size/stock/@quantity)"/>
                                </xsl:otherwise>
                            </xsl:choose>
                        </quantity>

                        <xsl:variable name="mainPrice">
                            <xsl:choose>
                                <xsl:when test="strikethrough_retail_price and  strikethrough_retail_price/@gross > 0 and
                                          strikethrough_retail_price/@gross > sizes/size/price/@gross and 
                                          sizes/size/price/@gross = price/@gross">
                                    <xsl:choose>
                                        <xsl:when test="strikethrough_retail_price/@gross > sizes/size/price/@gross">
                                            <xsl:value-of select="strikethrough_retail_price/@gross"/>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:value-of select="sizes/size/price/@gross"/>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:when>
                                <xsl:when test="iaiext:pricecomparator_price/iaiext:site and price/@gross = sizes/size/price/@gross">
                                    <xsl:choose>
                                        <xsl:when test="promotion/price/normal_retail_price/@gross > iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                            <xsl:value-of select="promotion/price/normal_retail_price/@gross"/>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:value-of select="iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:when>
                                <xsl:when test="sizes/size/price/@gross">
                                    <xsl:choose>
                                        <xsl:when test="sizes/size/price/@gross != price/@gross and
                                                promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > sizes/size/price/@gross">
                                            <xsl:value-of select="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                                        </xsl:when>
                                        <xsl:when test="sizes/size/price/@gross = price/@gross and
                                                promotion/price/normal_retail_price/@gross > sizes/size/price/@gross">
                                            <xsl:value-of select="promotion/price/normal_retail_price/@gross"/>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:value-of select="sizes/size/price/@gross"/>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:when>
                            </xsl:choose>
                        </xsl:variable>
                        <price_with_vat>
                            <xsl:value-of select="$mainPrice"/>
                        </price_with_vat>
                        <xsl:choose>
                            <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka">
                                <shipping_cost>
                                    <xsl:text><![CDATA[0]]></xsl:text>
                                </shipping_cost>
                            </xsl:when>
                            <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka_large">
                                <shipping_cost>
                                    <xsl:value-of select="$Kwota_wysylki_large"/>
                                </shipping_cost>
                            </xsl:when>
                            <xsl:otherwise>
                                <shipping_cost>
                                    <xsl:value-of select="$Kwota_wysylki"/>
                                </shipping_cost>
                            </xsl:otherwise>
                        </xsl:choose>

                        <!--Versja 2.0  -->
                        <xsl:choose>
                            <xsl:when test="sizes/size/@code_producer and sizes/size/@code_producer!=''">
                                <!-- mamy kod producenta -->
                                <!-- format-number(@code_on_card, '#')" -->
                                <xsl:variable name="code_producer_variable">
                                    <xsl:value-of select="sizes/size/@code_producer"/>
                                </xsl:variable>
                                <xsl:variable name="kod_producer" select="substring-after($code_producer_variable, substring-before($code_producer_variable, substring(translate($code_producer_variable, '0', ''), 1, 1)))">
                                </xsl:variable>

                                <xsl:choose>
                                    <xsl:when test="string-length($kod_producer) = '14' or string-length($kod_producer) = '13' or string-length($kod_producer) = '12' or string-length($kod_producer) = '8'">
                                        <ean>
                                            <xsl:value-of select="$kod_producer"/>
                                        </ean>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <mpn>
                                            <xsl:value-of select="$kod_producer"/>
                                        </mpn>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:variable name="code_producer_variable2">
                                    <xsl:value-of select="@code_on_card"></xsl:value-of>
                                </xsl:variable>
                                <xsl:variable name="code_on_card" select="substring-after($code_producer_variable2, substring-before($code_producer_variable2, substring(translate($code_producer_variable2, '0', ''), 1, 1)))"></xsl:variable>
                                <!-- tutaj uzyjemy code on card -->
                                <xsl:choose>
                                    <xsl:when test="string-length($code_on_card) = '14' or string-length($code_on_card) = '13' or string-length($code_on_card) = '12' or string-length($code_on_card) = '8'">
                                        <ean>
                                            <xsl:value-of select="$code_on_card"/>
                                        </ean>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <mpn>
                                            <xsl:value-of select="$code_on_card"/>
                                        </mpn>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:otherwise>
                        </xsl:choose>

                        <!-- Marka -->
                        <manufacturer>
                            <xsl:value-of select="normalize-space(producer/@name)"/>
                        </manufacturer>

                        <size>
                            <xsl:for-each select="sizes/size[position() &lt; 10]">
                                <xsl:choose>
                                    <xsl:when test="position() = 1">
                                        <xsl:value-of select="@name"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text>, </xsl:text>
                                        <xsl:value-of select="@name"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:for-each>
                        </size>

                        <!-- kolor -->
                        <xsl:choose>
                            <xsl:when test="parameters/parameter/@context_id = 'CONTEXT_COLOR'">
                                <color>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="parameters/parameter[@context_id = 'CONTEXT_COLOR']/value/@name"/>
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </color>
                            </xsl:when>
                            <xsl:when test="parameters/parameter/@group_distinction = 'y' and parameters/parameter/@name = 'Kolor'">
                                <color>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="parameters/parameter[@name = 'Kolor']/value/@name"/>
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </color>
                            </xsl:when>
                        </xsl:choose>

                        <!-- waga sizes/size/@weight-->
                        <weight>
                            <xsl:value-of select="sizes/size/@weight"/>
                        </weight>
                    </product>
                </xsl:for-each>
            </products>
        </mywebstore>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
</xsl:stylesheet>