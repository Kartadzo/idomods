    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <channel>
                <title>altijddier.nl</title>
                <link>https://altijddier.nl/</link>
                <description>Produkty ze sklepu https://altijddier.nl/</description>
                <xsl:for-each select="/offer/products/product[
                price/@gross &gt; 0 and 
                description/name/. != '']">
                    <!-- Id towaru -->
                    <xsl:choose>
                        <xsl:when test="count(sizes/size) &lt; 1">
                            <item>
                                <g:id>
                                    <xsl:value-of select="@id"/>
                                </g:id>
                                <xsl:call-template name="product"/>
                                <xsl:call-template name="productSizeMatter"/>
                            </item>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:for-each select="sizes/size">
                                <item>
                                    <xsl:choose>
                                        <xsl:when test = "position() = 1">
                                            <!-- Id produktu -->
                                            <g:id>
                                                <xsl:value-of select="@code"/>
                                            </g:id>
                                            <xsl:for-each select="../..">
                                                <xsl:call-template name="product"/>
                                            </xsl:for-each>
                                            <xsl:call-template name="productSizeMatter"/>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <!-- Id rozmiaru produktu -->
                                            <g:id>
                                                <xsl:value-of select="@code"/>
                                            </g:id>
                                            <xsl:for-each select="../..">
                                                <xsl:call-template name="product"/>
                                            </xsl:for-each>
                                            <xsl:call-template name="productSizeMatter"/>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </item>
                            </xsl:for-each>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:for-each>
            </channel>
        </rss>
    </xsl:template>

