<xsl:stylesheet version="1.0"
                xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
                xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
                xmlns:php="http://php.net/xsl">
    
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />
    
    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'BEŻOWY/RÓŻOWYSKÓRA/SYNT./BRĄZOWY/CZARNY/GRANATOWY'"/>
    <!-- dane potrzebne aby przekazywać informacje o kolorze -->
    <xsl:variable name='kolor_nazwa_w_panelu'>|kolor|</xsl:variable>
    <!-- dane potrzebne aby przekazywać informacje -->
    <xsl:variable name='material_nazwa_w_panelu'>|material|materiał|</xsl:variable>
    
    <xsl:key name="subcategories" match="item[starts-with(@textId, 'Meble')]" use="substring-before(substring-after(@textId, '\'), '\')"/>
    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <channel>
                <xsl:for-each select="/offer/products/product">
                    <xsl:for-each select="sizes/size">
                        <item>
                            <!--Unikalny identyfikator produktu  -->
                            <g:id>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="@code"></xsl:value-of>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:id>
                            <xsl:for-each select="../..">
                                <g:item_group_id>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="@id" />
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </g:item_group_id>
                                <g:is_bundle>
                                    <xsl:choose>
                                        <xsl:when test="sum(bundled/product/@quantity) > 1">
                                            <xsl:text>yes</xsl:text>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:text>no</xsl:text>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </g:is_bundle>
                                
                                <!-- kolor -->
                                <xsl:choose>
                                    <xsl:when test="parameters/parameter/@context_id = 'CONTEXT_COLOR'">
                                        <g:color>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:for-each select="parameters/parameter[@context_id = 'CONTEXT_COLOR']/value[position() &lt; 5]">
                                                <xsl:choose>
                                                    <xsl:when test="position() = 1">
                                                        <xsl:value-of select="@name" />
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:text>/</xsl:text>
                                                        <xsl:value-of select="@name" />
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:for-each>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </g:color>
                                    </xsl:when>
                                    <xsl:when test="parameters/parameter[@name = 'Kolor']/@group_distinction = 'y'">
                                        <g:color>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:for-each select="parameters/parameter[@name = 'Kolor']/value[position() &lt; 5]">
                                                <xsl:choose>
                                                    <xsl:when test="position() = 1">
                                                        <xsl:value-of select="@name" />
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:text>/</xsl:text>
                                                        <xsl:value-of select="@name" />
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:for-each>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </g:color>
                                    </xsl:when>
                                    <xsl:when test="$kolor_nazwa_w_panelu != '' and parameters/parameter[
                                                    contains($kolor_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))]">
                                        <xsl:variable name='kolor_get' select="parameters/parameter[
                                                                               contains($kolor_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))
                                                                               ]/@name" />
                                        <g:color>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:for-each select="parameters/parameter[@name= $kolor_get]/value[position() &lt; 5]">
                                                <xsl:choose>
                                                    <xsl:when test=" position()= 1">
                                                        <xsl:value-of select="@name" />
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:text>/</xsl:text>
                                                        <xsl:value-of select="@name" />
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:for-each>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </g:color>
                                    </xsl:when>
                                </xsl:choose>
                                
                                <!-- materiał -->
                                <xsl:if test="$material_nazwa_w_panelu != '' and parameters/parameter[
                                              contains($material_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))]">
                                    <xsl:variable name='material_get' select="parameters/parameter[
                                                                              contains($material_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))
                                                                              ]/@name" />
                                    <g:material>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:for-each select="parameters/parameter[@name= $material_get]/value[position() &lt; 5]">
                                            <xsl:choose>
                                                <xsl:when test=" position()= 1">
                                                    <xsl:value-of select="@name" />
                                                </xsl:when>
                                                <xsl:otherwise>
                                                    <xsl:text>/</xsl:text>
                                                    <xsl:value-of select="@name" />
                                                </xsl:otherwise>
                                            </xsl:choose>
                                        </xsl:for-each>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </g:material>
                                </xsl:if>
                            </xsl:for-each>
                            <xsl:variable name="cena_serwis">
                                <xsl:choose>
                                    <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                                        <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text>0</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <xsl:variable name="cena_przekreslona">
                                <xsl:choose>
                                    <!-- cena przekreslona domyslna -->
                                    <xsl:when test="../../strikethrough_retail_price and not(strikethrough_retail_price and ../../strikethrough_retail_price/@gross &lt; strikethrough_retail_price/@gross)">
                                        <xsl:value-of select="../../strikethrough_retail_price/@gross"/>
                                    </xsl:when>
                                    <!-- cena przekreslona dla rozmiaru -->
                                    <xsl:when test="strikethrough_retail_price">
                                        <xsl:value-of select="strikethrough_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text>0</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <xsl:variable name="cena_przedpromocyjna">
                                <xsl:choose>
                                    <!-- cena standard gdy jest cena promocyjna rozmiaru -->
                                    <xsl:when test="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@panel_name != '' and
                                                    ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                                    </xsl:when>
                                    <!-- cena standard gdy jest cena promocyna standardowej ceny -->
                                    <xsl:when test="../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross">
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text>0</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <xsl:variable name="mainPrice">
                                <xsl:choose>
                                    <xsl:when test="$cena_serwis > 0">
                                        <xsl:choose>
                                            <xsl:when test="$cena_przedpromocyjna > $cena_serwis or $cena_przekreslona > $cena_serwis">
                                                <xsl:choose>
                                                    <xsl:when test="$cena_przedpromocyjna > $cena_przekreslona">
                                                        <xsl:value-of select="$cena_przedpromocyjna"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:value-of select="$cena_przekreslona"/>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="$cena_serwis"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:choose>
                                            <xsl:when test="$cena_przedpromocyjna > price/@gross or $cena_przekreslona > price/@gross">
                                                <xsl:choose>
                                                    <xsl:when test="$cena_przedpromocyjna > $cena_przekreslona">
                                                        <xsl:value-of select="$cena_przedpromocyjna"/>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:value-of select="$cena_przekreslona"/>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="price/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <g:price>
                                <xsl:value-of select="$mainPrice"/>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="../../@currency"/>
                            </g:price>
                            <!-- produkcja -->
                            <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
                            <xsl:choose>
                                <xsl:when test="$cena_serwis > 0 and $mainPrice > $cena_serwis">
                                    <g:sale_price>
                                        <xsl:value-of select="$cena_serwis"/>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>
                                    </g:sale_price>
                                </xsl:when>
                                <xsl:when test="$mainPrice > price/@gross and $mainPrice > $cena_serwis">
                                    <g:sale_price>
                                        <xsl:value-of select="price/@gross"/>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>
                                    </g:sale_price>
                                </xsl:when>
                            </xsl:choose>
                            <!-- Dostępność -->
                            <g:availability>
                                <xsl:choose>
                                    <xsl:when test="@available = 'on_order'">
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:when test="@available = 'in_stock'">
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[out of stock]]&gt;</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </g:availability>
                            <g:custom_label_0>
                                <xsl:choose>
                                    <xsl:when test="../../price/@gross &lt;= 50">
                                        <xsl:text disable-output-escaping="yes">0-50 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 50 and ../../price/@gross &lt;= 100">
                                        <xsl:text disable-output-escaping="yes">50-100 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 100 and ../../price/@gross &lt;= 250">
                                        <xsl:text disable-output-escaping="yes">100-250 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 250 and ../../price/@gross &lt;= 500">
                                        <xsl:text disable-output-escaping="yes">250-500 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 500 and ../../price/@gross &lt;= 1000">
                                        <xsl:text disable-output-escaping="yes">500-1000 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 1000 and ../../price/@gross &lt;= 2000">
                                        <xsl:text disable-output-escaping="yes">1000-2000 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 2000 and ../../price/@gross &lt;= 3000">
                                        <xsl:text disable-output-escaping="yes">2000-3000 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 3000 and ../../price/@gross &lt;= 5000">
                                        <xsl:text disable-output-escaping="yes">3000-5000 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 5000">
                                        <xsl:text disable-output-escaping="yes">5000- </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                </xsl:choose>
                            </g:custom_label_0>
                        </item>
                    </xsl:for-each>
                </xsl:for-each>
            </channel>
        </rss>
    </xsl:template>
    
    <xsl:template name="strip-tags">
        <xsl:param name="text"/>
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;')">
                <xsl:value-of select="substring-before($text, '&lt;')"/>
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    
    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    
    <xsl:template name="string-subcategory">
        <xsl:param name="text"/>
        <xsl:choose>
            <xsl:when test="contains($text, '\')">
                <xsl:value-of select="substring-before($text, '\')"/>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    
    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring($word,1,1)"/>
                        <xsl:value-of select="translate(substring($word,2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="$word"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:value-of select="substring-before($text, '/')"/>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring($word,1,1)"/>
                        <xsl:value-of select="translate(substring($word,2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="$word"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:value-of select="$text"/>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring($word,1,1)"/>
                        <xsl:value-of select="translate(substring($word,2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="$word"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    
    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
</xsl:stylesheet>