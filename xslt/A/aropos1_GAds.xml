<xsl:stylesheet
version="1.0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
xmlns:php="http://php.net/xsl">

<xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes"/>

<xsl:variable name='Kwota_za_darmo_wysylka'>99999</xsl:variable>
<xsl:variable name="Kwota_wysylki">19.99</xsl:variable>
<xsl:variable name="Kwota_wysylki_large">29.99</xsl:variable>
<xsl:variable name='Kwota_za_darmo_wysylka_large'>199</xsl:variable>
<xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
<xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- dane potrzebne aby przekazywać informacje o kolorze -->
    <xsl:variable name='kolor_nazwa_w_panelu'>|kolorystyka|kolor nóżek|kolor łóżka|</xsl:variable>
    <!-- dane potrzebne aby przekazywać informacje -->
    <xsl:variable name='material_nazwa_w_panelu'>|materiał|skład materaca|wypełnienie|</xsl:variable>

<xsl:template match="/">
    <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
        <channel>

            <xsl:for-each select="/offer/products/product[
                price/@gross &gt; 0 and 
                description/name/. != '']">
                <xsl:variable name="menu_">
                    <xsl:for-each select="iaiext:navigation/iaiext:site/iaiext:menu">
                    <xsl:for-each select="iaiext:item">
                        <xsl:choose>
                            <xsl:when test="contains(@textid,'Narzędzia > Noże')">
                                <xsl:text>true</xsl:text>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>false</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:for-each>
                    </xsl:for-each>
                </xsl:variable>
          
                <xsl:if test="not(contains($menu_,'true'))"> 
                    <xsl:for-each select="sizes/size">
          
                    <xsl:variable name="element_position">
                        <xsl:value-of select="position()"/>
                    </xsl:variable>
                    <xsl:variable name="panelName">
                        <xsl:value-of select="@panel_name"/>
                    </xsl:variable>
                    <item>
                        <!-- Id towaru -->
                        <g:id>
                            <xsl:value-of select="@code"></xsl:value-of>
                        </g:id>
                        <!-- Nazwa towaru -->
                        <g:title>
                            <xsl:value-of select="../../description/name"></xsl:value-of>
                        </g:title>
                        <!-- Opis towaru -->
                        <!-- short descr -->
                        <xsl:choose>
                            <xsl:when test="../../description/short_desc = '' and ../../description/long_desc = ''">
                                <!-- nie jest git bo nie ma opisów  -->
                                <xsl:variable name="from_parameters">
                                    <xsl:for-each select="../../parameters/parameter">
                                        <xsl:text>&#xa;</xsl:text>
                                        <xsl:value-of select="@name"></xsl:value-of>
                                        <xsl:text>: </xsl:text>
                                        <xsl:value-of select="value/@name"></xsl:value-of>
                                    </xsl:for-each>
                                </xsl:variable>
                                <xsl:if test="$from_parameters != ''">
                                    <g:description>
                                        <xsl:value-of select="../../description/name"></xsl:value-of>
                                        <xsl:value-of select="$from_parameters"></xsl:value-of>
                                    </g:description>
                                </xsl:if>
                            </xsl:when>
                            <xsl:when test="../../description/short_desc = ''">
                                <xsl:variable name = "returned_value_without_html">
                                    <xsl:call-template name="strip-tags">
                                        <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:variable name="returned_value_300_char" select="substring(normalize-space($returned_value_without_html),1,300)"></xsl:variable>
                                <xsl:variable name="value_cut">
                                    <xsl:call-template name="tokenize">
                                        <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,300)"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:variable name="last_char" select="substring($returned_value_300_char, string-length($returned_value_300_char), 1)"></xsl:variable>
                                <xsl:choose>
                                    <xsl:when test="$last_char != '.'">
                                        <!-- chodzi oto ze nie ma przed kropka nic  -->
                                        <xsl:choose>
                                            <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut)) = ''">
                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                <g:description>
                                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                    <xsl:value-of select="$returned_value_300_char"></xsl:value-of>
                                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                </g:description>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- jest przed kropka text -->
                                                <g:description>
                                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                    <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut))"></xsl:value-of>
                                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                </g:description>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- Mamy kropke na koncu i jest git -->
                                        <g:description>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="$returned_value_300_char"></xsl:value-of>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </g:description>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:otherwise>
                                <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                <!-- załóżmy -->
                                <xsl:choose>
                                    <xsl:when test="string-length(../../description/short_desc) > 30">
                                        <!-- jest git bo ma wiecej niz  -->
                                        <g:description>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="../../description/short_desc"></xsl:value-of>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </g:description>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:variable name = "returned_value_without_html">
                                            <xsl:call-template name="strip-tags">
                                                <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="returned_value_300_char" select="substring(normalize-space($returned_value_without_html),1,300)"></xsl:variable>
                                        <xsl:variable name="value_cut">
                                            <xsl:call-template name="tokenize">
                                                <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,300)"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="last_char" select="substring($returned_value_300_char, string-length($returned_value_300_char), 1)"></xsl:variable>
                                        <xsl:choose>
                                            <xsl:when test="$last_char != '.'">
                                                <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                <xsl:choose>
                                                    <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut)) = ''">
                                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                        <g:description>
                                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                            <xsl:value-of select="$returned_value_300_char"></xsl:value-of>
                                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                        </g:description>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- jest przed kropka text -->
                                                        <g:description>
                                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                            <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut))"></xsl:value-of>
                                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                        </g:description>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- Mamy kropke na koncu i jest git -->
                                                <g:description>
                                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                    <xsl:value-of select="$returned_value_300_char"></xsl:value-of>
                                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                </g:description>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:otherwise>
                        </xsl:choose>

                        <!-- Link -->
                        <g:link><xsl:value-of select="substring-before(../../card/@url, '.feed')"/><![CDATA[.html]]></g:link>
                        <g:mobile_link><xsl:value-of select="substring-before(../../card/@url, '.feed')"/><![CDATA[.html]]></g:mobile_link>

                        <!-- Zdjęcia -->
                        <xsl:variable name="vLowest">
                            <xsl:for-each select="../../images/large/image/@iaiext:priority">
                             <xsl:sort data-type="number"/>
                             <xsl:if test="position()=1"><xsl:value-of select="."/></xsl:if>
                            </xsl:for-each>
                           </xsl:variable>

                            <xsl:for-each select="../../images/large/image[position()&lt;=10]">
                            <xsl:choose>
                                    <xsl:when test="@iaiext:priority = number($vLowest)">
                            <g:image_link>  <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="@url"></xsl:value-of>   <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:image_link>
                                    </xsl:when>
                                    <xsl:otherwise>
                                <g:additional_image_link>  <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="@url"></xsl:value-of>   <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:additional_image_link>
                            </xsl:otherwise>
                        </xsl:choose>
                     </xsl:for-each> 
                     <!-- Brand -->
                     <g:brand><xsl:value-of select="../../producer/@name"></xsl:value-of></g:brand>
                     <g:gtin><xsl:value-of select="@code_producer"></xsl:value-of></g:gtin>
                     <g:condition><![CDATA[new]]></g:condition>
                     <!-- Dostępność -->
                    <g:availability>
                        <xsl:choose>
                            <xsl:when test="@available = 'on_order'">
                                <!-- <![CDATA[available for order]]> -->
                                <![CDATA[in stock]]>
                            </xsl:when>
                            <xsl:when test="@available= 'in_stock'">
                                <![CDATA[in stock]]>
                            </xsl:when>
                            <xsl:otherwise>
                                <![CDATA[out of stock]]>
                            </xsl:otherwise>
                        </xsl:choose>
                    </g:availability>

                    <!-- cena -->
                <xsl:choose>
                    <!-- kiedy hurtowa cena detaliczna -->
                        <xsl:when test="../../strikethrough_retail_price and 
                        ../../strikethrough_retail_price/@gross > price/@gross and 
                        price/@gross = ../../price/@gross">
                            <xsl:choose>
                                <!-- kiedy cena promocyjna jest wieksza niz cena dla serwisu zewnetrznego -->
                                <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                                    <g:price>
                                        <xsl:value-of select="../../strikethrough_retail_price/@gross"></xsl:value-of>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>
                                    </g:price>
                                </xsl:when>
                                <!-- inaczej bierze cena główną -->
                                <xsl:otherwise>
                                    <g:price>
                                        <xsl:value-of select="price/@gross"></xsl:value-of>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>
                                    </g:price>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and price/@gross = ../../price/@gross">
                            <xsl:choose>
                                <!-- kiedy cena promocyjna jest wieksza niz cena dla serwisu zewnetrznego -->
                                <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                    <g:price>
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"></xsl:value-of>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>  
                                    </g:price>
                                </xsl:when>
                                <!-- inaczej bierze cena dla serwisu zewnetrznego -->
                                <xsl:otherwise>
                                    <g:price>
                                        <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"></xsl:value-of>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>  
                                    </g:price>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <!-- kiedy nie wystepuje hurtowa cena detaliczna -->
                        <xsl:when test="price/@gross">
                            <xsl:choose>
                                <!-- kiedy promocyjna bedzie wieksza  -->
                                <xsl:when test="price/@gross != ../../price/@gross and
                                ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                                    <g:price>
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"></xsl:value-of>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>  
                                    </g:price>
                                </xsl:when>
                                <xsl:when test="price/@gross = ../../price/@gross and
                                ../../promotion/price/normal_retail_price/@gross > price/@gross">
                                    <g:price>
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"></xsl:value-of>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>  
                                    </g:price>
                                </xsl:when>
                                <xsl:otherwise>
                                    <!-- bierzemy normalna price/gorss -->
                                    <g:price>
                                        <xsl:value-of select="price/@gross"></xsl:value-of>
                                        <xsl:text><![CDATA[ ]]></xsl:text>
                                        <xsl:value-of select="../../@currency"/>  
                                    </g:price>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                    </xsl:choose>
                    <xsl:variable name="mainPrice">
                        <xsl:choose>
                        <xsl:when test="../../strikethrough_retail_price and 
                        ../../strikethrough_retail_price/@gross > price/@gross and 
                        price/@gross = ../../price/@gross">
                            <xsl:choose>
                                <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                                        <xsl:value-of select="../../strikethrough_retail_price/@gross"></xsl:value-of>
                                </xsl:when>
                                <xsl:otherwise>
                                        <xsl:value-of select="sizes/size/price/@gross"></xsl:value-of>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and sizes/size/price/@gross = price/@gross">
                            <xsl:choose>
                                <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"></xsl:value-of>
                                </xsl:when>
                                <xsl:otherwise>
                                        <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"></xsl:value-of>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:when test="price/@gross">
                            <xsl:choose>
                                <xsl:when test="price/@gross != ../../price/@gross and
                                ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                                    <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"></xsl:value-of>
                                </xsl:when>
                                <xsl:when test="price/@gross = ../../price/@gross and
                                ../../promotion/price/normal_retail_price/@gross > price/@gross">
                                    <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"></xsl:value-of>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:value-of select="price/@gross"></xsl:value-of>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                    </xsl:choose>
                    </xsl:variable>
                    <xsl:choose>
                       <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka">
                            <g:shipping>
                                <g:price>
                                    <xsl:text>0<![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="../../@currency"/>  
                                </g:price>
                                <g:country>PL</g:country>
                            </g:shipping>
                        </xsl:when>
                        <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka_large">
                            <g:shipping>
                                <g:price>
                                    <xsl:value-of select="$Kwota_wysylki"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="../../@currency"/>  
                                </g:price>
                                <g:country>PL</g:country>
                            </g:shipping>
                        </xsl:when>
                        <xsl:otherwise>
                            <g:shipping>
                                <g:price>
                                    <xsl:value-of select="$Kwota_wysylki_large"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="../../@currency"/>  
                                </g:price>
                                <g:country>PL</g:country>
                            </g:shipping>
                        </xsl:otherwise>
                    </xsl:choose>
                    <!-- produkcja -->
                    <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
                    <xsl:if test="../../promotion/price/normal_retail_price or ../../strikethrough_retail_price">
                        <xsl:choose><!-- (../../srp and ../../srp/@gross > price/@gross) or -->
                            <xsl:when test = "
                              (../../strikethrough_retail_price and ../../strikethrough_retail_price/@gross > price/@gross) or
                              (../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross) or
                              (../../promotion/price/normal_retail_price and ../../price/@gross != price/@gross and 
                              ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross)">
                                <g:sale_price>
                                    <xsl:value-of select="price/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="../../@currency"/>
                                </g:sale_price>
                                <g:custom_label_2>PROMOCJA</g:custom_label_2>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:if>

                    
                    <!-- waga sizes/size/@weight-->
                    <shipping_weight>
                        <xsl:choose>
                            <xsl:when test="@weight > 100">
                                <xsl:value-of select="format-number((@weight div 1000),'#.##')"/>
                                <xsl:text><![CDATA[ kg]]></xsl:text>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="@weight"/>
                                <xsl:text><![CDATA[ g]]></xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </shipping_weight>
                    <!-- Product type -->
                    <xsl:for-each select="../../iaiext:navigation/iaiext:site/iaiext:menu[@id = 1]">
                        <xsl:for-each select="iaiext:item">
                            <xsl:choose>
                                <xsl:when test="position() &lt; 10">
                                    <g:product_type>
                                        <!-- <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> -->
                                        <!-- <xsl:value-of select="translate(@textid,'\','&gt;')"/>    -->
                                        <xsl:call-template name="string-replace-all">
                                            <xsl:with-param name="text" select="@textid" tunnel="yes"/>
                                            <xsl:with-param name="replace" select="'\'" tunnel="yes"/>
                                            <xsl:with-param name="by" select="' &gt; '" tunnel="yes"/>
                                        </xsl:call-template>
                                        <!-- <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> -->
                                    </g:product_type>
                                </xsl:when>
                            </xsl:choose>
                        </xsl:for-each>
                    </xsl:for-each>
                    <!-- grupa towarów -->
                    <g:item_group_id><xsl:value-of select="../../@id"></xsl:value-of></g:item_group_id>
                    <!-- rozmiar -->
                    <g:size><xsl:value-of select="@name"></xsl:value-of></g:size>

                    <xsl:if test="../../iaiext:priority_menu/site/menu[1]/item[@id = '368']">
                        <g:custom_label_1>WYPRZEDAŻ</g:custom_label_1>
                    </xsl:if>
                    
                    <g:custom_label_0>
                        <xsl:choose>
                            <xsl:when test="price/@gross &lt;= 50"><xsl:text disable-output-escaping="yes">0-50 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 50 and price/@gross &lt;= 100"><xsl:text disable-output-escaping="yes">50-100 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 100 and price/@gross &lt;= 200"><xsl:text disable-output-escaping="yes">100-200 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 200 and price/@gross &lt;= 300"><xsl:text disable-output-escaping="yes">200-300 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 300 and price/@gross &lt;= 400"><xsl:text disable-output-escaping="yes">300-400 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 400 and price/@gross &lt;= 500"><xsl:text disable-output-escaping="yes">400-500 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 500 and price/@gross &lt;= 600"><xsl:text disable-output-escaping="yes">500-600 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 600 and price/@gross &lt;= 700"><xsl:text disable-output-escaping="yes">600-700 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 700 and price/@gross &lt;= 800"><xsl:text disable-output-escaping="yes">700-800 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 800 and price/@gross &lt;= 900"><xsl:text disable-output-escaping="yes">800-900 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 900 and price/@gross &lt;= 1000"><xsl:text disable-output-escaping="yes">900-1000 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            <xsl:when test="price/@gross &gt; 1000 and price/@gross &lt;= 1100"><xsl:text disable-output-escaping="yes">1000-1100 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
