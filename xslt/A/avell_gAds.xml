<xsl:stylesheet version="1.0"
                xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
                xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
                xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />
    <!-- PL|DE|CZ|SK|RO|UA||||||||||||||||||||||||||||||| -->
    <xsl:variable name="upperLetters" 
                  select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻÄÖÜẞÁČĎÉĚÍŇÓŘŠŤÚŮÝŽÁÄČĎŽÉÍĹĽŇÓÔŔŠŤÚÝŽĂÂÎȘȚАБВГҐДЕЄЖЗИІЇЙКЛМНОПРСТУФХЦЧШЩЬЮЯ'" />
    <xsl:variable name="lowerLetters" 
                  select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźżäöüßáčďéěíňóřšťúůýžáäčďžéíĺľňóôŕšťúýžăâîșțабвгґдеєжзиіїйклмнопрстуфхцчшщьюя'" />
    <!-- długość opisu -->
    <xsl:variable name='dlugosc_opisu'>2400</xsl:variable>
    <xsl:variable name='dlugosc_opisu_z_parametrow'>1200</xsl:variable>
    <!-- wymagany limit długości opisu po którego przekroczeniu nie zostanie dodany opis z parametrów  -->
    <xsl:variable name='minimalna_dlugosc_opisu_dla_parametrow'>120</xsl:variable>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'\GEOMETRYCZNY\MARKER/SUCHOŚCIERALNY\KARTKA\RECYKLINGU\GRATIS\WYPRZEDAŻ\PIORNIK\OZDOBA\ZESZYT\FLAMASTRY\ZESTAW'" />
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='kwota_dla_darmowej_dostawy'>250</xsl:variable>
    <xsl:variable name='kwota_dla_wiekszych_zamowien'></xsl:variable>
    <xsl:variable name="Koszt_dostawy">9.99</xsl:variable>
    <xsl:variable name="Koszt_dostawy_wiekszych_zamowien">0.00</xsl:variable>
    <xsl:variable name="Kraj_dostawy" select="'PL'" />
    <xsl:variable name="Czas_obsługi_zamówienia_na_magazynie" select="'1'" />
    <xsl:variable name="Czas_dostawy_zamówienia" select="'1'" />
    <!-- dane potrzebne aby przekazywać informacje o płci -->
    <xsl:variable name='gender_nazwa_w_panelu'>Płeć</xsl:variable>
    <xsl:variable name='gender_male'>|Chłopcy|</xsl:variable>
    <xsl:variable name='gender_female'>|Dziewczynki|</xsl:variable>
    <xsl:variable name='gender_unisex'>|</xsl:variable>
    <!-- dane potrzebne aby przekazywać informacje o kolorze -->
    <xsl:variable name='kolor_nazwa_w_panelu'>|kolor|kolor:|kolor dominujący|kolor wkładu|</xsl:variable>
    <!-- dane potrzebne aby przekazywać informacje -->
    <xsl:variable name='material_nazwa_w_panelu'>|materiał|materiał wykonania|</xsl:variable>
    <!-- dane potrzebne aby przekazywać informacje o wadze -->
    <xsl:variable name='waga_nazwa_w_panelu'>Waga [g]</xsl:variable>
    <!-- dane potrzebne aby przekazywać informacje o pojemności -->
    <xsl:variable name='pojemnosc_nazwa_w_panelu'>Pojemność [ml]</xsl:variable>
    
    
    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <channel>
                <title>avell.pl</title>
                <link>https://avell.pl/</link>
                <description>Produkty ze sklepu https://avell.pl/</description>
                <xsl:for-each select="/offer/products/product[
                                      price/@gross &gt; 0 and 
                                  description/name/. != '']">
                    <!-- Id towaru -->
                    <xsl:choose>
                        <xsl:when test="count(sizes/size) &lt; 1">
                            <xsl:element name="item">
                                <xsl:element name="g:id">
                                    <xsl:value-of select="@id"/>
                                </xsl:element>
                                <xsl:call-template name="product"/>
                                <xsl:call-template name="productSizeMatter"/>
                            </xsl:element>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:for-each select="sizes/size">
                                <xsl:element name="item">
                                    <xsl:choose>
                                        <xsl:when test = "position() = 1">
                                            <!-- Id produktu -->
                                            <xsl:element name="g:id">
                                                <xsl:value-of select="@code"/>
                                            </xsl:element>
                                            <xsl:for-each select="../..">
                                                <xsl:call-template name="product"/>
                                            </xsl:for-each>
                                            <xsl:call-template name="productSizeMatter"/>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <!-- Id rozmiaru produktu -->
                                            <xsl:element name="g:id">
                                                <xsl:value-of select="@code"/>
                                            </xsl:element>
                                            <xsl:for-each select="../..">
                                                <xsl:call-template name="product"/>
                                            </xsl:for-each>
                                            <xsl:call-template name="productSizeMatter"/>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:element>
                            </xsl:for-each>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:for-each>
            </channel>
        </rss>
    </xsl:template>
    
    <xsl:template name="product" xmlns:g="http://base.google.com/ns/1.0" version="2.0">
    <!-- 01.09.2025 MD -->
        <xsl:variable name="nazwaTowaru">
            <xsl:choose>
                <xsl:when test="iaiext:pricecomparator_name and iaiext:pricecomparator_name != ''">
                    <xsl:call-template name="wordFormat">
                        <xsl:with-param name="text" select="iaiext:pricecomparator_name/." tunnel="yes" />
                    </xsl:call-template>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:call-template name="wordFormat">
                        <xsl:with-param name="text" select="description/name/." tunnel="yes" />
                    </xsl:call-template>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="upperCaseCount">
            <xsl:call-template name="upperCaseCount">
                <xsl:with-param name="text" select="$nazwaTowaru" />
            </xsl:call-template>
        </xsl:variable>
        <xsl:variable name="lowerCaseCount">
            <xsl:call-template name="lowerCaseCount">
                <xsl:with-param name="text" select="$nazwaTowaru" />
            </xsl:call-template>
        </xsl:variable>
        
        <xsl:element name="g:title">
            <xsl:choose>
                <xsl:when test="($lowerCaseCount div $upperCaseCount) &lt; 0.3">
                    <!-- wszystkie litery oprócz pierwszej i producenta zamienia na małe litery -->
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                    <xsl:variable name="lower-text">
                        <xsl:value-of select="concat(substring($nazwaTowaru, 1, 1), translate(substring(normalize-space($nazwaTowaru), 2), $upperLetters, $lowerLetters))" />
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="contains($lower-text, translate(producer/@name, $upperLetters, $lowerLetters))">
                            <xsl:value-of select="substring-before($lower-text, translate(producer/@name, $upperLetters, $lowerLetters))" />
                            <xsl:value-of select="producer/@name" />
                            <xsl:value-of select="substring-after($lower-text, translate(producer/@name, $upperLetters, $lowerLetters))" />
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$lower-text" />
                        </xsl:otherwise>
                    </xsl:choose>
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                    <xsl:value-of select="$nazwaTowaru" />
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:element>

        <!-- Grupuj tylko rozmiary -->
        <g:item_group_id>
            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
            <xsl:value-of select="@id" />
            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
        </g:item_group_id>
        
        <!-- jeśli na sklepie są jakieś zestawy -->
        <xsl:element name="g:is_bundle">
            <xsl:choose>
                <xsl:when test="sum(bundled/product/@quantity) > 1">
                    <xsl:text>yes</xsl:text>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text>no</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:element>
        
        <!-- kolor -->
        <xsl:choose>
            <xsl:when test="parameters/parameter/@context_id = 'CONTEXT_COLOR'">
                <xsl:element name="g:color">
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                    <xsl:for-each select="parameters/parameter[@context_id = 'CONTEXT_COLOR']/value[position() &lt; 5]">
                        <xsl:choose>
                            <xsl:when test="position() = 1">
                                <xsl:value-of select="@name" />
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>/</xsl:text>
                                <xsl:value-of select="@name" />
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:for-each>
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </xsl:element>
            </xsl:when>
            <xsl:when test="$kolor_nazwa_w_panelu != '' and parameters/parameter[
                            contains($kolor_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))]">
                <xsl:variable name='kolor_get' select="parameters/parameter[
                        contains($kolor_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))
                                                       ]/@name" />
                <xsl:element name="g:color">
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                    <xsl:for-each select="parameters/parameter[@name= $kolor_get]/value[position() &lt; 5]">
                        <xsl:choose>
                            <xsl:when test=" position()= 1">
                                <xsl:value-of select="@name" />
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>/</xsl:text>
                                <xsl:value-of select="@name" />
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:for-each>
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </xsl:element>
            </xsl:when>
        </xsl:choose>
        <!-- płeć -->
        <xsl:if test="$gender_nazwa_w_panelu != '' and parameters/parameter[@name = $gender_nazwa_w_panelu]/value/@name != ''">
            <xsl:element name="g:gender">
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:variable name='gender_wer'>
                    <xsl:text>|</xsl:text>
                    <xsl:value-of select="parameters/parameter[@name = $gender_nazwa_w_panelu]/value/@name" />
                    <xsl:text>|</xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($gender_male, $gender_wer)">
                        <![CDATA[male]]>
                    </xsl:when>
                    <xsl:when test="contains($gender_female, $gender_wer)">
                        <![CDATA[female]]>
                    </xsl:when>
                    <xsl:when test="contains($gender_unisex, $gender_wer)">
                        <![CDATA[unisex]]>
                    </xsl:when>
                </xsl:choose>
                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
            </xsl:element>
        </xsl:if>
        
        <!-- materiał -->
        <xsl:if test="$material_nazwa_w_panelu != '' and parameters/parameter[
                      contains($material_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))]">
            <xsl:variable name='material_get' select="parameters/parameter[
                    contains($material_nazwa_w_panelu, concat('|',translate(@name, $upperLetters, $lowerLetters),'|'))
                                                      ]/@name" />
            <xsl:element name="g:material">
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:for-each select="parameters/parameter[@name= $material_get]/value[position() &lt; 5]">
                    <xsl:choose>
                        <xsl:when test=" position()= 1">
                            <xsl:value-of select="@name" />
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:text>/</xsl:text>
                            <xsl:value-of select="@name" />
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:for-each>
                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
            </xsl:element>
        </xsl:if>
        
        <!-- 2026-01-14 - MD -->
        <xsl:variable name="final_form_unit_measure">
            <xsl:choose>
                <!-- Jeśli wartość pochodzi z parametru z kontekstem CONTEXT_STD_UNIT_WEIGHT -->
                <xsl:when test="parameters/parameter[@hide = 'n' and @context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != ''">
                    <xsl:variable name="raw" select="translate(parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ',', '.')"/>
                    <xsl:variable name="number_part">
                        <xsl:choose>
                            <xsl:when test="contains($raw,' kg') or contains($raw,' KG')">
                                <xsl:value-of select="number(substring-before(concat($raw, ' '), ' '))*1000"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="substring-before(concat($raw, ' '), ' ')"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="number($number_part) &gt;= 1000">
                            <xsl:value-of select="format-number(number($number_part) div 1000, '#.##')"/>
                            <xsl:text> kg</xsl:text>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$number_part"/>
                            <xsl:text> g</xsl:text>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:when test="parameters/parameter[@hide = 'n' and @context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != ''">
                    <xsl:variable name="raw" select="translate(parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ',', '.')" />
                    <xsl:variable name="number_part">
                        <xsl:choose>
                            <xsl:when test="contains($raw,' l') or contains($raw,' L')">
                                <xsl:value-of select="number(substring-before(concat($raw, ' '), ' '))*1000"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="substring-before(concat($raw, ' '), ' ')"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="number($number_part) &gt;= 1000">
                            <xsl:value-of select="format-number(number($number_part) div 1000, '#.##')"/>
                            <xsl:text> l</xsl:text>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$number_part"/>
                            <xsl:text> ml</xsl:text>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:when test="parameters/parameter[@hide = 'n' and @name=$waga_nazwa_w_panelu]/value/@name != ''">
                    <xsl:variable name="raw" select="translate(parameters/parameter[@name=$waga_nazwa_w_panelu]/value/@name, ',', '.')" />
                    <!-- Wyodrębniamy fragment przed spacją - jeśli jednostka jest dołączona -->
                    <xsl:variable name="number_part">
                        <xsl:choose>
                            <xsl:when test="contains($raw,' kg') or contains($raw,' KG')">
                                <xsl:value-of select="number(substring-before(concat($raw, ' '), ' '))*1000"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="substring-before(concat($raw, ' '), ' ')"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="number($number_part) &gt;= 1000">
                            <xsl:value-of select="format-number(number($number_part) div 1000, '#.##')"/>
                            <xsl:text> kg</xsl:text>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$number_part"/>
                            <xsl:text> g</xsl:text>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:when test="parameters/parameter[@hide = 'n' and @name=$pojemnosc_nazwa_w_panelu]/value/@name != ''">
                    <xsl:variable name="raw" select="translate(parameters/parameter[@name=$pojemnosc_nazwa_w_panelu]/value/@name, ',', '.')"/>
                    <xsl:variable name="number_part">
                        <xsl:choose>
                            <xsl:when test="contains($raw,' l') or contains($raw,' L')">
                                <xsl:value-of select="number(substring-before(concat($raw, ' '), ' '))*1000"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="substring-before(concat($raw, ' '), ' ')"/>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="number($number_part) &gt;= 1000">
                            <xsl:value-of select="format-number(number($number_part) div 1000, '#.##')"/>
                            <xsl:text> l</xsl:text>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="$number_part"/>
                            <xsl:text> ml</xsl:text>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:when test="@type = 'regular'">
                    <xsl:call-template name="find_unit_measure">
                        <xsl:with-param name="str" select="translate($nazwaTowaru,$upperLetters,$lowerLetters)"/>
                    </xsl:call-template>
                </xsl:when>
            </xsl:choose>
        </xsl:variable>
        
        <!-- Wyświetlenie jednostek -->
        <xsl:choose>
            <xsl:when test="$final_form_unit_measure != ''">
                <xsl:choose>
                    <xsl:when test="contains($final_form_unit_measure,' kg')">
                        <!-- Jeśli przeliczona wartość (w kg) jest >= 1, wyświetlamy kg -->
                        <xsl:element name="g:unit_pricing_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="$final_form_unit_measure"/>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </xsl:element>
                        <xsl:element name="g:unit_pricing_base_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 kg]]&gt;</xsl:text>
                        </xsl:element>
                    </xsl:when>
                    <xsl:when test="contains($final_form_unit_measure,' g')">
                        <xsl:element name="g:unit_pricing_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="$final_form_unit_measure"/>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </xsl:element>
                        <xsl:element name="g:unit_pricing_base_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[100 g]]&gt;</xsl:text>
                        </xsl:element>
                    </xsl:when>
                    <xsl:when test="contains($final_form_unit_measure,' l')">
                        <xsl:element name="g:unit_pricing_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="$final_form_unit_measure"/>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </xsl:element>
                        <xsl:element name="g:unit_pricing_base_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 l]]&gt;</xsl:text>
                        </xsl:element>
                    </xsl:when>
                    <xsl:when test="contains($final_form_unit_measure,' ml')">
                        <xsl:element name="g:unit_pricing_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="$final_form_unit_measure"/>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </xsl:element>
                        <xsl:element name="g:unit_pricing_base_measure">
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[100 ml]]&gt;</xsl:text>
                        </xsl:element>
                    </xsl:when>
                </xsl:choose>
            </xsl:when>
        </xsl:choose>
        
        <xsl:element name="g:custom_label_0">
            <xsl:choose>
                <xsl:when test="price/@gross &lt;= 50">
                    <xsl:text>0-50 </xsl:text>
                    <xsl:value-of select="@currency" />
                </xsl:when>
                <xsl:when test="price/@gross &gt; 50 and price/@gross &lt;= 100">
                    <xsl:text>50-100 </xsl:text>
                    <xsl:value-of select="@currency" />
                </xsl:when>
                <xsl:when test="price/@gross &gt; 100 and price/@gross &lt;= 150">
                    <xsl:text>100-150 </xsl:text>
                    <xsl:value-of select="@currency" />
                </xsl:when>
                <xsl:when test="price/@gross &gt; 150 and price/@gross &lt;= 200">
                    <xsl:text>150-200 </xsl:text>
                    <xsl:value-of select="@currency" />
                </xsl:when>
                <xsl:when test="price/@gross &gt; 200 and price/@gross &lt;= 500">
                    <xsl:text>200-500 </xsl:text>
                    <xsl:value-of select="@currency" />
                </xsl:when>
                <xsl:when test="price/@gross &gt; 500">
                    <xsl:text>500+ </xsl:text>
                    <xsl:value-of select="@currency" />
                </xsl:when>
            </xsl:choose>
        </xsl:element>
        <g:custom_label_1>
            <xsl:if test="iaiext:hotspots/iaiext:site/flag/@type='newproduct' and iaiext:hotspots/iaiext:site/flag/@visible='yes'">
                <xsl:text>|Nowość|</xsl:text>
            </xsl:if>
            <xsl:if test="iaiext:hotspots/iaiext:site/flag/@type='bestseller' and iaiext:hotspots/iaiext:site/flag/@visible='yes'">
                <xsl:text>|Bestseller|</xsl:text>
            </xsl:if>
            <xsl:if test="iaiext:hotspots/iaiext:site/flag/@type='promotion' and iaiext:hotspots/iaiext:site/flag/@visible='yes'">
                <xsl:text>|Promocja|</xsl:text>
            </xsl:if>
        </g:custom_label_1>
    </xsl:template>
    
    <xsl:template name="productSizeMatter"
                  xmlns:g="http://base.google.com/ns/1.0" 
                  version="2.0">
        <xsl:variable name="sell_by">
            <xsl:choose>
                <xsl:when test="../../iaiext:sell_by/iaiext:retail and ../../iaiext:sell_by/iaiext:retail/@quantity > 0">
                    <xsl:value-of select="../../iaiext:sell_by/iaiext:retail/@quantity" />
                </xsl:when>
                <xsl:when test="iaiext:sell_by/iaiext:retail and iaiext:sell_by/iaiext:retail/@quantity > 0">
                    <xsl:value-of select="iaiext:sell_by/iaiext:retail/@quantity" />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text>1</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <!-- Dostępność -->
        <xsl:variable name="stocksGobalCheck">
            <xsl:for-each select="stock">
                <xsl:choose>
                    <xsl:when test="@available_stock_quantity &gt; 0">
                        <xsl:value-of select="@available_stock_quantity"></xsl:value-of>
                        <xsl:text>/</xsl:text>
                    </xsl:when>
                    <xsl:when test="@available_stock_quantity = -1 ">
                        <xsl:value-of select="@available_stock_quantity"></xsl:value-of>
                        <xsl:text>/</xsl:text>
                    </xsl:when>
                </xsl:choose>
            </xsl:for-each>
        </xsl:variable>
        <xsl:variable name="avail">
            <xsl:choose>
                <xsl:when test="contains($stocksGobalCheck,'-1')">
                    <xsl:text>999999</xsl:text>
                </xsl:when>
                <xsl:when test="string-length($stocksGobalCheck) = 0">
                    <xsl:text>0</xsl:text>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="sum(stock/@available_stock_quantity)"></xsl:value-of>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:element name="g:availability">
            <xsl:choose>
                <xsl:when test="@available = 'on_order' and $avail >= $sell_by">
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                </xsl:when>
                <xsl:when test="@available = 'in_stock' and $avail >= $sell_by">
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[out of stock]]&gt;</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:element>
        <xsl:variable name="size_id">
            <xsl:choose>
                <xsl:when test="@name!=''">
                    <xsl:value-of select="@id" />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text>-</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="product_currency">
            <xsl:choose>
                <xsl:when test="../../@currency!=''">
                    <xsl:value-of select="../../@currency" />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="@currency" />
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="cena_serwis">
            <xsl:choose>
                <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                    <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site/@gross" />
                </xsl:when>
                <xsl:when test="iaiext:pricecomparator_price/iaiext:site">
                    <xsl:value-of select="iaiext:pricecomparator_price/iaiext:site/@gross" />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text>0</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="cena_przekreslona">
            <xsl:choose>
                <!-- cena przekreslona dla rozmiaru lub domyślna -->
                <xsl:when test="sizes/size/strikethrough_retail_price">
                    <xsl:value-of select="sizes/size/strikethrough_retail_price/@gross" />
                </xsl:when>
                <xsl:when test="strikethrough_retail_price">
                    <xsl:value-of select="strikethrough_retail_price/@gross" />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text>0</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="cena_przedpromocyjna">
            <xsl:choose>
                <!-- cena standard gdy jest cena promocyjna rozmiaru -->
                <xsl:when test="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = $size_id]/@panel_name != '' and
                                ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = $size_id]/@gross > price/@gross">
                    <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = $size_id]/@gross" />
                </xsl:when>
                <!-- cena standard gdy jest cena promocyna standardowej ceny -->
                <xsl:when test="../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross">
                    <xsl:value-of select="../../promotion/price/normal_retail_price/@gross" />
                </xsl:when>
                <!-- cena standard gdy jest cena promocyjna rozmiaru -->
                <xsl:when test="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = $size_id]/@panel_name != '' and
                                promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = $size_id]/@gross > price/@gross">
                    <xsl:value-of select="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = $size_id]/@gross" />
                </xsl:when>
                <!-- cena standard gdy jest cena promocyna standardowej ceny -->
                <xsl:when test="promotion/price/normal_retail_price and promotion/price/normal_retail_price/@gross > price/@gross">
                    <xsl:value-of select="promotion/price/normal_retail_price/@gross" />
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text>0</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="mainPrice">
            <xsl:choose>
                <xsl:when test="$cena_serwis > 0">
                    <xsl:choose>
                        <xsl:when test="$cena_przedpromocyjna > $cena_serwis or $cena_przekreslona > $cena_serwis">
                            <xsl:choose>
                                <xsl:when test="$cena_przedpromocyjna > 0 and $cena_przedpromocyjna > $cena_przekreslona">
                                    <!-- <xsl:value-of select="$cena_przedpromocyjna * $sell_by" /> -->
                                    <xsl:value-of select="$cena_przedpromocyjna" />
                                </xsl:when>
                                <xsl:otherwise>
                                    <!-- <xsl:value-of select="$cena_przekreslona * $sell_by" /> -->
                                    <xsl:value-of select="$cena_przekreslona" />
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:otherwise>
                            <!-- <xsl:value-of select="$cena_serwis * $sell_by" /> -->
                            <xsl:value-of select="$cena_serwis" />
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:choose>
                        <xsl:when test="$cena_przedpromocyjna > price/@gross or $cena_przekreslona > price/@gross">
                            <xsl:choose>
                                <xsl:when test="$cena_przedpromocyjna > 0 and $cena_przedpromocyjna > $cena_przekreslona">
                                    <!-- <xsl:value-of select="$cena_przedpromocyjna * $sell_by" /> -->
                                    <xsl:value-of select="$cena_przedpromocyjna" />
                                </xsl:when>
                                <xsl:otherwise>
                                    <!-- <xsl:value-of select="$cena_przekreslona * $sell_by" /> -->
                                    <xsl:value-of select="$cena_przekreslona" />
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:otherwise>
                            <!-- <xsl:value-of select="price/@gross * $sell_by" /> -->
                            <xsl:value-of select="price/@gross" />
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:element name="g:shipping">
            <xsl:element name="g:price">
                <xsl:choose>
                    <xsl:when test="$mainPrice >= $kwota_dla_darmowej_dostawy">
                        <xsl:text><![CDATA[0]]></xsl:text>
                    </xsl:when>
                    <xsl:when test="$kwota_dla_wiekszych_zamowien != '' and $mainPrice >= $kwota_dla_wiekszych_zamowien">
                        <xsl:value-of select="$Koszt_dostawy_wiekszych_zamowien" />
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="$Koszt_dostawy" />
                    </xsl:otherwise>
                </xsl:choose>
                <xsl:text><![CDATA[ ]]></xsl:text>
                <xsl:value-of select="$product_currency" />
            </xsl:element>
            <xsl:element name="g:country">
                <xsl:value-of select="$Kraj_dostawy" />
            </xsl:element>
            <xsl:element name="g:min_handling_time">
                <xsl:value-of select="$Czas_obsługi_zamówienia_na_magazynie" />
            </xsl:element>
            <xsl:element name="g:max_handling_time">
                <xsl:value-of select="$Czas_obsługi_zamówienia_na_magazynie + ceiling($Czas_obsługi_zamówienia_na_magazynie div 3)" />
            </xsl:element>
            <xsl:element name="g:min_transit_time">
                <xsl:value-of select="$Czas_dostawy_zamówienia" />
            </xsl:element>
            <xsl:element name="g:max_transit_time">
                <xsl:value-of select="$Czas_dostawy_zamówienia + ceiling($Czas_dostawy_zamówienia div 3)" />
            </xsl:element>
        </xsl:element>
        <xsl:element name="g:shipping_weight">
            <xsl:if test="@weight">
                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                <xsl:value-of select="format-number(@weight div 1000, '#.##')" />
                <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
            </xsl:if>
        </xsl:element>
    </xsl:template>
    
    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:text><![CDATA[ ]]></xsl:text>
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true" />
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true" />
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    
    <xsl:template name="tokenize">
        <xsl:param name="text" />
        <xsl:param name="delimiter" select="'.'" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, $delimiter)" />
                <xsl:value-of select="$delimiter" />
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)" />
                    <xsl:with-param name="delimiter" select="$delimiter" />
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
        </xsl:choose>
    </xsl:template>
    
    <xsl:template name="wordFormat">
        <xsl:param name="text" />
        <xsl:param name="delimiter" select="' '" />
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)" />
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)" />
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)" />
                        <xsl:value-of select="$delimiter" />
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)" />
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')" />
                        <xsl:value-of select="$delimiter" />
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)" />
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')" />
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)" />
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)" />
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')" />
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')" />
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')" />
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text" />
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)" />
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)" />
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')" />
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    
    <xsl:template name="string-replace-all">
        <xsl:param name="text" />
        <xsl:param name="replace" />
        <xsl:param name="by" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, $replace) and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text,$replace)" />
                <xsl:value-of select="$by" />
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)" />
                    <xsl:with-param name="replace" select="$replace" />
                    <xsl:with-param name="by" select="$by" />
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text" />
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    
    <!-- 03.07.2025 MD -->
    <xsl:template name="upperCaseCount"> 
        <xsl:param name="text"/> 
        <xsl:variable name="uppercaseOnly" select="translate($text, concat($lowerLetters,'0123456789., *%&amp;;\/-+()'), '')"/> 
        <xsl:value-of select="string-length($uppercaseOnly)"/> 
    </xsl:template> 
    <xsl:template name="lowerCaseCount"> 
        <xsl:param name="text"/> 
        <xsl:variable name="lowercaseOnly" select="translate($text, concat($upperLetters,'0123456789., *%&amp;;\/-+()'), '')"/> 
        <xsl:value-of select="string-length($lowercaseOnly)"/> 
    </xsl:template> 

    <!-- 07.08.2025 MD -->
    <xsl:template name="find_unit_measure">
        <xsl:param name="str"/> 
        <xsl:param name="prev" select="''"/> 
        <!-- 1) Rozbijamy na pierwszy token i resztę --> 
        <xsl:variable name="token"> 
            <xsl:choose> 
                <xsl:when test="contains($str,' ')"> 
                    <xsl:value-of select="substring-before($str,' ')"/> 
                </xsl:when> 
                <xsl:otherwise> 
                    <xsl:value-of select="$str"/> 
                </xsl:otherwise> 
            </xsl:choose> 
        </xsl:variable> 
        <xsl:variable name="remainingString"> 
            <xsl:choose> 
                <xsl:when test="contains($str,' ')"> 
                    <xsl:value-of select="substring-after($str,' ')"/> 
                </xsl:when> 
                <xsl:otherwise/> 
            </xsl:choose> 
        </xsl:variable> 
        <!-- 2) Normalizacja i usunięcie znaków specjalnych (*, %) -->
        <xsl:variable name="normalizedToken" select="normalize-space($token)"/> 
        <xsl:variable name="cleanedToken" select="translate($normalizedToken,'*%&amp;;\/-+()','')"/> 
        <!-- 3) Przygotowujemy części przed i po 'x' --> 
        <xsl:variable name="countPart" select="number(substring-before($cleanedToken,'x'))"/> 
        <xsl:variable name="afterXPart" select="substring-after($cleanedToken,'x')"/> 
        <xsl:choose> <!-- 3o) odfiltrowanie problematycznych tokenów -->
            <xsl:when test="contains($token,'xl') and $remainingString != ''"> 
                <xsl:call-template name="find_unit_measure"> 
                    <xsl:with-param name="str" select="$remainingString"/> 
                    <xsl:with-param name="prev" select="$cleanedToken"/> 
                </xsl:call-template> 
            </xsl:when> <!-- 3a) wzorzec “3x40ml” --> 
            <xsl:when test="$afterXPart != '' and 
                            translate($countPart,'0123456789.,','') = '' and 
                            string-length(translate($afterXPart,'0123456789.,','')) &gt; 0 and
                                                                         string-length(translate($afterXPart,'0123456789.,','')) &lt; 3 and
                                                                         string-length(translate($afterXPart,'0123456789.,kgml','')) = 0"> 
                <xsl:variable name="singleQuantity" select="number( translate($afterXPart,$lowerLetters,'') )"/> 
                <xsl:variable name="unit" select="translate($afterXPart,'0123456789.,','')"/> 
                <xsl:value-of select="concat($countPart * $singleQuantity, ' ', $unit)"/> 
            </xsl:when> <!-- 3b) wzorzec “3x50” + oddzielna jednostka w następnym tokenie --> 
            <xsl:when test="$afterXPart != '' and 
                            translate($countPart,'0123456789.,','') = '' and 
                            translate($afterXPart,'0123456789.,','') = '' "> 
                <xsl:variable name="nextTok" select="substring-before(concat($remainingString,' '),' ')"/> 
                <xsl:variable name="unit" select="translate($nextTok,'0123456789.,','')"/> 
                <xsl:if test=" $unit='ml' or $unit='l' or $unit='g' or $unit='kg' "> 
                    <xsl:variable name="singleQuantity" select="number($afterXPart)"/> 
                    <xsl:value-of select="concat($countPart * $singleQuantity, ' ', $unit)"/> 
                </xsl:if> 
            </xsl:when> <!-- 4) prosty token typu “1000ml” lub “1000ml*” --> 
            <xsl:when test="translate($cleanedToken,$lowerLetters,'') != '' and 
                            string-length(translate($cleanedToken,'0123456789.,','')) &gt; 0 and 
                                                                           (translate($cleanedToken,'0123456789.,','')='ml' or 
                                                                           translate($cleanedToken,'0123456789.,','')='l' or 
                                                                           translate($cleanedToken,'0123456789.,','')='g' or 
                                                                           translate($cleanedToken,'0123456789.,','')='kg' ) "> 
                <xsl:variable name="numPart" select="translate($cleanedToken,$lowerLetters,'')"/> 
                <xsl:variable name="unitPart" select="translate($cleanedToken,'0123456789.,','')"/> 
                <xsl:value-of select="concat($numPart, ' ', $unitPart)"/> 
            </xsl:when> <!-- 5) rozdzielone “50” + “ml” jako osobne tokeny --> 
            <xsl:when test=" ($cleanedToken='ml' or $cleanedToken='l' or $cleanedToken='g' or $cleanedToken='kg') and 
                            translate($prev,$lowerLetters,'') != '' "> 
                <xsl:value-of select="concat(translate($prev,$lowerLetters,''), ' ', $cleanedToken ) "/> 
            </xsl:when> <!-- 6) inaczej rekurencyjnie dalej --> 
            <xsl:when test="$remainingString != ''"> 
                <xsl:call-template name="find_unit_measure"> 
                    <xsl:with-param name="str" select="$remainingString"/> 
                    <xsl:with-param name="prev" select="$cleanedToken"/> 
                </xsl:call-template> 
            </xsl:when>
        </xsl:choose> 
    </xsl:template>
</xsl:stylesheet>