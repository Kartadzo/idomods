                                    <xsl:when test="../../price/@gross &lt;= 50"><xsl:text disable-output-escaping="yes">0-50 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 50 and ../../price/@gross &lt;= 100"><xsl:text disable-output-escaping="yes">50-100 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
