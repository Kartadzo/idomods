                                <xsl:when test="../../iaiext:navigation/iaiext:site[@id = '1']/iaiext:menu[@id = '1']/iaiext:item[substring-before(@textid ,'\') = 'Drony']/@textid">
                                      <g:product_type>
                                        <xsl:value-of select="translate(../../iaiext:navigation/iaiext:site[@id = '1']/iaiext:menu[@id = '1']/iaiext:item[substring-before(@textid ,'\') = 'Drony']/@textid, '\', '>')"/>
