<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">

    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <channel>
                <xsl:for-each select="/offer/products/product">
                    <xsl:for-each select="sizes/size">
                        <item>

                            <g:id>
                                <xsl:value-of select="@code"></xsl:value-of>
                            </g:id>

                            <!-- ean -->
                            <xsl:if test="@code_producer and @code_producer != ''">
                                <xsl:variable name="vnumsOnly" select="translate(@code_producer, translate(@code_producer,'0123456789',''), '')" />
                                <g:gtin>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="substring($vnumsOnly, (substring($vnumsOnly,1,1)='1') +1)" />
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </g:gtin>
                            </xsl:if>

                            <!-- Magazyny -->
                            <xsl:variable name="stocks">
                                <xsl:for-each select="stock">
                                    <xsl:choose>
                                        <xsl:when test="(@id = '1' or @id = '0') and @available_stock_quantity &gt; 0">
                                            <xsl:value-of select="@available_stock_quantity"></xsl:value-of>
                                            <xsl:text>/</xsl:text>
                                        </xsl:when>
                                        <xsl:when test="(@id = '1' or @id = '0') and @available_stock_quantity = -1 ">
                                            <xsl:value-of select="@available_stock_quantity"></xsl:value-of>
                                            <xsl:text>/</xsl:text>
                                        </xsl:when>
                                    </xsl:choose>
                                </xsl:for-each>
                            </xsl:variable>


                            <g:availability>
                                <xsl:choose>

                                    <xsl:when test="contains($stocks,'-1') and string-length($stocks) &gt;0">
                                        <!-- <xsl:text>999999</xsl:text> -->
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>in stock<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:when test="string-length($stocks) = 0">
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>out of stock<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>

                                        <!-- <xsl:value-of select="sum(sizes/size/stock[@id = '11'
                                        or
                                    @id = '-1' or @id = '13' or @id = '1' or @id = '8' or @id =
                                    '0']/@available_stock_quantity)"></xsl:value-of> -->
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>in stock<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>

                            </g:availability>
                            <!-- Koniec magazynów -->

                            <!-- short descr -->
                            <xsl:choose>
                                <xsl:when test="../../description/short_desc = ''">
                                    <xsl:variable name="returned_value_without_html">
                                        <xsl:call-template name="strip-tags">
                                            <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes" />
                                        </xsl:call-template>
                                    </xsl:variable>
                                    <xsl:variable name="returned_value_300_char" select="substring(normalize-space($returned_value_without_html),1,300)" />
                                    <xsl:variable name="value_cut">
                                        <xsl:call-template name="tokenize">
                                            <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,300)" />
                                        </xsl:call-template>
                                    </xsl:variable>
                                    <xsl:variable name="last_char" select="substring($returned_value_300_char, string-length($returned_value_300_char), 1)" />
                                    <xsl:choose>
                                        <xsl:when test="$last_char != '.'">
                                            <!-- chodzi oto ze nie ma przed kropka nic  -->
                                            <xsl:choose>
                                                <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut)) = ''">
