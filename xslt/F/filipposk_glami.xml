<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="''"/>
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='Kwota_dostawa_darmo'>1999999.00</xsl:variable>
    <xsl:variable name='Kwota_dostawa_większa'>5.00</xsl:variable>
    <xsl:variable name="Koszt_wysyłki">3.9</xsl:variable>
    <xsl:variable name="Koszt_wiekszej_wysyłki">3.9</xsl:variable>

    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <SHOP>
                <xsl:for-each select="/offer/products/product">
                    <xsl:for-each select="sizes/size[@available != 'unavailable' and stock[@id = '1'] and stock[@id = '1']/@available_stock_quantity &gt; '1']">
                        <SHOPITEM>
                            <!--Unikalny identyfikator produktu  -->
                            <ITEM_ID>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="@code"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </ITEM_ID>
                            <PROMOTION_ID>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="../../promotion/@iaiext:id"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </PROMOTION_ID>

                            <ITEMGROUP_ID>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="../../group/@id"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </ITEMGROUP_ID>
                            <!-- Tytuł -->
                            <PRODUCTNAME>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:call-template name="wordFormat">
                                    <xsl:with-param name="text" select="../../description/name/." tunnel="yes"/>
                                </xsl:call-template>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </PRODUCTNAME>
                            <!-- Opis -->
                            <!-- short descr -->
                            <xsl:variable name="from_parameters_raw">
                                <xsl:for-each select="../../parameters/parameter[@hide = 'n' and value/@name != '']">
                                    <xsl:text>&#xa;</xsl:text>
                                    <xsl:value-of select="@name"/>
                                    <xsl:text>: </xsl:text>
                                    <xsl:for-each select="value">
                                        <xsl:value-of select="@name"/>
                                        <xsl:text>; </xsl:text>
                                    </xsl:for-each>
                                </xsl:for-each>
                            </xsl:variable>
                            <xsl:variable name="from_parameters">
                                <xsl:choose>
                                    <xsl:when test="$from_parameters_raw != ''">
                                        <xsl:call-template name="tokenize">
                                            <xsl:with-param name="text" select="substring($from_parameters_raw, 1, 600)"/>
                                            <xsl:with-param name="delimeter" select="' '"/>
                                        </xsl:call-template>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text></xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <DESCRIPTION>
                                <xsl:choose>
                                    <xsl:when test="../../description/short_desc = '' and ../../description/long_desc = ''">
                                        <!-- nie jest git bo nie ma opisów  -->
                                        <xsl:if test="$from_parameters != ''">
                                            <xsl:value-of select="../../description/name"/>
                                            <xsl:value-of select="$from_parameters"/>
                                        </xsl:if>
                                    </xsl:when>
                                    <xsl:when test="../../description/short_desc = ''">
                                        <xsl:variable name = "returned_value_without_html">
                                            <xsl:call-template name="strip-tags">
                                                <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="returned_value_500_char" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                        <xsl:variable name="value_cut">
                                            <xsl:call-template name="tokenize">
                                                <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="last_char" select="substring($returned_value_500_char, string-length($returned_value_500_char), 1)"/>
                                        <xsl:choose>
                                            <xsl:when test="$last_char != '.'">
                                                <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                <xsl:choose>
                                                    <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut)) = ''">
                                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="$returned_value_500_char"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- jest przed kropka text -->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- Mamy kropke na koncu i jest git -->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$returned_value_500_char"/>
                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                        <!-- załóżmy -->
                                        <xsl:choose>
                                            <xsl:when test="string-length(../../description/short_desc) > 300">
                                                <!-- jest git bo ma wiecej niz  -->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="../../description/short_desc"/>
                                                <xsl:if test="string-length(../../description/short_desc) &lt; 400 and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:variable name = "returned_value_without_html">
                                                    <xsl:call-template name="strip-tags">
                                                        <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:variable name="returned_value_500_char" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                                <xsl:variable name="value_cut">
                                                    <xsl:call-template name="tokenize">
                                                        <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:variable name="last_char" select="substring($returned_value_500_char, string-length($returned_value_500_char), 1)"/>
                                                <xsl:choose>
                                                    <xsl:when test="$last_char != '.'">
                                                        <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                        <xsl:choose>
                                                            <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut)) = ''">
                                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                                <xsl:value-of select="$returned_value_500_char"/>
                                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                    <xsl:text>&#xa;</xsl:text>
                                                                    <xsl:value-of select="../../description/name"/>
                                                                    <xsl:value-of select="$from_parameters"/>
                                                                </xsl:if>
                                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                            </xsl:when>
                                                            <xsl:otherwise>
                                                                <!-- jest przed kropka text -->
                                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                                <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))"/>
                                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                    <xsl:text>&#xa;</xsl:text>
                                                                    <xsl:value-of select="../../description/name"/>
                                                                    <xsl:value-of select="$from_parameters"/>
                                                                </xsl:if>
                                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                            </xsl:otherwise>
                                                        </xsl:choose>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- Mamy kropke na koncu i jest git -->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="$returned_value_500_char"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </DESCRIPTION>
                            <URL>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </URL>
                            <URL_SIZE>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                                <xsl:text>?selected_size=</xsl:text>
                                <xsl:value-of select="@id"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </URL_SIZE>
                            <!-- g product type -->
                            <xsl:for-each select="../../iaiext:navigation/iaiext:site[1]/iaiext:menu">
                                <xsl:for-each select="iaiext:item[position() &lt; 10]">
                                    <CATEGORYTEXT>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="translate(@textid,'\','|')"/>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </CATEGORYTEXT>
                                </xsl:for-each>
                            </xsl:for-each>

                            <xsl:choose>
                                <xsl:when test="../../images/icons/auction_icon/@url">
                                    <IMGURL>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="../../images/icons/auction_icon/@url"></xsl:value-of>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </IMGURL>
                                    <xsl:for-each select="../../images/large/image[position() &lt; 5]">
                                        <IMGURL_ALTERNATIVE>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="@url"/>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </IMGURL_ALTERNATIVE>
                                    </xsl:for-each>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:variable name="vLowest">
                                        <xsl:for-each select="../../images/large/image/@iaiext:priority">
                                            <xsl:sort data-type="number"/>
                                            <xsl:if test="position()=1">
                                                <xsl:value-of select="."/>
                                            </xsl:if>
                                        </xsl:for-each>
                                    </xsl:variable>

                                    <xsl:for-each select="../../images/large/image[position() &lt; 5]">
                                        <xsl:choose>
                                            <xsl:when test="@iaiext:priority = number($vLowest)">
                                                <IMGURL>
                                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                    <xsl:value-of select="@url"/>
                                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                </IMGURL>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <IMGURL_ALTERNATIVE>
                                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                    <xsl:value-of select="@url"/>
                                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                </IMGURL_ALTERNATIVE>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:for-each>
                                </xsl:otherwise>
                            </xsl:choose>

                            <xsl:variable name="cena_serwis">
                                <xsl:choose>
                                    <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                                        <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text>0</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <xsl:variable name="mainPrice">
                                <xsl:choose>
                                    <xsl:when test="../../strikethrough_retail_price and  ../../strikethrough_retail_price/@gross > 0 and
                                      ../../strikethrough_retail_price/@gross > price/@gross and 
                                      price/@gross = ../../price/@gross and 
                                      ../../strikethrough_retail_price/@gross > $cena_serwis">
                                        <xsl:choose>
                                            <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                                                <xsl:value-of select="../../strikethrough_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="price/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and ../../price/@gross = price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="price/@gross != ../../price/@gross and
                                            ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                                            </xsl:when>
                                            <xsl:when test="price/@gross = ../../price/@gross and
                                            ../../promotion/price/normal_retail_price/@gross > price/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="price/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:variable>
                            <PRICE_VAT>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="price/@gross"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </PRICE_VAT>
                            <DELIVERY_DATE>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[4]]&gt;</xsl:text>
                            </DELIVERY_DATE>
                            <xsl:choose>
                                <xsl:when test="$mainPrice >= $Kwota_dostawa_darmo">
                                    <DELIVERY>
                                        <DELIVERY_PRICE>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[0]]&gt;</xsl:text>
                                        </DELIVERY_PRICE>
                                    </DELIVERY>
                                </xsl:when>
                                <xsl:when test="$mainPrice >= $Kwota_dostawa_większa">
                                    <DELIVERY>
                                        <DELIVERY_PRICE>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="$Koszt_wiekszej_wysyłki"/>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </DELIVERY_PRICE>
                                    </DELIVERY>
                                </xsl:when>
                                <xsl:otherwise>
                                    <DELIVERY>
                                        <DELIVERY_PRICE>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="$Koszt_wysyłki"/>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </DELIVERY_PRICE>
                                    </DELIVERY>
                                </xsl:otherwise>
                            </xsl:choose>
                            <!--Versja 2.0  -->
                            <xsl:choose>
                                <xsl:when test="@code_producer and @code_producer!=''">
                                    <!-- mamy kod producenta -->
                                    <!-- format-number(@code_on_card, '#')" -->
                                    <xsl:variable name="code_producer_variable">
                                        <xsl:value-of select="@code_producer"></xsl:value-of>
                                    </xsl:variable>
                                    <xsl:variable name="kod_producer" select="substring-after($code_producer_variable, substring-before($code_producer_variable, substring(translate($code_producer_variable, '0', ''), 1, 1)))">
                                    </xsl:variable>

                                    <xsl:choose>
                                        <xsl:when test="string-length($kod_producer) = '14' or string-length($kod_producer) = '13' or string-length($kod_producer) = '12' or string-length($kod_producer) = '8'">
                                            <GTIN>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$kod_producer"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </GTIN>
                                        </xsl:when>
                                    </xsl:choose>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:variable name="code_producer_variable2">
                                        <xsl:value-of select="../../@code_on_card"></xsl:value-of>
                                    </xsl:variable>
                                    <xsl:variable name="code_on_card" select="substring-after($code_producer_variable2, substring-before($code_producer_variable2, substring(translate($code_producer_variable2, '0', ''), 1, 1)))"></xsl:variable>
                                    <!-- tutaj uzyjemy code on card -->

                                    <xsl:choose>
                                        <xsl:when test="string-length($code_on_card) = '14' or string-length($code_on_card) = '13' or string-length($code_on_card) = '12' or string-length($code_on_card) = '8'">
                                            <GTIN>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$code_on_card"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </GTIN>
                                        </xsl:when>
                                    </xsl:choose>
                                </xsl:otherwise>
                            </xsl:choose>
                            <!-- Marka -->
                            <MANUFACTURER>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="normalize-space(../../producer/@name)"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </MANUFACTURER>
                            <!-- kolor -->
                            <xsl:choose>
                                <xsl:when test="../../parameters/parameter/@context_id = 'CONTEXT_COLOR'">
                                    <PARAM>
                                        <PARAM_NAME>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[Farba]]&gt;</xsl:text>
                                        </PARAM_NAME>
                                        <VAL>
                                            <xsl:for-each select="../../parameters/parameter[@context_id = 'CONTEXT_COLOR']/value">
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:if test="position() &gt; 1">
                                                    <xsl:text disable-output-escaping="yes"> || </xsl:text>
                                                </xsl:if>
                                                <xsl:value-of select="@name"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:for-each>
                                        </VAL>
                                    </PARAM>
                                </xsl:when>
                                <xsl:when test="../../parameters/parameter/@group_distinction = 'y' and ../../parameters/parameter/@name = 'Farba'">
                                    <PARAM>
                                        <PARAM_NAME>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[Farba]]&gt;</xsl:text>
                                        </PARAM_NAME>
                                        <VAL>
                                            <xsl:for-each select="../../parameters/parameter[@name = 'Farba']/value">
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:if test="position() &gt; 1">
                                                    <xsl:text disable-output-escaping="yes"> || </xsl:text>
                                                </xsl:if>
                                                <xsl:value-of select="@name"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:for-each>
                                        </VAL>
                                    </PARAM>
                                </xsl:when>
                            </xsl:choose>
                            <PARAM>
                                <PARAM_NAME>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[veľkosť]]&gt;</xsl:text>
                                </PARAM_NAME>
                                <VAL>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="@name"/>
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </VAL>
                            </PARAM>
                            <PARAM>
                                <PARAM_NAME>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[size_system]]&gt;</xsl:text>
                                </PARAM_NAME>
                                <VAL>
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[EU]]&gt;</xsl:text>
                                </VAL>
                            </PARAM>
                            <xsl:for-each select="../../parameters/parameter">
                                <xsl:choose>
                                    <xsl:when test="@hide = 'n' and 
                                    not(@context_id = 'CONTEXT_COLOR' or @name = 'Farba') and 
                                    not(@name = 'Zloženie ponožiek')">
                                        <PARAM>
                                            <xsl:for-each select="value">
                                                <PARAM_NAME>
                                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                    <xsl:value-of select="../@name"></xsl:value-of>
                                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                </PARAM_NAME>
                                                <VAL>
                                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                    <xsl:value-of select="@name"></xsl:value-of>
                                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                </VAL>
                                                <xsl:choose>
                                                    <xsl:when test="../@name = 'Dominantný materiál' or 
                                                    ../@name = 'Materiál podrážky' or 
                                                    ../@name = 'Materiál stielky' or 
                                                    ../@name = 'Vonkajší materiál' or 
                                                    ../@name = 'Podrážka' or 
                                                    ../@name = 'Materiál'">
                                                        <PERCENTAGE>
                                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                            <xsl:value-of select="format-number(100 div count(../value), '#.##')"/>
                                                            <xsl:text disable-output-escaping="yes">%]]&gt;</xsl:text>
                                                        </PERCENTAGE>
                                                    </xsl:when>
                                                </xsl:choose>
                                            </xsl:for-each>
                                        </PARAM>
                                    </xsl:when>
                                    <xsl:when test="@name = 'Zloženie ponožiek'">
                                        <xsl:call-template name="rozbicie_skladu_skarpetek">
                                            <xsl:with-param name="text" select="translate(value/@name, ',', '')" tunnel="yes"/>
                                        </xsl:call-template>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:for-each>
                        </SHOPITEM>
                    </xsl:for-each>
                </xsl:for-each>
            </SHOP>
        </rss>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="rozbicie_skladu_skarpetek">
        <xsl:param name="text"/>
        <xsl:param name="replace" select="' '"/>
        <xsl:variable name="word">
            <xsl:value-of select="substring-after($text,$replace)"/>
        </xsl:variable>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <PARAM>
                    <PARAM_NAME>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[Zloženie ponožiek]]&gt;</xsl:text>
                    </PARAM_NAME>
                    <xsl:if test="contains(substring-before($text,$replace), '%')">
                        <VAL>
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:choose>
                                <xsl:when test="contains($word, ' ')">
                                    <xsl:value-of select="substring-before($word,$replace)"/>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:value-of select="$word"/>
                                </xsl:otherwise>
                            </xsl:choose>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </VAL>
                        <PERCENTAGE>
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="substring-before($text,$replace)"/>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </PERCENTAGE>
                    </xsl:if>
                    <xsl:if test="not(contains(substring-before($text,$replace), '%'))">
                        <VAL>
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="substring-before($text,$replace)"/>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </VAL>
                        <PERCENTAGE>
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:choose>
                                <xsl:when test="contains($word, ' ')">
                                    <xsl:value-of select="substring-before($word,$replace)"/>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:value-of select="$word"/>
                                </xsl:otherwise>
                            </xsl:choose>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </PERCENTAGE>
                    </xsl:if>
                </PARAM>
                <xsl:call-template name="rozbicie_skladu_skarpetek">
                    <xsl:with-param name="text" select="substring-after($word,$replace)"/>
                </xsl:call-template>
            </xsl:when>
        </xsl:choose>
    </xsl:template>
</xsl:stylesheet>