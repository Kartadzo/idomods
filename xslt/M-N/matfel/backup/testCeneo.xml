<?xmlversion="1.0"encoding="UTF-8"?>
<xsl:stylesheetversion="1.0"
xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
<xsl:outputmethod="xml"indent="yes"/>

<!--Głównyszablonprzetwarzającydokument-->
<xsl:templatematch="/">
<offersversion="1">
<xsl:variablename="responsibleProducers"/>
<xsl:variablename="responsiblePersons"/>

<!--Przetwarzaniekażdegoelementu"product"-->
<xsl:for-eachselect="//product">
<!--Przetwarzanieodpowiedzialnychproducentów-->
<xsl:iftest="iaiext:responsible_entity/producer">
<xsl:iftest="not(contains($responsibleProducers,iaiext:responsible_entity/producer/@id))">
<xsl:variablename="newProducer">
<pid="{iaiext:responsible_entity/producer/@id}">
<name>
<xsl:value-ofselect="iaiext:responsible_entity/producer/name"/>
</name>
<address>
<countryCode>
<xsl:value-ofselect="iaiext:responsible_entity/producer/country"/>
</countryCode>
<street>
<xsl:value-ofselect="iaiext:responsible_entity/producer/street"/>
</street>
<postalCode>
<xsl:value-ofselect="iaiext:responsible_entity/producer/zipcode"/>
</postalCode>
<city>
<xsl:value-ofselect="iaiext:responsible_entity/producer/city"/>
</city>
</address>
<contact>
<email>
<xsl:value-ofselect="iaiext:responsible_entity/producer/mail"/>
</email>
<phoneNumber>
<xsl:value-ofselect="iaiext:responsible_entity/producer/phone"/>
</phoneNumber>
</contact>
</p>
</xsl:variable>
<xsl:variablename="responsibleProducers"select="concat($responsibleProducers,$newProducer)"/>
</xsl:if>
</xsl:if>

<!--Przetwarzanieodpowiedzialnychosób-->
<xsl:iftest="iaiext:responsible_persons/person">
<xsl:iftest="not(contains($responsiblePersons,iaiext:responsible_persons/person/@id))">
<xsl:variablename="newPerson">
<pid="{iaiext:responsible_persons/person/@id}">
<name>
<xsl:value-ofselect="iaiext:responsible_persons/person/name"/>
</name>
<address>
<countryCode>
<xsl:value-ofselect="iaiext:responsible_persons/person/country"/>
</countryCode>
<street>
<xsl:value-ofselect="iaiext:responsible_persons/person/street"/>
</street>
<postalCode>
<xsl:value-ofselect="iaiext:responsible_persons/person/zipcode"/>
</postalCode>
<city>
<xsl:value-ofselect="iaiext:responsible_persons/person/city"/>
</city>
</address>
<contact>
<email>
<xsl:value-ofselect="iaiext:responsible_persons/person/mail"/>
</email>
<phoneNumber>
<xsl:value-ofselect="iaiext:responsible_persons/person/phone"/>
</phoneNumber>
</contact>
</p>
</xsl:variable>
<xsl:variablename="responsiblePersons"select="concat($responsiblePersons,$newPerson)"/>
</xsl:if>
</xsl:if>

<!--Przetwarzanieproduktów-->
<oid="{@id}">
<description>
<nametype="name">
<xsl:value-ofselect="description/name"/>
</name>
</description>
<attrs>
<aname="Producentodpowiedzialny">
<xsl:value-ofselect="iaiext:responsible_entity/producer/@id"/>
</a>
<aname="Podmiotodpowiedzialny">
<xsl:value-ofselect="iaiext:responsible_persons/person/@id"/>
</a>
</attrs>
</o>
</xsl:for-each>

<!--Wyświetlanieodpowiedzialnychproducentów-->
<responsibleProducers>
<xsl:value-ofselect="$responsibleProducers"disable-output-escaping="yes"/>
</responsibleProducers>

<!--Wyświetlanieodpowiedzialnychosób-->
<respons></respons>









