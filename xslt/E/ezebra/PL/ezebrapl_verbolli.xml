<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="''"/>
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='Kwota_za_darmo_wysylka'>159.00</xsl:variable>
    <xsl:variable name='Kwota_za_darmo_wysylka_large'>5.00</xsl:variable>
    <xsl:variable name="Kwota_wysylki">10.89</xsl:variable>
    <xsl:variable name="Kwota_wysylki_large">10.89</xsl:variable>

    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <channel>
                <title>www.ezebra.pl</title>
                <link>https://www.ezebra.pl/</link>
                <description>Produkty ze sklepu https://www.ezebra.pl/</description>
                <xsl:for-each select="/offer/products/product">
                    <xsl:for-each select="sizes/size">
                        <item>
                            <!--Unikalny identyfikator produktu  -->
                            <id>
                                <xsl:value-of select="@code"/>
                            </id>
                            <!-- Tytuł -->
                            <title>
                                <xsl:call-template name="wordFormat">
                                    <xsl:with-param name="text" select="../../description/name/." tunnel="yes"/>
                                </xsl:call-template>
                            </title>
                            <!-- Opis -->
                            <!-- short descr -->
                            <xsl:variable name="from_parameters_raw">
                                <xsl:for-each select="../../parameters/parameter[@hide = 'n' and value/@name != '']">
                                    <xsl:text>&#xa;</xsl:text>
                                    <xsl:value-of select="@name"/>
                                    <xsl:text>: </xsl:text>
                                    <xsl:for-each select="value">
                                        <xsl:value-of select="@name"/>
                                        <xsl:text>; </xsl:text>
                                    </xsl:for-each>
                                </xsl:for-each>
                            </xsl:variable>
                            <xsl:variable name="from_parameters">
                                <xsl:choose>
                                    <xsl:when test="$from_parameters_raw != ''">
                                        <xsl:call-template name="tokenize">
                                            <xsl:with-param name="text" select="substring($from_parameters_raw, 1, 600)"/>
                                            <xsl:with-param name="delimeter" select="' '"/>
                                        </xsl:call-template>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text></xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <description>
                                <xsl:choose>
                                    <xsl:when test="../../description/short_desc = '' and ../../description/long_desc = ''">
                                        <!-- nie jest git bo nie ma opisów  -->
                                        <xsl:if test="$from_parameters != ''">
                                            <xsl:value-of select="../../description/name"/>
                                            <xsl:value-of select="$from_parameters"/>
                                        </xsl:if>
                                    </xsl:when>
                                    <xsl:when test="../../description/short_desc = ''">
                                        <xsl:variable name = "returned_value_without_html">
                                            <xsl:call-template name="strip-tags">
                                                <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="returned_value_500_char" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                        <xsl:variable name="value_cut">
                                            <xsl:call-template name="tokenize">
                                                <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="last_char" select="substring($returned_value_500_char, string-length($returned_value_500_char), 1)"/>
                                        <xsl:choose>
                                            <xsl:when test="$last_char != '.'">
                                                <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                <xsl:choose>
                                                    <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut)) = ''">
                                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                        <xsl:value-of select="$returned_value_500_char"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- jest przed kropka text -->
                                                        <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- Mamy kropke na koncu i jest git -->
                                                <xsl:value-of select="$returned_value_500_char"/>
                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                        <!-- załóżmy -->
                                        <xsl:choose>
                                            <xsl:when test="string-length(../../description/short_desc) > 300">
                                                <!-- jest git bo ma wiecej niz  -->
                                                <xsl:value-of select="../../description/short_desc"/>
                                                <xsl:if test="string-length(../../description/short_desc) &lt; 400 and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:variable name = "returned_value_without_html">
                                                    <xsl:call-template name="strip-tags">
                                                        <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:variable name="returned_value_500_char" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                                <xsl:variable name="value_cut">
                                                    <xsl:call-template name="tokenize">
                                                        <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:variable name="last_char" select="substring($returned_value_500_char, string-length($returned_value_500_char), 1)"/>
                                                <xsl:choose>
                                                    <xsl:when test="$last_char != '.'">
                                                        <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                        <xsl:choose>
                                                            <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut)) = ''">
                                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                                <xsl:value-of select="$returned_value_500_char"/>
                                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                    <xsl:text>&#xa;</xsl:text>
                                                                    <xsl:value-of select="../../description/name"/>
                                                                    <xsl:value-of select="$from_parameters"/>
                                                                </xsl:if>
                                                            </xsl:when>
                                                            <xsl:otherwise>
                                                                <!-- jest przed kropka text -->
                                                                <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))"/>
                                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                    <xsl:text>&#xa;</xsl:text>
                                                                    <xsl:value-of select="../../description/name"/>
                                                                    <xsl:value-of select="$from_parameters"/>
                                                                </xsl:if>
                                                            </xsl:otherwise>
                                                        </xsl:choose>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- Mamy kropke na koncu i jest git -->
                                                        <xsl:value-of select="$returned_value_500_char"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </description>
                            <!-- g product type -->
                            <xsl:for-each select="../../iaiext:navigation/iaiext:site[1]/iaiext:menu[1]">
                                <xsl:for-each select="iaiext:item[position() &lt; 10]">
                                    <!-- <category> -->
                                    <xsl:text disable-output-escaping="yes">&lt;category</xsl:text>
                                    <xsl:value-of select="position()"/>
                                    <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                    <xsl:value-of select="translate(@textid,'\','&gt;')"/>
                                    <xsl:text disable-output-escaping="yes">&lt;/category</xsl:text>
                                    <xsl:value-of select="position()"/>
                                    <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                    <!-- </category> -->
                                </xsl:for-each>
                            </xsl:for-each>

                            <!-- link do produktu -->
                            <!-- WYMAGANY: Link do produktu -->
                            <!-- pl zzamienic na jezyk ktory bedziemy realizować -->
                            <url>
                                <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                                <xsl:text disable-output-escaping="yes">.html</xsl:text>
                            </url>

                            <!-- Dostępność -->
                            <quantityInStock>
                                <xsl:choose>
                                    <xsl:when test="sum(stock[@id = '1' or @id = '0' or @id = '2' or @id = '3']/@available_stock_quantity) != 0 and stock[@id = '1' or @id = '0' or @id = '2' or @id = '3']/@available_stock_quantity != '-1' and stock[@id = '1' or @id = '0' or @id = '2' or @id = '3']/@available_stock_quantity != '-1'">
                                        <xsl:value-of select="sum(stock[@id = '1' or @id = '0' or @id = '2' or @id = '3']/@available_stock_quantity)"/>
                                    </xsl:when>
                                    <xsl:when test="stock[@id = '1' or @id = '0' or @id = '2' or @id = '3']/@available_stock_quantity = '-1' or stock[@id = '1' or @id = '0' or @id = '2' or @id = '3']/@available_stock_quantity != '-1'">
                                        <xsl:text disable-output-escaping="yes">999</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text disable-output-escaping="yes">0</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </quantityInStock>

                            <xsl:variable name="mainPrice">
                                <xsl:choose>
                                    <xsl:when test="../../strikethrough_retail_price and  ../../strikethrough_retail_price/@gross > 0 and
                                      ../../strikethrough_retail_price/@gross > price/@gross and 
                                      price/@gross = ../../price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                                                <xsl:value-of select="../../strikethrough_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="price/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and ../../price/@gross = price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="price/@gross != ../../price/@gross and
                                            ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                                            </xsl:when>
                                            <xsl:when test="price/@gross = ../../price/@gross and
                                            ../../promotion/price/normal_retail_price/@gross > price/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="price/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:variable>
                            <originalPrice>
                                <xsl:value-of select="$mainPrice"/>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="../../@currency"/>
                            </originalPrice>
                            <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
                            <xsl:if test="../../promotion/price/normal_retail_price or ../../strikethrough_retail_price">
                                <xsl:choose>
                                    <xsl:when test = "
                                      (../../strikethrough_retail_price and ../../strikethrough_retail_price/@gross > price/@gross) or
                                      (../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross) or
                                      (../../promotion/price/normal_retail_price and ../../price/@gross != price/@gross and 
                                      ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross)">
                                        <sale_price>
                                            <xsl:value-of select="price/@gross"/>
                                            <xsl:text><![CDATA[ ]]></xsl:text>
                                            <xsl:value-of select="../../@currency"/>
                                        </sale_price>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:if>

                            <!-- Marka -->
                            <brand>
                                <xsl:value-of select="normalize-space(../../producer/@name)"/>
                            </brand>

                            <groupId>
                                <xsl:value-of select="../../group/@id"/>
                            </groupId>
                            <xsl:variable name="vLowest">
                                <xsl:for-each select="../../images/large/image/@iaiext:priority">
                                    <xsl:sort data-type="number"/>
                                    <xsl:if test="position()=1">
                                        <xsl:value-of select="."/>
                                    </xsl:if>
                                </xsl:for-each>
                            </xsl:variable>
                            <xsl:for-each select="../../images/large/image[position() &lt; 10]">
                                <xsl:choose>
                                    <xsl:when test="@iaiext:priority = number($vLowest)">
                                        <image_url>
                                            <xsl:value-of select="@url"/>
                                        </image_url>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text disable-output-escaping="yes">&lt;additionalImageUrl</xsl:text>
                                        <xsl:value-of select="position()-1"/>
                                        <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                        <xsl:value-of select="@url"/>
                                        <xsl:text disable-output-escaping="yes">&lt;/additionalImageUrl</xsl:text>
                                        <xsl:value-of select="position()-1"/>
                                        <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:for-each>
                            <xsl:variable name="numberOpinions" select="count(../../iaiext:opinions/iaiext:opinion)"/>
                            <rating>
                                <xsl:if test="$numberOpinions &gt; 0">
                                    <xsl:value-of select="format-number(sum(../../iaiext:opinions/iaiext:opinion/note) div $numberOpinions, '#.##')"/>
                                </xsl:if>
                            </rating>
                            <ratingCount>
                                <xsl:if test="$numberOpinions &gt; 0">
                                    <xsl:value-of select="$numberOpinions"/>
                                </xsl:if>
                            </ratingCount>
                            <xsl:if test="../../iaiext:omnibus_price_retail/iaiext:site/@gross > 0">
                                <historicallyLowestPrice>
                                    <xsl:value-of select="../../iaiext:omnibus_price_retail/iaiext:site/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="../../@currency"/>
                                </historicallyLowestPrice>
                            </xsl:if>
                            <!-- parameters -->
                            <atttributes>
                                <xsl:for-each select="../../parameters/parameter[@hide = 'n' and position() &lt; 20]">
                                    <xsl:for-each select="value">
                                        <atttribute>
                                            <type>
                                                <xsl:value-of select="../@name"/>
                                            </type>
                                            <value>
                                                <xsl:value-of select="@name"/>
                                            </value>
                                        </atttribute>
                                    </xsl:for-each>
                                </xsl:for-each>
                                <xsl:for-each select="../../parameters/parameter[@id = '87890' or @id = '30936']">
                                    <xsl:if test="value/@id = '38044'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>OFERTA SPECJALNA</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                    <xsl:if test="value/@id = '87881'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>WYBÓR KOSMETOLOGA</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                    <xsl:if test="value/@id = '36977'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>W ZESTAWIE TANIEJ</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                    <xsl:if test="value/@id = '87891'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>HIT TikToka</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                    <xsl:if test="value/@id = '87896'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>OSTATNIA SZANSA!</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                    <xsl:if test="value/@id = '87893'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>TYLKO U NAS!</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                </xsl:for-each>
                                <xsl:for-each select="../../iaiext:hotspots/iaiext:site/flag">
                                    <xsl:if test="@type='bestseller' and @visible='yes'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>BESTSELLER</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                    <xsl:if test="@type='promotion' and @visible='yes'">
                                        <atttribute>
                                            <type>
                                                <xsl:text>badge</xsl:text>
                                            </type>
                                            <value>
                                                <xsl:text>PROMOCJA</xsl:text>
                                            </value>
                                        </atttribute>
                                    </xsl:if>
                                </xsl:for-each>
                                <xsl:if test="$mainPrice &gt; $Kwota_za_darmo_wysylka">
                                    <atttribute>
                                        <type>
                                            <xsl:text>badge</xsl:text>
                                        </type>
                                        <value>
                                            <xsl:text>Dostawa za 0 zł</xsl:text>
                                        </value>
                                    </atttribute>
                                </xsl:if>
                            </atttributes>
                        </item>
                    </xsl:for-each>
                </xsl:for-each>
            </channel>
        </rss>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
</xsl:stylesheet>