<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- długoś opisu -->
    <xsl:variable name='dlugosc_opisu'>2400</xsl:variable>
    <xsl:variable name='dlugosc_opisu_z_parametrow'>1200</xsl:variable>
    <!-- wymagany limit długości opisu po którego przekroczeniu nie zostanie dodany opis z parametrów  -->
    <xsl:variable name='minimalna_dlugosc_opisu_dla_parametrow'>360</xsl:variable>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'ŁÓŻKO/STÓŁ/KRZESŁO/FOTEL/ŁAWA/REGAŁ'"/>
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='Kwota_za_darmo_wysylka'>5.00</xsl:variable>
    <xsl:variable name='Kwota_za_darmo_wysylka_large'>5.00</xsl:variable>
    <xsl:variable name="Kwota_wysylki">0.00</xsl:variable>
    <xsl:variable name="Kwota_wysylki_large">0.00</xsl:variable>

    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <channel>
                <title>elektromarket24.pl</title>
                <link>https://elektromarket24.pl/</link>
                <description>Produkty ze sklepu https://elektromarket24.pl/</description>
                <xsl:for-each select="/offer/products/product">
                    <xsl:for-each select="sizes/size">
                        <item>

                            <!--Unikalny identyfikator produktu  -->
                            <g:id>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="@code"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:id>
                            <!-- Opis -->
                            <!-- short descr -->
                            <xsl:variable name="from_parameters_raw">
                                <xsl:for-each select="../../parameters/parameter[@hide = 'n' and value/@name != '']">
                                    <xsl:text>&#xa;</xsl:text>
                                    <xsl:value-of select="@name"/>
                                    <xsl:text>: </xsl:text>
                                    <xsl:for-each select="value">
                                        <xsl:value-of select="@name"/>
                                        <xsl:text>; </xsl:text>
                                    </xsl:for-each>
                                </xsl:for-each>
                            </xsl:variable>
                            <xsl:variable name="from_parameters">
                                <xsl:choose>
                                    <xsl:when test="$from_parameters_raw != ''">
                                        <xsl:call-template name="tokenize">
                                            <xsl:with-param name="text" select="substring($from_parameters_raw, 1, $dlugosc_opisu_z_parametrow)"/>
                                            <xsl:with-param name="delimiter" select="';'"/>
                                        </xsl:call-template>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text></xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:variable>
                            <g:description>
                                <xsl:choose>
                                    <xsl:when test="../../description/short_desc = '' and ../../description/long_desc = ''">
                                        <!-- nie jest git bo nie ma opisów  -->
                                        <xsl:if test="$from_parameters != ''">
                                            <xsl:value-of select="../../description/name"/>
                                            <xsl:value-of select="$from_parameters"/>
                                        </xsl:if>
                                    </xsl:when>
                                    <xsl:when test="../../description/short_desc = '' and string-length(normalize-space(../../description/long_desc)) > 0">
                                        <xsl:variable name = "opis_bez_tagow">
                                            <xsl:call-template name="strip-tags">
                                                <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="opis_do_kropki">
                                            <xsl:call-template name="tokenize">
                                                <xsl:with-param name="text" select="substring(normalize-space($opis_bez_tagow),1,$dlugosc_opisu)"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:choose>
                                            <xsl:when test="$opis_do_kropki = ''">
                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$opis_bez_tagow"/>
                                                <xsl:if test="string-length(normalize-space($opis_bez_tagow)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$opis_do_kropki"/>
                                                <xsl:if test="string-length(normalize-space($opis_do_kropki)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                        <!-- załóżmy -->
                                        <xsl:choose>
                                            <xsl:when test="string-length(../../description/short_desc) > 240 or ../../description/long_desc = ''">
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="../../description/short_desc"/>
                                                <xsl:if test="string-length(../../description/short_desc) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:variable name = "opis_bez_tagow">
                                                    <xsl:call-template name="strip-tags">
                                                        <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:variable name="opis_do_kropki">
                                                    <xsl:call-template name="tokenize">
                                                        <xsl:with-param name="text" select="substring(normalize-space($opis_bez_tagow),1,$dlugosc_opisu)"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:choose>
                                                    <xsl:when test="$opis_do_kropki = ''">
                                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="$opis_bez_tagow"/>
                                                        <xsl:if test="string-length(normalize-space($opis_bez_tagow)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="$opis_do_kropki"/>
                                                        <xsl:if test="string-length(normalize-space($opis_do_kropki)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </g:description>
                            <!-- waga sizes/size/@weight-->
                            <xsl:variable name="weight_final_form">
                                <xsl:choose>
                                    <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != '' and contains(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ' ')">
                                        <xsl:choose>
                                            <xsl:when test="substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ' ') &gt;= 1000">
                                                <xsl:value-of select="format-number(substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ' ') div 1000, '#.##')"/>
                                            </xsl:when>
                                            <xsl:when test="substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ' ') &lt; 1000">
                                                <xsl:value-of select="substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ' ')"/>
                                            </xsl:when>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != '' and not(contains(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ' '))">
                                        <xsl:choose>
                                            <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name &gt;= 1000">
                                                <xsl:value-of select="format-number(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name div 1000, '#.##')"/>
                                            </xsl:when>
                                            <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name &lt; 1000">
                                                <xsl:value-of select="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name"/>
                                            </xsl:when>
                                        </xsl:choose>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:variable>
                            <xsl:variable name="volume_final_form">
                                <xsl:choose>
                                    <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != '' and contains(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ' ')">
                                        <xsl:choose>
                                            <xsl:when test="substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ' ') &gt;= 1000">
                                                <xsl:value-of select="format-number(substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ' ') div 1000, '#.##')"/>
                                            </xsl:when>
                                            <xsl:when test="substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ' ') &lt; 1000">
                                                <xsl:value-of select="substring-before(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ' ')"/>
                                            </xsl:when>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != '' and not(contains(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ' '))">
                                        <xsl:choose>
                                            <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name &gt;= 1000">
                                                <xsl:value-of select="format-number(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name div 1000, '#.##')"/>
                                            </xsl:when>
                                            <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name &lt; 1000">
                                                <xsl:value-of select="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name"/>
                                            </xsl:when>
                                        </xsl:choose>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:variable>
                            <g:shipping_weight>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="format-number(@weight div 1000, '#.##')"/>
                                <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                            </g:shipping_weight>
                            <xsl:choose>
                                <xsl:when test="$weight_final_form != ''">
                                    <xsl:choose>
                                        <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != '' and $weight_final_form &gt;= 1000">
                                            <g:unit_pricing_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$weight_final_form"/>
                                                <xsl:text disable-output-escaping="yes"> kg]]&gt;</xsl:text>
                                            </g:unit_pricing_measure>
                                            <g:unit_pricing_base_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 kg]]&gt;</xsl:text>
                                            </g:unit_pricing_base_measure>
                                        </xsl:when>
                                        <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != '' and $weight_final_form &lt; 1000">
                                            <g:unit_pricing_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$weight_final_form"/>
                                                <xsl:text disable-output-escaping="yes"> g]]&gt;</xsl:text>
                                            </g:unit_pricing_measure>
                                            <g:unit_pricing_base_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[100 g]]&gt;</xsl:text>
                                            </g:unit_pricing_base_measure>
                                        </xsl:when>
                                        <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != '' and $volume_final_form &gt;= 1000">
                                            <g:unit_pricing_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$volume_final_form"/>
                                                <xsl:text disable-output-escaping="yes"> l]]&gt;</xsl:text>
                                            </g:unit_pricing_measure>
                                            <g:unit_pricing_base_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[1 l]]&gt;</xsl:text>
                                            </g:unit_pricing_base_measure>
                                        </xsl:when>
                                        <xsl:when test="../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != '' and $volume_final_form &lt; 1000">
                                            <g:unit_pricing_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$volume_final_form"/>
                                                <xsl:text disable-output-escaping="yes"> ml]]&gt;</xsl:text>
                                            </g:unit_pricing_measure>
                                            <g:unit_pricing_base_measure>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[100 ml]]&gt;</xsl:text>
                                            </g:unit_pricing_base_measure>
                                        </xsl:when>
                                    </xsl:choose>
                                </xsl:when>
                            </xsl:choose>
                            
                            <g:custom_label_0>
                            <xsl:choose>
                                <xsl:when test="price/@gross &lt;= 5"><xsl:text disable-output-escaping="yes">0-5 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 5 and price/@gross &lt;= 10"><xsl:text disable-output-escaping="yes">5-10 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 10 and price/@gross &lt;= 30"><xsl:text disable-output-escaping="yes">10-30 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 30 and price/@gross &lt;= 50"><xsl:text disable-output-escaping="yes">30-50 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 50 and price/@gross &lt;= 200"><xsl:text disable-output-escaping="yes">50-200 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 200 and price/@gross &lt;= 500"><xsl:text disable-output-escaping="yes">200-500 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 500 and price/@gross &lt;= 1000"><xsl:text disable-output-escaping="yes">500-1000 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 1000 and price/@gross &lt;= 2000"><xsl:text disable-output-escaping="yes">1000-2000 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 2000 and price/@gross &lt;= 5000"><xsl:text disable-output-escaping="yes">2000-5000 </xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                                <xsl:when test="price/@gross &gt; 5000"><xsl:text disable-output-escaping="yes">5000-</xsl:text><xsl:value-of select="../../@currency"/></xsl:when>
                            </xsl:choose>
                            </g:custom_label_0>
                        </item>
                    </xsl:for-each>
                </xsl:for-each>
            </channel>
        </rss>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:value-of select="substring-before($text, $delimiter)"/>
                <xsl:value-of select="$delimiter"/>
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                    <xsl:with-param name="delimiter" select="$delimiter"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="throwLastNode">
        <xsl:param name="text"/>
        <xsl:choose>
            <xsl:when test="not(contains($text, '/'))">
                <xsl:value-of select="$text"/>
            </xsl:when>
            <xsl:otherwise>
                <xsl:call-template name="throwLastNode">
                    <xsl:with-param name="text" select="substring-after($text, '/')" tunnel="yes"/>
                </xsl:call-template>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
</xsl:stylesheet>