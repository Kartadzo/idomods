<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />
    
    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'LOWE ALPINE/REEBOK/GABEL ESCAPE CARBON TOUR/SPORTIVA/GOGLE NARCIARSKIE/BLACK-GREY/SANDAŁY/OKULARY PRZECIWSŁONECZNE/ADIDAS/STRIKER/SANDBLAST/RELMENT/DAGGETT/ALYSSA/HYPER BURST MANCHESTER/DEODORANT RUNNER/MOTIVE SILVER/MIZUNO WAVE DAICHI/CAVIAR/RĘKAWICE REUSCH/DRAGON/SHOES/SNEAKERSY/RELAX MID/HICKORY/MEGA SURGE/GO WALK MAX CLINCHED/MOOD INDIGO/LYNX ZERO/OPAL/BASALT/JACKET/SALEWA/CROCS/DAMSKIE PÓŁBUTY/EXPEDITION/STAND ON AIR/WILD/ADAMANT ORANGE/MUSHROOM/UNIZIPPED DUSKY GREEN/CROSSCOURT/MANUAL PLATFORM/METRIC/YOUTH PALE PINK/COMPASS POCKET/KOMPAS/GARMINIUM BLUE/ORGANIC METRO/CLASSIC META/NEON PURPLE/MULTI/CRISIS/SKATE/TRAPERY/BAGGY SUPPLY DESERT/UNISEX/CONSTRUCT/PLATFORM/RAIN BOOT KIDS/CORTEX/WHITESPREAD THE LOVE/SHORTY GRAY FOG/SPECIFIC SHORT ZIP NAVY/YOUTH BLACK/PAMPA LITE/CROSSCOURT/HEGGERTY TRACK PANT/PALLADIUM PALLATROOPER/LA Sportiva/TONIK/SANDAL KIDS/MODERN/GRADIENT WO CLASSIC JER THEOR MULTI PINK/BUTY MĘSKIE/LIGHTS THERMO FLASH HEAT FLUX'"/>
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='kwota_dla_darmowej_dostawy'>100.00</xsl:variable>
    <xsl:variable name='kwota_dla_wiekszych_zamowien'>100.00</xsl:variable>
    <xsl:variable name="Koszt_dostawy">6.99</xsl:variable>
    <xsl:variable name="Koszt_dostawy_wiekszych_zamowien">6.99</xsl:variable>
    <xsl:variable name="Kraj_dostawy" select="'PL'"/>
    <xsl:variable name="Czas_obsługi_zamówienia_na_magazynie" select="'1'"/>
    <xsl:variable name="Czas_dostawy_zamówienia" select="'1'"/>

    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0">
            <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <channel>
                <title>butomaniak.pl</title>
                <link>https://butomaniak.pl/</link>
                <description>Produkty ze sklepu https://butomaniak.pl/</description>
                <xsl:for-each select="/offer/products/product">
                    <xsl:for-each select="sizes/size">
                        <item>
                            <!--Unikalny identyfikator produktu  -->
                            <g:id>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="@code"></xsl:value-of>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:id>
                            <!-- Tytuł -->
                            <g:title>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:call-template name="wordFormat">
                                    <xsl:with-param name="text" select="../../description/name/." tunnel="yes"/>
                                </xsl:call-template>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:title>
                            <!-- Opis -->
                            <!-- short descr -->
                            <xsl:variable name="from_parameters">
                                <xsl:for-each select="../../parameters/parameter">
                                    <xsl:text>&#xa;</xsl:text>
                                    <xsl:value-of select="@name"/>
                                    <xsl:text>: </xsl:text>
                                    <xsl:value-of select="value/@name"/>
                                </xsl:for-each>
                            </xsl:variable>
                            <g:description>
                                <xsl:choose>
                                    <xsl:when test="../../description/short_desc = '' and ../../description/long_desc = ''">
                                        <!-- nie jest git bo nie ma opisów  -->
                                        <xsl:if test="$from_parameters != ''">
                                            <xsl:value-of select="../../description/name"/>
                                            <xsl:value-of select="$from_parameters"/>
                                        </xsl:if>
                                    </xsl:when>
                                    <xsl:when test="../../description/short_desc = ''">
                                        <xsl:variable name = "returned_value_without_html">
                                            <xsl:call-template name="strip-tags">
                                                <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="returned_value_500_char" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                        <xsl:variable name="value_cut">
                                            <xsl:call-template name="tokenize">
                                                <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="last_char" select="substring($returned_value_500_char, string-length($returned_value_500_char), 1)"/>
                                        <xsl:choose>
                                            <xsl:when test="$last_char != '.'">
                                                <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                <xsl:choose>
                                                    <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut)) = ''">
                                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="$returned_value_500_char"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- jest przed kropka text -->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- Mamy kropke na koncu i jest git -->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$returned_value_500_char"/>
                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="../../description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                        <!-- załóżmy -->
                                        <xsl:choose>
                                            <xsl:when test="string-length(../../description/short_desc) > 300">
                                                <!-- jest git bo ma wiecej niz  -->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="../../description/short_desc"/>
                                                <xsl:text>&#xa;</xsl:text>
                                                <xsl:value-of select="../../description/name"/>
                                                <xsl:value-of select="$from_parameters"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:variable name = "returned_value_without_html">
                                                    <xsl:call-template name="strip-tags">
                                                        <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:variable name="returned_value_500_char" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                                <xsl:variable name="value_cut">
                                                    <xsl:call-template name="tokenize">
                                                        <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,500)"/>
                                                    </xsl:call-template>
                                                </xsl:variable>
                                                <xsl:variable name="last_char" select="substring($returned_value_500_char, string-length($returned_value_500_char), 1)"/>
                                                <xsl:choose>
                                                    <xsl:when test="$last_char != '.'">
                                                        <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                        <xsl:choose>
                                                            <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut)) = ''">
                                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                                <xsl:value-of select="$returned_value_500_char"/>
                                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                    <xsl:text>&#xa;</xsl:text>
                                                                    <xsl:value-of select="../../description/name"/>
                                                                    <xsl:value-of select="$from_parameters"/>
                                                                </xsl:if>
                                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                            </xsl:when>
                                                            <xsl:otherwise>
                                                                <!-- jest przed kropka text -->
                                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                                <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))"/>
                                                                <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                                    <xsl:text>&#xa;</xsl:text>
                                                                    <xsl:value-of select="../../description/name"/>
                                                                    <xsl:value-of select="$from_parameters"/>
                                                                </xsl:if>
                                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                            </xsl:otherwise>
                                                        </xsl:choose>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- Mamy kropke na koncu i jest git -->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="$returned_value_500_char"/>
                                                        <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_500_char), $value_cut))) &lt; 400 and $from_parameters != ''">
                                                            <xsl:text>&#xa;</xsl:text>
                                                            <xsl:value-of select="../../description/name"/>
                                                            <xsl:value-of select="$from_parameters"/>
                                                        </xsl:if>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </g:description>
                            <xsl:variable name="mainPrice">
                                <xsl:choose>
                                    <xsl:when test="../../strikethrough_retail_price and  ../../strikethrough_retail_price/@gross > 0 and
                                      ../../strikethrough_retail_price/@gross > price/@gross and 
                                      price/@gross = ../../price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                                                <xsl:value-of select="../../strikethrough_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="price/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and sizes/size/price/@gross = price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:when test="price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="price/@gross != ../../price/@gross and
                                            ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                                            </xsl:when>
                                            <xsl:when test="price/@gross = ../../price/@gross and
                                            ../../promotion/price/normal_retail_price/@gross > price/@gross">
                                                <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="price/@gross"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:variable>
                            <g:price>
                                <xsl:value-of select="$mainPrice"></xsl:value-of>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="../../@currency"/>
                            </g:price>
                            <!-- produkcja -->
                            <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
                            <xsl:if test="../../promotion/price/normal_retail_price or ../../strikethrough_retail_price">
                                <xsl:choose>
                                    <xsl:when test = "
                                      (../../strikethrough_retail_price and ../../strikethrough_retail_price/@gross > price/@gross) or
                                      (../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross) or
                                      (../../promotion/price/normal_retail_price and ../../price/@gross != price/@gross and 
                                      ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross)">
                                        <g:sale_price>
                                            <xsl:value-of select="price/@gross"/>
                                            <xsl:text><![CDATA[ ]]></xsl:text>
                                            <xsl:value-of select="../../@currency"/>
                                        </g:sale_price>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:if>
                            <g:shipping>
                                <g:price>
                                    <xsl:choose>
                                        <xsl:when test="$mainPrice >= $kwota_dla_darmowej_dostawy">
                                            <xsl:text><![CDATA[0]]></xsl:text>
                                        </xsl:when>
                                        <xsl:when test="$mainPrice >= $kwota_dla_wiekszych_zamowien">
                                            <xsl:value-of select="$Koszt_dostawy_wiekszych_zamowien"/>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:value-of select="$Koszt_dostawy"/>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="../../@currency"/>
                                </g:price>
                                <g:country>
                                    <xsl:value-of select="$Kraj_dostawy"/>
                                </g:country>
                                <g:min_handling_time>
                                    <xsl:value-of select="$Czas_obsługi_zamówienia_na_magazynie"/>
                                </g:min_handling_time>
                                <g:max_handling_time>
                                    <xsl:value-of select="$Czas_obsługi_zamówienia_na_magazynie + floor($Czas_obsługi_zamówienia_na_magazynie div 3)"/>
                                </g:max_handling_time>
                                <g:min_transit_time>
                                    <xsl:value-of select="$Czas_dostawy_zamówienia"/>
                                </g:min_transit_time>
                                <g:max_transit_time>
                                    <xsl:value-of select="$Czas_dostawy_zamówienia + floor($Czas_dostawy_zamówienia div 3)"/>
                                </g:max_transit_time>
                            </g:shipping>
                            <!-- Dostępność -->
                            <g:availability>
                                <xsl:choose>
                                    <xsl:when test="@available = 'on_order'">
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:when test="@available = 'in_stock'">
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[in stock]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[out of stock]]&gt;</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </g:availability>
                            
                            <g:custom_label_0>
                                <xsl:choose>
                                    <xsl:when test="price/@gross &lt;= 50"><xsl:text disable-output-escaping="yes">0-50 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 50 and price/@gross &lt;= 100"><xsl:text disable-output-escaping="yes">50-100 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 100 and price/@gross &lt;= 200"><xsl:text disable-output-escaping="yes">100-200 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 200 and price/@gross &lt;= 300"><xsl:text disable-output-escaping="yes">200-300 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 300 and price/@gross &lt;= 400"><xsl:text disable-output-escaping="yes">300-400 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 400 and price/@gross &lt;= 500"><xsl:text disable-output-escaping="yes">400-500 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 500 and price/@gross &lt;= 600"><xsl:text disable-output-escaping="yes">500-600 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 600 and price/@gross &lt;= 700"><xsl:text disable-output-escaping="yes">600-700 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 700 and price/@gross &lt;= 800"><xsl:text disable-output-escaping="yes">700-800 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 800 and price/@gross &lt;= 900"><xsl:text disable-output-escaping="yes">800-900 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 900 and price/@gross &lt;= 1000"><xsl:text disable-output-escaping="yes">900-1000 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1000 and price/@gross &lt;= 1100"><xsl:text disable-output-escaping="yes">1000-1100 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1100 and price/@gross &lt;= 1200"><xsl:text disable-output-escaping="yes">1100-1200 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1200 and price/@gross &lt;= 1300"><xsl:text disable-output-escaping="yes">1200-1300 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1300 and price/@gross &lt;= 1400"><xsl:text disable-output-escaping="yes">1300-1400 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1400 and price/@gross &lt;= 1500"><xsl:text disable-output-escaping="yes">1400-1500 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1500 and price/@gross &lt;= 1600"><xsl:text disable-output-escaping="yes">1500-1600 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1600 and price/@gross &lt;= 1700"><xsl:text disable-output-escaping="yes">1600-1700 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1700 and price/@gross &lt;= 1800"><xsl:text disable-output-escaping="yes">1700-1800 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1800 and price/@gross &lt;= 1900"><xsl:text disable-output-escaping="yes">1800-1900 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 1900 and price/@gross &lt;= 2000"><xsl:text disable-output-escaping="yes">1900-2000 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2000 and price/@gross &lt;= 2100"><xsl:text disable-output-escaping="yes">2000-2100 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2100 and price/@gross &lt;= 2200"><xsl:text disable-output-escaping="yes">2100-2200 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2200 and price/@gross &lt;= 2300"><xsl:text disable-output-escaping="yes">2200-2300 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2300 and price/@gross &lt;= 2400"><xsl:text disable-output-escaping="yes">2300-2400 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2400 and price/@gross &lt;= 2500"><xsl:text disable-output-escaping="yes">2400-2500 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2500 and price/@gross &lt;= 2600"><xsl:text disable-output-escaping="yes">2500-2600 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2600 and price/@gross &lt;= 2700"><xsl:text disable-output-escaping="yes">2600-2700 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
                                    <xsl:when test="price/@gross &gt; 2700 and price/@gross &lt;= 2800"><xsl:text disable-output-escaping="yes">2700-2800 </xsl:text><xsl:value-of select="../../@currency"></xsl:value-of></xsl:when>
