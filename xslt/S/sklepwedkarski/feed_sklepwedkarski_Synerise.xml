<xsl:stylesheet version="1.0" xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml" xmlns:php="http://php.net/xsl">
<xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />
<xsl:template match="/">
<rss xmlns:g="http://base.google.com/ns/1.0" xmlns:c="http://base.google.com/cns/1.0" version="2.0">
    <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
    <channel>
        <title>sklepwedkarski.pl</title>
        <link>https://sklepwedkarski.pl/</link>
	    <description>Produkty ze sklepu https://sklepwedkarski.pl/</description>
        <xsl:for-each select="/offer/products/product[iaiext:navigation/iaiext:site/iaiext:menu[5]/iaiext:item[1]/@id != '']">
            <item>  
                <!-- kwoty stawek wysyłek do ustalenia -->
                <xsl:variable name='Kwota_za_darmo_wysylka'>350</xsl:variable>
                <xsl:variable name="Kwota_wysylki">14.5</xsl:variable>
                <xsl:variable name="Kwota_wysylki_large">14.5</xsl:variable>
                <xsl:variable name='Kwota_za_darmo_wysylka_large'>29.94</xsl:variable>
                <!--Unikalny identyfikator produktu  -->
                <g:id> 
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>    
                    <xsl:value-of select="@id"></xsl:value-of>   
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </g:id> 
                <!-- Tytuł -->
                <title>  
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> 
                    <xsl:value-of select="description/name/."/>  
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </title>
                <!-- Opis -->
                <!-- short descr -->
                <xsl:choose>
                    <xsl:when test="description/short_desc = ''">
                        <xsl:variable name = "returned_value_without_html">
                            <xsl:call-template name="strip-tags">
                                <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                            </xsl:call-template>
                        </xsl:variable>
                        <xsl:variable name="returned_value_300_char" select="substring(normalize-space($returned_value_without_html),1,300)"></xsl:variable>
                        <xsl:variable name="value_cut">
                            <xsl:call-template name="tokenize">
                                <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,300)"/>
                            </xsl:call-template>
                        </xsl:variable>
                        <xsl:variable name="last_char" select="substring($returned_value_300_char, string-length($returned_value_300_char), 1)"></xsl:variable>         
                        <xsl:choose>
                            <xsl:when test="$last_char != '.'">
                                <!-- chodzi oto ze nie ma przed kropka nic  -->
                                <xsl:choose>
                                    <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut)) = ''">
                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                        <description><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$returned_value_300_char"></xsl:value-of><xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>  </description>  
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- jest przed kropka text -->
                                        <description><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut))"></xsl:value-of> <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> </description>  
                                    </xsl:otherwise>
                                </xsl:choose>                                                          
                            </xsl:when>
                            <xsl:otherwise>
                                <!-- Mamy kropke na koncu i jest git -->
                                <description><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$returned_value_300_char"></xsl:value-of><xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>  </description>  
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <xsl:otherwise>
                        <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                        <!-- załóżmy -->
                        <xsl:choose>
                            <xsl:when test="string-length(description/short_desc) > 30">
                                <!-- jest git bo ma wiecej niz  -->
                                <description><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="description/short_desc"></xsl:value-of>  <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> </description> 
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:variable name = "returned_value_without_html">
                                    <xsl:call-template name="strip-tags">
                                        <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:variable name="returned_value_300_char" select="substring(normalize-space($returned_value_without_html),1,300)"></xsl:variable>
                                <xsl:variable name="value_cut">
                                    <xsl:call-template name="tokenize">
                                        <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,300)"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:variable name="last_char" select="substring($returned_value_300_char, string-length($returned_value_300_char), 1)"></xsl:variable>
                                <xsl:choose>
                                    <xsl:when test="$last_char != '.'">
                                        <!-- chodzi oto ze nie ma przed kropka nic  -->
                                        <xsl:choose>
                                            <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut)) = ''">
                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                <description><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$returned_value_300_char"></xsl:value-of><xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>  </description>  
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- jest przed kropka text -->
                                                <description><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_300_char), $value_cut))"></xsl:value-of> <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> </description>  
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- Mamy kropke na koncu i jest git -->
                                        <description><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$returned_value_300_char"></xsl:value-of><xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>  </description>  
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:otherwise>
                </xsl:choose>
                <!-- g product type -->
                <xsl:variable name="extra_type">
                    <xsl:for-each select="iaiext:navigation/iaiext:site[1]/iaiext:menu[@id = 1]/iaiext:item">
                    <xsl:choose>
                        <xsl:when test="contains(@textid, 'Nowości')">
                            <xsl:text>/Nowości</xsl:text>
                        </xsl:when>
                        <xsl:when test="contains(@textid, 'Akcesoria')">
                            <xsl:text>/Akcesoria</xsl:text>
                        </xsl:when>
                    </xsl:choose>
                    </xsl:for-each>
                </xsl:variable>
                <xsl:for-each select="iaiext:navigation/iaiext:site[@id = 3]/iaiext:menu">
                    <xsl:for-each select="iaiext:item">
                        <xsl:choose>
                            <xsl:when test="position()=1 and ../@id = 1">
                                <g:product_type>
                                    <!-- <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> -->
                                    <!-- <xsl:value-of select="translate(@textid,'\','&gt;')"/>    -->
                                    <xsl:call-template name="string-replace-all">
                                        <xsl:with-param name="text" select="@textid" tunnel="yes"/>
                                        <xsl:with-param name="replace" select="'\'" tunnel="yes"/>
                                        <xsl:with-param name="by" select="' &gt; '" tunnel="yes"/>
                                    </xsl:call-template>
                                    <!-- <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> -->
                                </g:product_type>  
                                <xsl:if test="contains($extra_type, 'Nowości') or contains(../../../../description/name/., 'Nowość') or contains(../../../../description/name/., 'Nowości')">
                                    <g:additional_product_type>Nowości</g:additional_product_type>
                                </xsl:if>
                                <xsl:if test="contains($extra_type, 'Akcesoria')">
                                    <g:additional_product_type>Akcesoria</g:additional_product_type>
                                </xsl:if>
                            </xsl:when>
                            <xsl:otherwise>  
                                <g:additional_product_type>
                                    <xsl:call-template name="string-replace-all">
                                        <xsl:with-param name="text" select="@textid" tunnel="yes"/>
                                        <xsl:with-param name="replace" select="'\'" tunnel="yes"/>
                                        <xsl:with-param name="by" select="' &gt; '" tunnel="yes"/>
                                    </xsl:call-template>
                                </g:additional_product_type>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:for-each>
                </xsl:for-each>
                <!-- link do produktu -->
                <!-- WYMAGANY: Link do produktu -->
                <!-- pl zzamienic na jezyk ktory bedziemy realizować -->
                <link><xsl:value-of select="substring-before(card/@url, '.feed')"/><![CDATA[.html]]></link>


                <xsl:variable name="vLowest">
                    <xsl:for-each select="images/large/image/@iaiext:priority">
                        <xsl:sort data-type="number"/>
                        <xsl:if test="position()=1"><xsl:value-of select="."/></xsl:if>
                    </xsl:for-each>
                </xsl:variable>
                <xsl:for-each select="images/large/image">
                    <xsl:choose>
                        <xsl:when test="@iaiext:priority = number($vLowest)">
                            <g:image_link>  <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="@url"></xsl:value-of>   <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:image_link>
                        </xsl:when>
                        <xsl:otherwise>
                            <g:additional_image_link>  <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="@url"></xsl:value-of>   <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:additional_image_link>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:for-each> 
                <!-- stan -->
                <g:condition>   
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>new<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </g:condition>  
                <!-- Dostępność -->
                <g:availability>
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                    <xsl:choose>
                        <xsl:when test="sizes/size/@available= 'on_order'">
                            <![CDATA[in stock]]>
                        </xsl:when>
                        <xsl:when test="sizes/size/@available= 'in_stock'">
                            <![CDATA[in stock]]>
                        </xsl:when>
                        <xsl:otherwise>
                            <![CDATA[out of stock]]>
                        </xsl:otherwise>
                    </xsl:choose>
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </g:availability>
                <xsl:choose>
                <!-- kiedy hurtowa cena detaliczna -->
					<xsl:when test="strikethrough_retail_price and 
                    strikethrough_retail_price/@gross > sizes/size/price/@gross and 
                    sizes/size/price/@gross = price/@gross">
                        <xsl:choose>
                            <!-- kiedy cena promocyjna jest wieksza niz cena dla serwisu zewnetrznego -->
                            <xsl:when test="strikethrough_retail_price/@gross > sizes/size/price/@gross">
                                <g:price>
                                    <xsl:value-of select="strikethrough_retail_price/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="@currency"/>
                                </g:price>
                            </xsl:when>
                            <!-- inaczej bierze cena główną -->
                            <xsl:otherwise>
                                <g:price>
                                    <xsl:value-of select="sizes/size/price/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="@currency"/>
                                </g:price>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <xsl:when test="iaiext:pricecomparator_price/iaiext:site and sizes/size/price/@gross = price/@gross">
                        <xsl:choose>
                            <!-- kiedy cena promocyjna jest wieksza niz cena dla serwisu zewnetrznego -->
                            <xsl:when test="promotion/price/normal_retail_price/@gross > iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                <g:price>
                                    <xsl:value-of select="promotion/price/normal_retail_price/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="@currency"/>  
                                </g:price>
                            </xsl:when>
                            <!-- inaczej bierze cena dla serwisu zewnetrznego -->
                            <xsl:otherwise>
                                <g:price>
                                    <xsl:value-of select="iaiext:pricecomparator_price/iaiext:site[1]/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="@currency"/>  
                                </g:price>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <!-- kiedy nie wystepuje hurtowa cena detaliczna -->
                    <xsl:when test="sizes/size/price/@gross">
                        <xsl:choose>
                            <!-- kiedy promocyjna bedzie wieksza  -->
                            <xsl:when test="sizes/size/price/@gross != price/@gross and
                            promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > sizes/size/price/@gross">
                                <g:price>
                                    <xsl:value-of select="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="@currency"/>  
                                </g:price>
                            </xsl:when>
                            <xsl:when test="sizes/size/price/@gross = price/@gross and
                            promotion/price/normal_retail_price/@gross > sizes/size/price/@gross">
                                <g:price>
                                    <xsl:value-of select="promotion/price/normal_retail_price/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="@currency"/>  
                                </g:price>
                            </xsl:when>
                            <xsl:otherwise>
                                <!-- bierzemy normalna price/gorss -->
                                <g:price>
                                    <xsl:value-of select="sizes/size/price/@gross"></xsl:value-of>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="@currency"/>  
                                </g:price>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                </xsl:choose>
                <xsl:variable name="mainPrice">
                    <xsl:choose>
					<xsl:when test="strikethrough_retail_price and 
                    strikethrough_retail_price/@gross > sizes/size/price/@gross and 
                    sizes/size/price/@gross = price/@gross">
                        <xsl:choose>
                            <xsl:when test="strikethrough_retail_price/@gross > sizes/size/price/@gross">
                                    <xsl:value-of select="strikethrough_retail_price/@gross"></xsl:value-of>
                            </xsl:when>
                            <xsl:otherwise>
                                    <xsl:value-of select="sizes/size/price/@gross"></xsl:value-of>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <xsl:when test="iaiext:pricecomparator_price/iaiext:site and sizes/size/price/@gross = price/@gross">
                        <xsl:choose>
                            <xsl:when test="promotion/price/normal_retail_price/@gross > iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                    <xsl:value-of select="promotion/price/normal_retail_price/@gross"></xsl:value-of>
                            </xsl:when>
                            <xsl:otherwise>
                                    <xsl:value-of select="iaiext:pricecomparator_price/iaiext:site[1]/@gross"></xsl:value-of>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <xsl:when test="sizes/size/price/@gross">
                        <xsl:choose>
                            <xsl:when test="sizes/size/price/@gross != price/@gross and
                            promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > sizes/size/price/@gross">
                                <xsl:value-of select="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"></xsl:value-of>
                            </xsl:when>
                            <xsl:when test="sizes/size/price/@gross = price/@gross and
                            promotion/price/normal_retail_price/@gross > sizes/size/price/@gross">
                                <xsl:value-of select="promotion/price/normal_retail_price/@gross"></xsl:value-of>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:value-of select="sizes/size/price/@gross"></xsl:value-of>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                </xsl:choose>
                </xsl:variable>
                <xsl:choose>
                   <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka">
                        <g:shipping>
                            <g:price>
                                <xsl:text>0<![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="@currency"/>  
                            </g:price>
                            <g:country>PL</g:country>
                        </g:shipping>
                    </xsl:when>
                    <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka_large">
                        <g:shipping>
                            <g:price>
                                <xsl:value-of select="$Kwota_wysylki"></xsl:value-of>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="@currency"/>  
                            </g:price>
                            <g:country>PL</g:country>
                        </g:shipping>
                    </xsl:when>
                    <xsl:otherwise>
                        <g:shipping>
                            <g:price>
                                <xsl:value-of select="$Kwota_wysylki_large"></xsl:value-of>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="@currency"/>  
                            </g:price>
                            <g:country>PL</g:country>
                        </g:shipping>
                    </xsl:otherwise>
                </xsl:choose>
                <xsl:if test="iaiext:hotspots/iaiext:site/flag/@type='bestseller' and iaiext:hotspots/iaiext:site/flag/@visible='yes'">
                    <c:custom_tagName2>BESTSELLER</c:custom_tagName2>
                </xsl:if>
                <xsl:if test="iaiext:hotspots/iaiext:site/flag/@type='promotion' and iaiext:hotspots/iaiext:site/flag/@visible='yes'">
                    <c:custom_tagName1>PROMOCJA</c:custom_tagName1>
                </xsl:if>
                <!-- produkcja -->
                <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
                <xsl:if test="promotion/price/normal_retail_price or strikethrough_retail_price">
                    <xsl:choose>
                        <xsl:when test = "(strikethrough_retail_price and (strikethrough_retail_price/@gross > sizes/size/price/@gross)) or 
                        (price/@iaiext:promotional_gross and (price/@gross > price/@iaiext:promotional_gross)) or
                        (promotion/price/normal_retail_price and  
                        (promotion/price/normal_retail_price/@gross > sizes/size/price/@gross or 
                        (price/@gross != sizes/size/price/@gross and 
                        promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > sizes/size/price/@gross)))">
                            <g:sale_price>
                                <xsl:value-of select="sizes/size/price/@gross"></xsl:value-of>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="@currency"/>    
                            </g:sale_price>
                        </xsl:when>
                    </xsl:choose>
                </xsl:if>
                <xsl:if test="iaiext:omnibus_price_retail/iaiext:site/@gross > 0">
                    <c:lowestprice>
                        <xsl:value-of select="iaiext:omnibus_price_retail/iaiext:site/@gross"></xsl:value-of>
                        <xsl:text><![CDATA[ ]]></xsl:text>
                        <xsl:value-of select="@currency"/>    
                    </c:lowestprice>
                </xsl:if>
                <!--Versja 2.0  -->
                <xsl:choose>
                    <xsl:when test="sizes/size/@code_producer and sizes/size/@code_producer!=''">
                        <!-- mamy kod producenta -->
                        <!-- format-number(@code_on_card, '#')" -->
                        <xsl:variable name="code_producer_variable">
                            <xsl:value-of select="sizes/size/@code_producer"></xsl:value-of>
                        </xsl:variable>
                        <xsl:variable name="kod_producer" select="substring-after($code_producer_variable, substring-before($code_producer_variable, substring(translate($code_producer_variable, '0', ''), 1, 1)))">
                        </xsl:variable>
                        <xsl:choose>
                            <xsl:when test="string-length($kod_producer) = '14' or string-length($kod_producer) = '13' or string-length($kod_producer) = '12' or string-length($kod_producer) = '8'">
                                <g:gtin>   <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$kod_producer"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:gtin>
                            </xsl:when>
                            <xsl:otherwise>
                                <g:mpn><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$kod_producer"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:mpn>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:variable name="code_producer_variable2">
                            <xsl:value-of select="@code_on_card"></xsl:value-of>
                        </xsl:variable>
                        <xsl:variable name="code_on_card" select="substring-after($code_producer_variable2, substring-before($code_producer_variable2, substring(translate($code_producer_variable2, '0', ''), 1, 1)))"></xsl:variable>
                        <!-- tutaj uzyjemy code on card -->
                        <xsl:choose>
                            <xsl:when test="string-length($code_on_card) = '14' or string-length($code_on_card) = '13' or string-length($code_on_card) = '12' or string-length($code_on_card) = '8'">
                                <g:gtin>   <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$code_on_card"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:gtin>
                            </xsl:when>
                            <xsl:otherwise>
                                <g:mpn><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$code_on_card"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:mpn>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:otherwise>
                </xsl:choose>
                <!-- Marka -->
                <g:brand>   
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>   
                    <xsl:value-of select="normalize-space(producer/@name)"/>    
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </g:brand>
                <g:size>    
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>   
                    <xsl:value-of select="sizes/size/@name"/>    
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </g:size>
                <g:item_group_id> 
                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>   
                    <xsl:value-of select="@id"></xsl:value-of>    
                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                </g:item_group_id>
                <!-- waga sizes/size/@weight-->
                <xsl:variable name="value_of_weight" select="sizes/size/@weight"></xsl:variable>
                <xsl:variable name="value_of_weight_to_kg" select="$value_of_weight div 1000"></xsl:variable>
                <xsl:variable name="to_3_point_after_decimal" select="format-number($value_of_weight_to_kg , '#.00000')"></xsl:variable>
                <xsl:variable name="after_dots" select="substring-after($to_3_point_after_decimal,'.')"></xsl:variable>
                <!-- ruszyc przecinek do lewej dwa razy bo aby dwa miejsca bedziemy zostawiac -->
                <xsl:variable name="move_decimal_to_left_2_point" select="$after_dots div 1000"></xsl:variable>
                <!-- tutaj pobieram wartosc 3 miejsca po przecinku i sprawdzam czy trzeba zaokraglic druga liczbe czy nie -->
                <xsl:variable name="value_if_round" select="substring-after($move_decimal_to_left_2_point,'.')"></xsl:variable>
                <!-- wartosci po pierwszej cyfrze after decimal -->
                <xsl:variable name="current_second_and_more_decimal_value" select="substring-after(($value_of_weight_to_kg)*10,'.')"></xsl:variable>
                <xsl:choose>
                    <xsl:when test="$current_second_and_more_decimal_value != '' and $value_if_round != ''">
                        <xsl:variable name="real_second_number_after_decimal" select="substring-before(($current_second_and_more_decimal_value)div10,'.')"></xsl:variable>
                        <xsl:variable name="real_first_number_after_decimal" select="substring-after(substring-before($value_of_weight_to_kg *10,'.')div 10,'.')"></xsl:variable>
                        <xsl:choose>
                            <xsl:when test="$real_second_number_after_decimal = '0' and $real_first_number_after_decimal = ''">
                                <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.01 kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                            </xsl:when>
                            <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal != '9' and $real_first_number_after_decimal=''">
                                <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.1 kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                            </xsl:when>
                            <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal != '9' and $real_first_number_after_decimal!=''">
                                <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                            </xsl:when>
                            <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal = '9'">
                                <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="ceiling($value_of_weight_to_kg)"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:choose>
                                    <xsl:when test="$real_first_number_after_decimal = ''">
                                        <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.0<xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                        <xsl:if test="parameters/parameter[@name='Waga [g]']/value/@name > 0">
                                            <g:unit_pricing_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.0<xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_measure>
                                            <g:unit_pricing_base_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>1kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_base_measure>
                                        </xsl:if>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal"></xsl:value-of><xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                        <xsl:if test="parameters/parameter[@name='Waga [g]']/value/@name > 0">
                                            <g:unit_pricing_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal"></xsl:value-of><xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_measure>
                                            <g:unit_pricing_base_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>1kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_base_measure>
                                        </xsl:if>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:variable name="read_value_to_two_decimal_point" select="format-number($value_of_weight_to_kg , '#.00')"></xsl:variable>
                        <xsl:choose>
                            <xsl:when test="substring-before($read_value_to_two_decimal_point, '.') = ''">
                                <xsl:if test="parameters/parameter[@name='Waga [g]']/value/@name > 0">
                                    <g:unit_pricing_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>0<xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_measure>
                                    <g:unit_pricing_base_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>1kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_base_measure>
                                </xsl:if>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:if test="parameters/parameter[@name='Waga [g]']/value/@name > 0">
                                    <g:unit_pricing_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_measure>
                                    <g:unit_pricing_base_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>1kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_base_measure>
                                </xsl:if>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:otherwise>
                </xsl:choose>
            </item>
        </xsl:for-each>
    </channel>
</rss>
</xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text"/>
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;')">
                <xsl:value-of select="substring-before($text, '&lt;')"/>
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

</xsl:stylesheet>