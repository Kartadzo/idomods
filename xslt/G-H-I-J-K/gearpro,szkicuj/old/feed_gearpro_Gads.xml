<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet xmlns:xsl="http://www.w3.org/1999/XSL/Transform" xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml" xmlns:php="http://php.net/xsl" version="1.0">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes"/>

    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='kwota_dla_darmowej_dostawy'>50.00</xsl:variable>
    <xsl:variable name='kwota_dla_wiekszych_zamowien'>3.00</xsl:variable>
    <xsl:variable name="Koszt_dostawy">9.99</xsl:variable>
    <xsl:variable name="Koszt_dostawy_wiekszych_zamowien">9.99</xsl:variable>
    <xsl:variable name="Kraj_dostawy" select="'PL'"/>
    <xsl:variable name="Czas_obsługi_zamówienia_na_magazynie" select="'1'"/>

    <xsl:template match="/">
        <rss xmlns:g="http://base.google.com/ns/1.0" version="2.0"><!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
            <channel>
                <title>gearpro.pl</title>
                <link>https://gearpro.pl/</link>
                <description>Produkty ze sklepu https://gearpro.pl/</description>
                <xsl:for-each select="/offer/products/product">
                    <xsl:for-each select="sizes/size">
                        <item>
                            <g:id>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="@code"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:id>
                            <!-- Tytuł -->
                            <g:title>  
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> 
                                <xsl:value-of select="../../description/name/."/>  
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:title>
                            <!-- g product type -->
                            <xsl:for-each select="../../iaiext:navigation/iaiext:site[1]/iaiext:menu">
                                <xsl:for-each select="iaiext:item[position() &lt; 10]">
                                    <g:product_type>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <!-- <xsl:value-of select="translate(normalize-space(translate(@textid,'\','&gt;')))"/>   -->
                                        <xsl:call-template name="replace-string">
                                            <xsl:with-param name="text" select="@textid"/>
                                            <xsl:with-param name="replace" select="'\'" />
                                            <xsl:with-param name="with" select="' &gt; '"/>
                                        </xsl:call-template> 
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </g:product_type>    
                                </xsl:for-each>
                            </xsl:for-each>
                            <!-- g:google_product_category -->
                                    <g:google_product_category>
                                        <!-- <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> -->
                                        <xsl:value-of select="translate(../../category_idosell/@path,'\','&gt;')"/>   
                                        <!-- <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> -->
                                    </g:google_product_category> 
                            <!-- link do produktu -->
                            <!-- WYMAGANY: Link do produktu -->
                            <!-- pl zzamienic na jezyk ktory bedziemy realizować -->
                            <g:link><xsl:value-of select="substring-before(../../card/@url, '.feed')"/><![CDATA[.googleshoppingpl.html]]></g:link>
                            <!-- display ads link -->
                            <!-- to samo pl zamienic na jezyk ktory bedziemy obslugiwac -->
                            <g:display_ads_link><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before(../../card/@url, '.feed')"/>.googleremarketing.html    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:display_ads_link>  
                            <!-- mobile link -->
                            <g:mobile_link> <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before(../../card/@url, '.feed')"/><![CDATA[.googleshoppingpl.html]]>   <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:mobile_link>
                            <xsl:variable name="vLowest">
                                <xsl:for-each select="../../images/large/image/@iaiext:priority">
                                    <xsl:sort data-type="number"/>
                                    <xsl:if test="position()=1"><xsl:value-of select="."/></xsl:if>
                                </xsl:for-each>
                            </xsl:variable>
                            <xsl:for-each select="../../images/large/image">
                                <xsl:choose>
                                    <xsl:when test="@iaiext:priority = number($vLowest)">
                                        <g:image_link>  <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="@url"></xsl:value-of>   <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:image_link>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:for-each> 
        
                    <!-- stan -->
                    <g:condition>   <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>new<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:condition>  
                    <!-- Dostępność -->
                    <!-- <test_SUMA><xsl:value-of select="sum(sizes/size/stock/@quantity)"></xsl:value-of></test_SUMA> -->
                    <xsl:choose>
                        <xsl:when test="sum(stock/@quantity) = 0 and stock[1]/@quantity != '-1' and stock[2]/@quantity != '-1'">
                            <g:availability>  
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>out of stock<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:availability>
                        </xsl:when>
                        <xsl:otherwise>
                            <g:availability>  
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>in stock<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </g:availability>
                        </xsl:otherwise>
                    </xsl:choose>

                    <!--Versja 2.0  -->
                    <xsl:choose>
                        <xsl:when test="@code_producer and @code_producer!=''">
                            <!-- mamy kod producenta -->
                            <!-- format-number(@code_on_card, '#')" -->
                            <xsl:variable name="code_producer_variable">
                                <xsl:value-of select="@code_producer"></xsl:value-of>
                            </xsl:variable>
                            <xsl:variable name="kod_producer" select="substring-after($code_producer_variable, substring-before($code_producer_variable, substring(translate($code_producer_variable, '0', ''), 1, 1)))">
                            </xsl:variable>

                            <xsl:choose>
                                <xsl:when test="string-length($kod_producer) = '14' or string-length($kod_producer) = '13' or string-length($kod_producer) = '12' or string-length($kod_producer) = '8'">
                                    <g:gtin>   <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$kod_producer"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:gtin>
                                </xsl:when>
                                <xsl:otherwise>
                                    <g:mpn><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$kod_producer"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:mpn>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:variable name="code_producer_variable2">
                                <xsl:value-of select="../../@code_on_card"></xsl:value-of>
                            </xsl:variable>
                            <xsl:variable name="code_on_card" select="substring-after($code_producer_variable2, substring-before($code_producer_variable2, substring(translate($code_producer_variable2, '0', ''), 1, 1)))"></xsl:variable>
                            <!-- tutaj uzyjemy code on card -->

                            <xsl:choose>
                                <xsl:when test="string-length($code_on_card) = '14' or string-length($code_on_card) = '13' or string-length($code_on_card) = '12' or string-length($code_on_card) = '8'">
                                    <g:gtin>   <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$code_on_card"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:gtin>
                                </xsl:when>
                                <xsl:otherwise>
                                    <g:mpn><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$code_on_card"/>      <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:mpn>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:otherwise>
                    </xsl:choose>
                    <!-- Marka -->
                    <g:brand>   
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>   
                        <xsl:value-of select="normalize-space(../../producer/@name)"/>    
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </g:brand>

                    <g:size>    
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>   
                        <xsl:value-of select="@name"/>    
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </g:size>

                    <g:item_group_id> 
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>   
                        <xsl:value-of select="../../@id"></xsl:value-of>    
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </g:item_group_id>

                    <!-- waga sizes/size/@weight-->
                    <xsl:variable name="value_of_weight" select="@weight"></xsl:variable>
                    <xsl:variable name="value_of_weight_to_kg" select="$value_of_weight div 1000"></xsl:variable>

                    <xsl:variable name="to_3_point_after_decimal" select="format-number($value_of_weight_to_kg , '#.00000')"></xsl:variable>
                    <xsl:variable name="after_dots" select="substring-after($to_3_point_after_decimal,'.')"></xsl:variable>
                    <!-- ruszyc przecinek do lewej dwa razy bo aby dwa miejsca bedziemy zostawiac -->
                    <xsl:variable name="move_decimal_to_left_2_point" select="$after_dots div 1000"></xsl:variable>
                    <!-- tutaj pobieram wartosc 3 miejsca po przecinku i sprawdzam czy trzeba zaokraglic druga liczbe czy nie -->
                    <xsl:variable name="value_if_round" select="substring-after($move_decimal_to_left_2_point,'.')"></xsl:variable>
                    <!-- wartosci po pierwszej cyfrze after decimal -->
                    <xsl:variable name="current_second_and_more_decimal_value" select="substring-after(($value_of_weight_to_kg)*10,'.')"></xsl:variable>
                    <xsl:choose>
                        <xsl:when test="$current_second_and_more_decimal_value != '' and $value_if_round != ''">
                            <xsl:variable name="real_second_number_after_decimal" select="substring-before(($current_second_and_more_decimal_value)div10,'.')"></xsl:variable>
                            <xsl:variable name="real_first_number_after_decimal" select="substring-after(substring-before($value_of_weight_to_kg *10,'.')div 10,'.')"></xsl:variable>

                            <xsl:choose>
                                <xsl:when test="$real_second_number_after_decimal = '0' and $real_first_number_after_decimal = ''">
                                    <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.01 kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                </xsl:when>
                                <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal != '9' and $real_first_number_after_decimal=''">
                                    <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.1 kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                </xsl:when>
                                <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal != '9' and $real_first_number_after_decimal!=''">
                                    <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                </xsl:when>
                                <xsl:when test="$real_second_number_after_decimal = '9' and $real_first_number_after_decimal = '9'">
                                    <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="ceiling($value_of_weight_to_kg)"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:choose>
                                        <xsl:when test="$real_first_number_after_decimal = ''">
                                            <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.0<xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="substring-before($value_of_weight_to_kg,'.')"></xsl:value-of>.<xsl:value-of select="$real_first_number_after_decimal"></xsl:value-of><xsl:value-of select="$real_second_number_after_decimal +1"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:variable name="read_value_to_two_decimal_point" select="format-number($value_of_weight_to_kg , '#.00')"></xsl:variable>
                            <xsl:choose>
                                <xsl:when test="substring-before($read_value_to_two_decimal_point, '.') = ''">
                                    <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>0<xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                    <xsl:if test="../../parameters/parameter[@name='Gewicht']/value/@name > 0">
                                        <g:unit_pricing_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>0<xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_measure>
                                        <g:unit_pricing_base_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>1kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_base_measure>
                                    </xsl:if>
                                </xsl:when>
                                <xsl:otherwise>
                                    <g:shipping_weight><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:shipping_weight>
                                    <xsl:if test="../../parameters/parameter[@name='Gewicht']/value/@name > 0">
                                        <g:unit_pricing_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text><xsl:value-of select="$read_value_to_two_decimal_point"></xsl:value-of> kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_measure>
                                        <g:unit_pricing_base_measure><xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>1kg<xsl:text disable-output-escaping="yes">]]&gt;</xsl:text></g:unit_pricing_base_measure>
                                    </xsl:if>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:otherwise>
                    </xsl:choose>
                    <xsl:variable name="cena_serwis">
                        <xsl:choose>
                            <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                                <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site/@gross"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>0</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:variable name="mainPrice">
                        <xsl:choose>
                            <xsl:when test="../../strikethrough_retail_price and  ../../strikethrough_retail_price/@gross > 0 and
                              ../../strikethrough_retail_price/@gross > price/@gross and 
                              price/@gross = ../../price/@gross and 
                              ../../strikethrough_retail_price/@gross > $cena_serwis">
                                <xsl:choose>
                                    <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                                        <xsl:value-of select="../../strikethrough_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="price/@gross"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and ../../price/@gross = price/@gross">
                                <xsl:choose>
                                    <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:when test="price/@gross">
                                <xsl:choose>
                                    <xsl:when test="price/@gross != ../../price/@gross and
                                    ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                                    </xsl:when>
                                    <xsl:when test="price/@gross = ../../price/@gross and
                                    ../../promotion/price/normal_retail_price/@gross > price/@gross">
                                        <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="price/@gross"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:variable>
                    <g:price>
                        <xsl:value-of select="$mainPrice"/>
                        <xsl:text><![CDATA[ ]]></xsl:text>
                        <xsl:value-of select="../../@currency"/>
                    </g:price>
                    <!-- produkcja -->
                    <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
                    <xsl:if test="../../promotion/price/normal_retail_price or ../../strikethrough_retail_price">
                        <xsl:choose>
                            <xsl:when test = "
                              (../../strikethrough_retail_price and ../../strikethrough_retail_price/@gross > price/@gross) or
                              (../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross) or
                              (../../promotion/price/normal_retail_price and ../../price/@gross != price/@gross and 
                              ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross)">
                                <g:sale_price>
                                    <xsl:value-of select="price/@gross"/>
                                    <xsl:text><![CDATA[ ]]></xsl:text>
                                    <xsl:value-of select="../../@currency"/>
                                </g:sale_price>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:if>
                    <g:shipping>
                        <g:price>
                            <xsl:choose>
                                <xsl:when test="$mainPrice >= $kwota_dla_darmowej_dostawy">
                                    <xsl:text><![CDATA[0]]></xsl:text>
                                </xsl:when>
                                <xsl:when test="$mainPrice >= $kwota_dla_wiekszych_zamowien">
                                    <xsl:value-of select="$Koszt_dostawy_wiekszych_zamowien"/>
                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:value-of select="$Koszt_dostawy"/>
                                </xsl:otherwise>
                            </xsl:choose>
                            <xsl:text><![CDATA[ ]]></xsl:text>
                            <xsl:value-of select="../../@currency"/>
                        </g:price>
                        <g:country>
                            <xsl:value-of select="$Kraj_dostawy"/>
                        </g:country>
                        <xsl:if test="../../iaiext:delivery_time/@unit = 'day' and ../../iaiext:delivery_time/@value > 0">
                            <xsl:variable name="czas_dostawy" select="../../iaiext:delivery_time/iaiext:time/@days + ../../iaiext:delivery_time_from_card/iaiext:time/@days"/>
                            <g:min_handling_time>
                                <xsl:value-of select="$Czas_obsługi_zamówienia_na_magazynie"/>
                            </g:min_handling_time>
                            <g:max_handling_time>
                                <xsl:value-of select="$Czas_obsługi_zamówienia_na_magazynie + floor($Czas_obsługi_zamówienia_na_magazynie div 3)"/>
                            </g:max_handling_time>
                            <g:min_transit_time>
                                <xsl:value-of select="$czas_dostawy - floor($czas_dostawy div 3)"/>
                            </g:min_transit_time>
                            <g:max_transit_time>
                                <xsl:value-of select="$czas_dostawy + floor($czas_dostawy div 3)"/>
                            </g:max_transit_time>
                        </xsl:if>
                    </g:shipping>
                            <xsl:for-each select="../../parameters/parameter">
                                <xsl:if test="@name = &apos;Google Ads&apos;">
                                    <xsl:for-each select="value">
                                        <xsl:choose>
                                            <xsl:when test="@name = 0">
                                                <g:custom_label_0>0</g:custom_label_0>
                                            </xsl:when>
                                            <xsl:when test="@name = 1">
                                                <g:custom_label_0>1</g:custom_label_0>
                                            </xsl:when>
                                            <xsl:when test="@name = 2">
                                                <g:custom_label_0>2</g:custom_label_0>
                                            </xsl:when>
                                            <xsl:when test="@name = 3">
                                                <g:custom_label_0>3</g:custom_label_0>
                                            </xsl:when>
                                            <xsl:when test="@name = 4">
                                                <g:custom_label_0>4</g:custom_label_0>
                                            </xsl:when>
                                            <xsl:when test="@name = 5">
                                                <g:custom_label_0>5</g:custom_label_0>
                                            </xsl:when>
                                        </xsl:choose>
                                    </xsl:for-each>
                                </xsl:if>
                            </xsl:for-each><!-- description -->
                           

                            <!-- opis -->
                            <xsl:variable name="returned_value_without_html">
                                <xsl:call-template name="strip-tags">
                                    <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                </xsl:call-template>
                            </xsl:variable>
                            <xsl:variable name="returned_value_300_char" select="substring(normalize-space($returned_value_without_html),1,300)"></xsl:variable>
                            <xsl:variable name="value_cut">
                                <xsl:call-template name="tokenize">
                                    <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,300)"/>
                                </xsl:call-template>
                            </xsl:variable>
                            <xsl:variable name="last_char" select="substring($returned_value_300_char, string-length($returned_value_300_char), 1)"></xsl:variable>
                            <g:description>
                  
                            <xsl:choose>
                                <xsl:when test="../../description/short_desc =''">

                                </xsl:when>
                                <xsl:otherwise>
                                    <xsl:value-of select="../../description/short_desc"></xsl:value-of>
                                    <xsl:text> </xsl:text>
                                </xsl:otherwise>
                            </xsl:choose>
                                <xsl:value-of select="$returned_value_300_char"></xsl:value-of>
                            
                            </g:description>


                        </item><!--Custom labels  -->
                    </xsl:for-each>
                </xsl:for-each>
            </channel>
        </rss>
    </xsl:template>
    <xsl:template name="strip-tags">
        <xsl:param name="text"/>
        <xsl:choose>
            <xsl:when test="contains($text, &apos;&lt;&apos;)">
                <xsl:value-of select="substring-before($text, &apos;&lt;&apos;)"/>
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), &apos;&gt;&apos;)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="&apos;.&apos;"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
    <xsl:template name="replace-string">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="with"/>
        <xsl:choose>
          <xsl:when test="contains($text,$replace)">
            <xsl:value-of select="substring-before($text,$replace)"/>
            <xsl:value-of select="$with"/>
            <xsl:call-template name="replace-string">
              <xsl:with-param name="text"
    select="substring-after($text,$replace)"/>
              <xsl:with-param name="replace" select="$replace"/>
              <xsl:with-param name="with" select="$with"/>
            </xsl:call-template>
          </xsl:when>
          <xsl:otherwise>
            <xsl:value-of select="$text"/>
          </xsl:otherwise>
        </xsl:choose>
      </xsl:template>
</xsl:stylesheet>