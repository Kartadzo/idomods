                                </xsl:choose>
                            </g:shipping> -->
                            <g:custom_label_0>
                                <xsl:choose>
                                    <xsl:when test="../../price/@gross &lt;= 5">
                                        <xsl:text disable-output-escaping="yes">0-5 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 5 and ../../price/@gross &lt;= 10">
                                        <xsl:text disable-output-escaping="yes">5-10 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 10 and ../../price/@gross &lt;= 20">
                                        <xsl:text disable-output-escaping="yes">10-20 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 20 and ../../price/@gross &lt;= 30">
                                        <xsl:text disable-output-escaping="yes">20-30 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 30 and ../../price/@gross &lt;= 40">
                                        <xsl:text disable-output-escaping="yes">30-40 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 40 and ../../price/@gross &lt;= 50">
                                        <xsl:text disable-output-escaping="yes">40-50 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 50 and ../../price/@gross &lt;= 100">
                                        <xsl:text disable-output-escaping="yes">50-100 </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                    <xsl:when test="../../price/@gross &gt; 100">
                                        <xsl:text disable-output-escaping="yes">100- </xsl:text>
                                        <xsl:value-of select="../../@currency"></xsl:value-of>
                                    </xsl:when>
                                </xsl:choose>
                            </g:custom_label_0>
                        </item>
                    </xsl:for-each>
                </xsl:for-each>
            </channel>
        </rss>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text"/>
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;')">
                <xsl:value-of select="substring-before($text, '&lt;')"/>
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>


    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

</xsl:stylesheet>
