                                    <xsl:choose>
                                        <xsl:when test = "position() = 1">
                                            <!-- Id produktu -->
                                            <g:id>
                                                <xsl:value-of select="@code"/>
                                            </g:id>
                                            <xsl:for-each select="../..">
                                                <xsl:call-template name="product"/>
                                            </xsl:for-each>
                                            <xsl:call-template name="productSizeMatter"/>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <!-- Id rozmiaru produktu -->
                                            <g:id>
                                                <xsl:value-of select="@code"/>
                                            </g:id>
                                            <xsl:for-each select="../..">
                                                <xsl:call-template name="product"/>
                                            </xsl:for-each>
                                            <xsl:call-template name="productSizeMatter"/>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </item>
                            </xsl:for-each>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:for-each>
