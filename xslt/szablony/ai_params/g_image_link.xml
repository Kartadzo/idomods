<?xml version="1.0" encoding="UTF-8"?>
<!-- Field: g:image_link
     Purpose: main product image URL
-->
<parameter_template>
  <metadata>
    <source>google.xml / facebook.xml</source>
    <created>2026-06-24</created>
    <note>Prefer `images/main/@url` or `images/image[1]/@url` depending on template.</note>
  </metadata>

  <field>g:image_link</field>
  <candidates>
    <candidate>
      <xpath>images/main/@url | images/image[1]/@url | images/icons/auction_icon/@url</xpath>
      <priority>1</priority>
    </candidate>
  </candidates>

  <method>
    <step>Take first non-empty image URL candidate.</step>
    <step>Ensure absolute URL; if relative, prepend site base from metadata or config.</step>
  </method>

  <example>https://example.com/images/product1.jpg</example>
</parameter_template>
