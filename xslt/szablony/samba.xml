<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- długoś opisu -->
    <xsl:variable name='dlugosc_opisu'>1200</xsl:variable>
    <xsl:variable name='dlugosc_opisu_z_parametrow'>400</xsl:variable>
    <!-- wymagany limit długości opisu po którego przekroczeniu nie zostanie dodany opis z parametrów  -->
    <xsl:variable name='minimalna_dlugosc_opisu_dla_parametrow'>120</xsl:variable>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'/GRATIS/'"/>

    <xsl:template match="/">
        <PRODUCTS>
            <xsl:for-each select="/offer/products/product">
                <PRODUCT>
                    <xsl:for-each select="sizes/size">
                        <xsl:choose>
                            <xsl:when test = "position() = 1">
                                <!-- Id produktu -->
                                <PRODUCT_ID>
                                    <xsl:value-of select="../../@id"/>
                                </PRODUCT_ID>
                                <xsl:call-template name="product"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <VARIANT>
                                    <!-- Id produktu -->
                                    <PRODUCT_ID>
                                        <xsl:value-of select="@code"/>
                                    </PRODUCT_ID>
                                    <xsl:call-template name="product"/>
                                </VARIANT>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:for-each>
                </PRODUCT>
            </xsl:for-each>
        </PRODUCTS>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:value-of select="substring-before($text, $delimiter)"/>
                <xsl:value-of select="$delimiter"/>
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                    <xsl:with-param name="delimiter" select="$delimiter"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="product">
        <!-- Nazwa produkty -->
        <xsl:variable name="name_variant">
            <xsl:value-of select="../../description/name/."/>
            <xsl:if test="count(../size) &gt; 1">
                <xsl:text><![CDATA[ - ]]></xsl:text>
                <xsl:value-of select="@name"/>
            </xsl:if>
        </xsl:variable>
        <TITLE>
            <xsl:call-template name="wordFormat">
                <xsl:with-param name="text" select="$name_variant" tunnel="yes"/>
            </xsl:call-template>
        </TITLE>
        <!-- price - zwykla cena det. brutto-->

        <xsl:variable name="cena_serwis">
            <xsl:choose>
                <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site">
                    <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site/@gross"/>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text>0</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <xsl:variable name="mainPrice">
            <xsl:choose>
                <xsl:when test="../../strikethrough_retail_price and  ../../strikethrough_retail_price/@gross > 0 and
              ../../strikethrough_retail_price/@gross > price/@gross and 
              price/@gross = ../../price/@gross and 
              ../../strikethrough_retail_price/@gross > $cena_serwis">
                    <xsl:choose>
                        <xsl:when test="../../strikethrough_retail_price/@gross > price/@gross">
                            <xsl:value-of select="../../strikethrough_retail_price/@gross"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="price/@gross"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:when test="../../iaiext:pricecomparator_price/iaiext:site and ../../price/@gross = price/@gross">
                    <xsl:choose>
                        <xsl:when test="../../promotion/price/normal_retail_price/@gross > ../../iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                            <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="../../iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:when test="price/@gross">
                    <xsl:choose>
                        <xsl:when test="price/@gross != ../../price/@gross and
                    ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross">
                            <xsl:value-of select="../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                        </xsl:when>
                        <xsl:when test="price/@gross = ../../price/@gross and
                    ../../promotion/price/normal_retail_price/@gross > price/@gross">
                            <xsl:value-of select="../../promotion/price/normal_retail_price/@gross"/>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:value-of select="price/@gross"/>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
            </xsl:choose>
        </xsl:variable>
        <!-- produkcja -->
        <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
        <xsl:choose>
            <xsl:when test="../../promotion/price/normal_retail_price or ../../strikethrough_retail_price">
                <xsl:choose>
                    <xsl:when test = "
              (../../strikethrough_retail_price and ../../strikethrough_retail_price/@gross > price/@gross) or
              (../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross) or
              (../../promotion/price/normal_retail_price and ../../price/@gross != price/@gross and 
              ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross)">
                        <PRICE>
                            <xsl:value-of select="price/@gross"></xsl:value-of>
                        </PRICE>
                        <PRICE_BEFORE_DISCOUNT>
                            <xsl:value-of select="$mainPrice"/>
                        </PRICE_BEFORE_DISCOUNT>
                    </xsl:when>
                    <xsl:otherwise>
                        <PRICE>
                            <xsl:value-of select="$mainPrice"/>
                        </PRICE>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <PRICE>
                    <xsl:value-of select="$mainPrice"/>
                </PRICE>
            </xsl:otherwise>
        </xsl:choose>

        <PRICES>
            <CATEGORY>
                <NAME>
                    <xsl:text><![CDATA[PRICE_WHOLESALE]]></xsl:text>
                </NAME>
                <xsl:choose>
                    <xsl:when test="../../promotion/price/normal_wholesale_price or ../../strikethrough_retail_price">
                        <xsl:choose>
                            <xsl:when test = "
              (../../strikethrough_retail_price and ../../strikethrough_retail_price/@gross > price/@gross) or
              (../../promotion/price/normal_retail_price and ../../promotion/price/normal_retail_price/@gross > price/@gross) or
              (../../promotion/price/normal_retail_price and ../../price/@gross != price/@gross and 
              ../../promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > price/@gross)">
                                <PRICE>
                                    <xsl:value-of select="../../iaiext:price_wholesale/iaiext:site/@gross"></xsl:value-of>
                                </PRICE>
                                <PRICE_BEFORE_DISCOUNT>
                                    <xsl:value-of select="../../promotion/price/normal_wholesale_price/iaiext:site/iaiext:price_per_size/@gross"/>
                                </PRICE_BEFORE_DISCOUNT>
                            </xsl:when>
                            <xsl:otherwise>
                                <PRICE>
                                    <xsl:value-of select="../../iaiext:price_wholesale/iaiext:site/@gross"></xsl:value-of>
                                </PRICE>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:when>
                    <xsl:otherwise>
                        <PRICE>
                            <xsl:value-of select="../../iaiext:price_wholesale/iaiext:site/@gross"></xsl:value-of>
                        </PRICE>
                    </xsl:otherwise>
                </xsl:choose>
            </CATEGORY>
            <CATEGORY>
                <NAME>
                    <xsl:text><![CDATA[OMNIBUS_PRICE_RETAIL]]></xsl:text>
                </NAME>
                <PRICE>
                    <xsl:value-of select="../../iaiext:omnibus_price_retail/iaiext:site/@gross"></xsl:value-of>
                </PRICE>
            </CATEGORY>
            <CATEGORY>
                <NAME>
                    <xsl:text><![CDATA[OMNIBUS_PRICE_WHOLESALE]]></xsl:text>
                </NAME>
                <PRICE>
                    <xsl:value-of select="../../iaiext:omnibus_price_wholesale/iaiext:site/@gross"></xsl:value-of>
                </PRICE>
            </CATEGORY>
        </PRICES>
        <URL>
            <xsl:choose>
                <xsl:when test = "count(../size) &gt; 1">
                    <!-- jeśli strona nie ma osobnych linków dla rozmiarów to zakomentować -->
                    <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                    <![CDATA[?selected_size=]]>
                    <xsl:value-of select="@id"/>
                    <xsl:text>.html</xsl:text>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="substring-before(../../card/@url, '.feed')"/>
                    <xsl:text>.html</xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </URL>
        <!-- Zdjęcie -->
        <IMAGE>
            <xsl:value-of select="../../images/icons/auction_icon/@url"/>
        </IMAGE>
        <!-- Opis -->
        <!-- short descr -->
        <xsl:variable name="from_parameters_raw">
            <xsl:for-each select="../../parameters/parameter[@hide = 'n' and value/@name != '']">
                <xsl:text>&#xa;</xsl:text>
                <xsl:value-of select="@name"/>
                <xsl:text>: </xsl:text>
                <xsl:for-each select="value">
                    <xsl:value-of select="@name"/>
                    <xsl:text>; </xsl:text>
                </xsl:for-each>
            </xsl:for-each>
        </xsl:variable>
        <xsl:variable name="from_parameters">
            <xsl:choose>
                <xsl:when test="$from_parameters_raw != ''">
                    <xsl:call-template name="tokenize">
                        <xsl:with-param name="text" select="substring($from_parameters_raw, 1, $dlugosc_opisu_z_parametrow)"/>
                        <xsl:with-param name="delimiter" select="';'"/>
                    </xsl:call-template>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:text></xsl:text>
                </xsl:otherwise>
            </xsl:choose>
        </xsl:variable>
        <DESCRIPTION>
            <xsl:choose>
                <xsl:when test="../../description/short_desc = '' and ../../description/long_desc = ''">
                    <!-- nie jest git bo nie ma opisów  -->
                    <xsl:if test="$from_parameters != ''">
                        <xsl:value-of select="../../description/name"/>
                        <xsl:value-of select="$from_parameters"/>
                    </xsl:if>
                </xsl:when>
                <xsl:when test="../../description/short_desc = ''">
                    <xsl:variable name = "returned_value_without_html">
                        <xsl:call-template name="strip-tags">
                            <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                        </xsl:call-template>
                    </xsl:variable>
                    <xsl:variable name="returned_value_x_char" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                    <xsl:variable name="value_cut">
                        <xsl:call-template name="tokenize">
                            <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                        </xsl:call-template>
                    </xsl:variable>
                    <xsl:variable name="last_char" select="substring($returned_value_x_char, string-length($returned_value_x_char), 1)"/>
                    <xsl:choose>
                        <xsl:when test="$last_char != '.'">
                            <!-- chodzi oto ze nie ma przed kropka nic  -->
                            <xsl:choose>
                                <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut)) = ''">
                                    <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="$returned_value_x_char"/>
                                    <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                        <xsl:text>&#xa;</xsl:text>
                                        <xsl:value-of select="../../description/name"/>
                                        <xsl:value-of select="$from_parameters"/>
                                    </xsl:if>
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </xsl:when>
                                <xsl:otherwise>
                                    <!-- jest przed kropka text -->
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))"/>
                                    <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                        <xsl:text>&#xa;</xsl:text>
                                        <xsl:value-of select="../../description/name"/>
                                        <xsl:value-of select="$from_parameters"/>
                                    </xsl:if>
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:otherwise>
                            <!-- Mamy kropke na koncu i jest git -->
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="$returned_value_x_char"/>
                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                <xsl:text>&#xa;</xsl:text>
                                <xsl:value-of select="../../description/name"/>
                                <xsl:value-of select="$from_parameters"/>
                            </xsl:if>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:when>
                <xsl:otherwise>
                    <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                    <!-- załóżmy -->
                    <xsl:choose>
                        <xsl:when test="string-length(../../description/short_desc) > 500 or ../../description/long_desc = ''">
                            <!-- jest git bo ma wiecej niz  -->
                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                            <xsl:value-of select="../../description/short_desc"/>
                            <xsl:if test="string-length(../../description/short_desc) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                <xsl:text>&#xa;</xsl:text>
                                <xsl:value-of select="../../description/name"/>
                                <xsl:value-of select="$from_parameters"/>
                            </xsl:if>
                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:variable name = "returned_value_without_html">
                                <xsl:call-template name="strip-tags">
                                    <xsl:with-param name="text" select="../../description/long_desc" tunnel="yes"/>
                                </xsl:call-template>
                            </xsl:variable>
                            <xsl:variable name="returned_value_x_char" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                            <xsl:variable name="value_cut">
                                <xsl:call-template name="tokenize">
                                    <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,$dlugosc_opisu)"/>
                                </xsl:call-template>
                            </xsl:variable>
                            <xsl:variable name="last_char" select="substring($returned_value_x_char, string-length($returned_value_x_char), 1)"/>
                            <xsl:choose>
                                <xsl:when test="$last_char != '.'">
                                    <!-- chodzi oto ze nie ma przed kropka nic  -->
                                    <xsl:choose>
                                        <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut)) = ''">
                                            <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="$returned_value_x_char"/>
                                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                <xsl:text>&#xa;</xsl:text>
                                                <xsl:value-of select="../../description/name"/>
                                                <xsl:value-of select="$from_parameters"/>
                                            </xsl:if>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <!-- jest przed kropka text -->
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))"/>
                                            <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                <xsl:text>&#xa;</xsl:text>
                                                <xsl:value-of select="../../description/name"/>
                                                <xsl:value-of select="$from_parameters"/>
                                            </xsl:if>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:when>
                                <xsl:otherwise>
                                    <!-- Mamy kropke na koncu i jest git -->
                                    <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                    <xsl:value-of select="$returned_value_x_char"/>
                                    <xsl:if test="string-length(normalize-space(substring-before(normalize-space($returned_value_x_char), $value_cut))) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                        <xsl:text>&#xa;</xsl:text>
                                        <xsl:value-of select="../../description/name"/>
                                        <xsl:value-of select="$from_parameters"/>
                                    </xsl:if>
                                    <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:otherwise>
                    </xsl:choose>
                </xsl:otherwise>
            </xsl:choose>
        </DESCRIPTION>
        <BRAND>
            <xsl:value-of select="../../producer/@name"/>
        </BRAND>

        <!-- Magazyny -->
        <xsl:variable name="stocks">
            <xsl:for-each select="stock">
                <xsl:choose>
                    <xsl:when test="(@id = '1' or @id = '0' or @id ='2' or @id='3' or @id ='4' or @id='5' or @id='6' or @id='7' or @id='8' or @id='9') 
                    and @available_stock_quantity &gt; 0">
                        <xsl:value-of select="@available_stock_quantity"/>
                        <xsl:text>/</xsl:text>
                    </xsl:when>
                    <xsl:when test="(@id = '1' or @id = '0' or @id ='2' or @id='3' or @id ='4' or @id='5' or @id='6' or @id='7' or @id='8' or @id='9') 
                    and @available_stock_quantity = -1 ">
                        <xsl:value-of select="@available_stock_quantity"/>
                        <xsl:text>/</xsl:text>
                    </xsl:when>
                </xsl:choose>
            </xsl:for-each>
        </xsl:variable>

        <STOCK>
            <xsl:choose>
                <xsl:when test="contains($stocks,'-1') and string-length($stocks) &gt;0">
                    <xsl:text>999999</xsl:text>
                </xsl:when>
                <xsl:when test="string-length($stocks) = 0">
                    <xsl:text>0</xsl:text>
                </xsl:when>
                <xsl:otherwise>
                    <xsl:value-of select="sum(stock[@id = '1' or @id = '0' or @id ='2' or @id='3' or @id ='4' or @id='5' or @id='6' or @id='7' or @id='8' or @id='9']/@available_stock_quantity)"/>
                </xsl:otherwise>
            </xsl:choose>
        </STOCK>

        <PARAMETERS>
            <xsl:for-each select="../../parameters/parameter">
                <xsl:if test="@hide = 'n'">                    <!-- Warunek dla parametrów które chcemy -->
                    <xsl:for-each select="value">
                        <PARAMETER>
                            <NAME>
                                <xsl:value-of select="../@name"></xsl:value-of>
                            </NAME>
                            <VALUE>
                                <xsl:value-of select="@name"></xsl:value-of>
                            </VALUE>
                        </PARAMETER>
                    </xsl:for-each>
                </xsl:if>
            </xsl:for-each>
        </PARAMETERS>
        <CATEGORYTEXT>
            <xsl:call-template name="string-replace-all">
                <xsl:with-param name="text" select="../../category/@name" tunnel="yes"/>
                <xsl:with-param name="replace" select="'/'" tunnel="yes"/>
                <xsl:with-param name="by" select="' | '" tunnel="yes"/>
            </xsl:call-template>
        </CATEGORYTEXT>
    </xsl:template>
</xsl:stylesheet>