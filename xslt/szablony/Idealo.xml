<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:variable name="upperLetters" select="'ABCDEFGHIJKLMNOPQRSTUVWXYZÄÖÜẞ'"/>
    <xsl:variable name="lowerLetters" select="'abcdefghijklmnopqrstuvwxyzäöüß'"/>
    <!-- długoś opisu -->
    <xsl:variable name='dlugosc_opisu'>800</xsl:variable>
    <xsl:variable name='dlugosc_opisu_z_parametrow'>600</xsl:variable>
    <!-- wymagany limit długości opisu po którego przekroczeniu nie zostanie dodany opis z parametrów  -->
    <xsl:variable name='minimalna_dlugosc_opisu_dla_parametrow'>120</xsl:variable>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'GRATIS'"/>
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='kwota_dla_darmowej_dostawy'>39.9</xsl:variable>
    <xsl:variable name='kwota_dla_wiekszych_zamowien'>29.00</xsl:variable>
    <xsl:variable name="Koszt_dostawy">3.95</xsl:variable>
    <xsl:variable name="Koszt_dostawy_za_pobraniem"></xsl:variable>
    <xsl:variable name="Koszt_dostawy_wiekszych_zamowien">1.95</xsl:variable>
    <xsl:variable name="Kraj_dostawy" select="'ES'"/>
    <!-- czas dostawy -->
    <xsl:variable name="czas_dostawy">4 días laborables</xsl:variable>
    <xsl:variable name="czas_dostawy_magazyn_obcy_m0">4 días laborables</xsl:variable>

    <xsl:template match="/">
        <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
        <LIST>
            <xsl:for-each select="/offer/products/product">
                <ARTICLE>
                    <!--Unikalny identyfikator produktu  -->
                    <ARTICLENUMBER>
                        <xsl:value-of select="sizes/size/@code"/>
                        <!-- <xsl:value-of select="@id"/> -->
                    </ARTICLENUMBER>
                    <!-- Tytuł -->
                    <PRODUCTNAME>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="description/name/." tunnel="yes"/>
                        </xsl:call-template>
                    </PRODUCTNAME>
                    <!-- Opis -->
                    <!-- short descr -->
                    <xsl:variable name="from_parameters_raw">
                        <xsl:for-each select="parameters/parameter[@hide = 'n' and value/@name != '']">
                            <xsl:text>&#xa;</xsl:text>
                            <xsl:value-of select="@name"/>
                            <xsl:text>: </xsl:text>
                            <xsl:for-each select="value">
                                <xsl:value-of select="@name"/>
                                <xsl:text>; </xsl:text>
                            </xsl:for-each>
                        </xsl:for-each>
                    </xsl:variable>
                    <xsl:variable name="from_parameters">
                        <xsl:choose>
                            <xsl:when test="$from_parameters_raw != ''">
                                <xsl:call-template name="tokenize">
                                    <xsl:with-param name="text" select="substring($from_parameters_raw, 1, $dlugosc_opisu_z_parametrow)"/>
                                    <xsl:with-param name="delimiter" select="';'"/>
                                </xsl:call-template>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text></xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <DESCRIPTION>
                        <xsl:choose>
                            <xsl:when test="description/short_desc = '' and description/long_desc = ''">
                                <!-- nie jest git bo nie ma opisów  -->
                                <xsl:if test="$from_parameters != ''">
                                    <xsl:value-of select="description/name"/>
                                    <xsl:value-of select="$from_parameters"/>
                                </xsl:if>
                            </xsl:when>
                            <xsl:when test="description/short_desc = '' and string-length(normalize-space(description/long_desc)) > 0">
                                <xsl:variable name = "opis_bez_tagow">
                                    <xsl:call-template name="strip-tags">
                                        <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:variable name="opis_do_kropki">
                                    <xsl:call-template name="tokenize">
                                        <xsl:with-param name="text" select="substring(normalize-space($opis_bez_tagow),1,$dlugosc_opisu)"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:choose>
                                    <xsl:when test="$opis_do_kropki = ''">
                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="$opis_bez_tagow"/>
                                        <xsl:if test="string-length(normalize-space($opis_bez_tagow)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                            <xsl:text>&#xa;</xsl:text>
                                            <xsl:value-of select="description/name"/>
                                            <xsl:value-of select="$from_parameters"/>
                                        </xsl:if>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="$opis_do_kropki"/>
                                        <xsl:if test="string-length(normalize-space($opis_do_kropki)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                            <xsl:text>&#xa;</xsl:text>
                                            <xsl:value-of select="description/name"/>
                                            <xsl:value-of select="$from_parameters"/>
                                        </xsl:if>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:otherwise>
                                <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                <!-- załóżmy -->
                                <xsl:choose>
                                    <xsl:when test="string-length(description/short_desc) > 240 or description/long_desc = ''">
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="description/short_desc"/>
                                        <xsl:if test="string-length(description/short_desc) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                            <xsl:text>&#xa;</xsl:text>
                                            <xsl:value-of select="description/name"/>
                                            <xsl:value-of select="$from_parameters"/>
                                        </xsl:if>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:variable name = "opis_bez_tagow">
                                            <xsl:call-template name="strip-tags">
                                                <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="opis_do_kropki">
                                            <xsl:call-template name="tokenize">
                                                <xsl:with-param name="text" select="substring(normalize-space($opis_bez_tagow),1,$dlugosc_opisu)"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:choose>
                                            <xsl:when test="$opis_do_kropki = ''">
                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$opis_bez_tagow"/>
                                                <xsl:if test="string-length(normalize-space($opis_bez_tagow)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$opis_do_kropki"/>
                                                <xsl:if test="string-length(normalize-space($opis_do_kropki)) &lt; $minimalna_dlugosc_opisu_dla_parametrow and $from_parameters != ''">
                                                    <xsl:text>&#xa;</xsl:text>
                                                    <xsl:value-of select="description/name"/>
                                                    <xsl:value-of select="$from_parameters"/>
                                                </xsl:if>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:otherwise>
                        </xsl:choose>
                    </DESCRIPTION>
                    <PRODUCTCATEGORY>
                        <!-- <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text> -->
                        <xsl:value-of select="category/@name"/>
                        <!-- <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text> -->
                    </PRODUCTCATEGORY>
                    <!-- link do produktu -->
                    <PRODUCTURL>
                        <xsl:value-of select="substring-before(card/@url, '.feed')"/>
                        <xsl:text disable-output-escaping="yes">.idealo</xsl:text>
                        <xsl:value-of select="translate($Kraj_dostawy, $upperLetters, $lowerLetters)"/>
                    </PRODUCTURL>

                    <xsl:choose>
                        <xsl:when test="images/icons/auction_icon/@url != ''">
                            <IMAGES>
                                <xsl:text disable-output-escaping="yes">&lt;IMAGEURL1&gt;</xsl:text>
                                <xsl:value-of select="images/icons/auction_icon/@url"/>
                                <xsl:text disable-output-escaping="yes">&lt;/IMAGEURL1&gt;</xsl:text>
                                <xsl:for-each select="images/large/image[position() &lt; 5]">
                                    <xsl:text disable-output-escaping="yes">&lt;IMAGEURL</xsl:text>
                                    <xsl:value-of select="position()+1"/>
                                    <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                    <xsl:value-of select="@url"/>
                                    <xsl:text disable-output-escaping="yes">&lt;/IMAGEURL</xsl:text>
                                    <xsl:value-of select="position()+1"/>
                                    <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                </xsl:for-each>
                            </IMAGES>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:variable name="vLowest">
                                <xsl:for-each select="images/large/image/@iaiext:priority">
                                    <xsl:sort data-type="number"/>
                                    <xsl:if test="position()=1">
                                        <xsl:value-of select="."/>
                                    </xsl:if>
                                </xsl:for-each>
                            </xsl:variable>

                            <IMAGES>
                                <xsl:for-each select="images/large/image[position() &lt; 5]">
                                    <xsl:text disable-output-escaping="yes">&lt;IMAGEURL</xsl:text>
                                    <xsl:value-of select="position()"/>
                                    <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                    <xsl:value-of select="@url"/>
                                    <xsl:text disable-output-escaping="yes">&lt;/IMAGEURL</xsl:text>
                                    <xsl:value-of select="position()"/>
                                    <xsl:text disable-output-escaping="yes">&gt;</xsl:text>
                                </xsl:for-each>
                            </IMAGES>
                        </xsl:otherwise>
                    </xsl:choose>

                    <xsl:variable name="cena_serwis">
                        <xsl:choose>
                            <xsl:when test="iaiext:pricecomparator_price/iaiext:site">
                                <xsl:value-of select="iaiext:pricecomparator_price/iaiext:site/@gross"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>0</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:variable name="cena_przekreslona">
                        <xsl:choose>
                            <!-- cena przekreslona domyslna -->
                            <xsl:when test="strikethrough_retail_price and not(strikethrough_retail_price and strikethrough_retail_price/@gross &lt; sizes/size/strikethrough_retail_price/@gross)">
                                <xsl:value-of select="strikethrough_retail_price/@gross"/>
                            </xsl:when>
                            <!-- cena przekreslona dla rozmiaru -->
                            <xsl:when test="sizes/size/strikethrough_retail_price">
                                <xsl:value-of select="sizes/size/strikethrough_retail_price/@gross"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>0</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:variable name="cena_przedpromocyjna">
                        <xsl:choose>
                            <!-- cena standard gdy jest cena promocyjna rozmiaru -->
                            <xsl:when test="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@panel_name != '' and
                                      promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > sizes/size/price/@gross">
                                <xsl:value-of select="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                            </xsl:when>
                            <!-- cena standard gdy jest cena promocyna standardowej ceny -->
                            <xsl:when test="promotion/price/normal_retail_price and promotion/price/normal_retail_price/@gross > sizes/size/price/@gross">
                                <xsl:value-of select="promotion/price/normal_retail_price/@gross"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>0</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:variable name="mainPrice">
                        <xsl:choose>
                            <xsl:when test="$cena_serwis > 0">
                                <xsl:choose>
                                    <xsl:when test="$cena_przedpromocyjna > $cena_serwis or $cena_przekreslona > $cena_serwis">
                                        <xsl:choose>
                                            <xsl:when test="$cena_przedpromocyjna > $cena_przekreslona">
                                                <xsl:value-of select="$cena_przedpromocyjna"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="$cena_przekreslona"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="$cena_serwis"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:choose>
                                    <xsl:when test="$cena_przedpromocyjna > sizes/size/price/@gross or $cena_przekreslona > sizes/size/price/@gross">
                                        <xsl:choose>
                                            <xsl:when test="$cena_przedpromocyjna > $cena_przekreslona">
                                                <xsl:value-of select="$cena_przedpromocyjna"/>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <xsl:value-of select="$cena_przekreslona"/>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="sizes/size/price/@gross"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <PRICE>
                        <xsl:value-of select="$mainPrice"/>
                    </PRICE>
                    <xsl:choose>
                        <xsl:when test="$cena_serwis > 0 and $mainPrice > $cena_serwis">
                            <FORMERPRICE>
                                <xsl:value-of select="$cena_serwis"/>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="@currency"/>
                            </FORMERPRICE>
                        </xsl:when>
                        <xsl:when test="$mainPrice > sizes/size/price/@gross and $mainPrice > $cena_serwis">
                            <FORMERPRICE>
                                <xsl:value-of select="sizes/size/price/@gross"/>
                                <xsl:text><![CDATA[ ]]></xsl:text>
                                <xsl:value-of select="@currency"/>
                            </FORMERPRICE>
                        </xsl:when>
                    </xsl:choose>
                    <DELIVERYTIME>
                        <!-- Czas dostawy -->
                        <xsl:choose>
                            <xsl:when test="sizes/size/stock[@id != 0]/@quantity">
                                <xsl:value-of select="$czas_dostawy"/>
                            </xsl:when>
                            <xsl:when test="sizes/size/stock[@id = 0]/@quantity">
                                <!-- mamy m0 -->
                                <xsl:value-of select="$czas_dostawy_magazyn_obcy_m0"/>
                            </xsl:when>
                        </xsl:choose>
                    </DELIVERYTIME>
                    <xsl:choose>
                        <xsl:when test="$mainPrice >= $kwota_dla_darmowej_dostawy">
                            <SHIPPINGCOSTS>
                                <PREPAYMENT>
                                    <xsl:text><![CDATA[0]]></xsl:text>
                                </PREPAYMENT>
                                <xsl:if test="$Koszt_dostawy_za_pobraniem != ''">
                                    <CASH_ON_DELIVERY>
                                        <xsl:value-of select="$Koszt_dostawy_za_pobraniem"/>
                                    </CASH_ON_DELIVERY>
                                </xsl:if>
                            </SHIPPINGCOSTS>
                        </xsl:when>
                        <xsl:when test="$mainPrice >= $kwota_dla_wiekszych_zamowien">
                            <SHIPPINGCOSTS>
                                <PREPAYMENT>
                                    <xsl:value-of select="$Koszt_dostawy_wiekszych_zamowien"/>
                                </PREPAYMENT>
                                <xsl:if test="$Koszt_dostawy_za_pobraniem != ''">
                                    <CASH_ON_DELIVERY>
                                        <xsl:value-of select="$Koszt_dostawy_za_pobraniem"/>
                                    </CASH_ON_DELIVERY>
                                </xsl:if>
                            </SHIPPINGCOSTS>
                        </xsl:when>
                        <xsl:otherwise>
                            <SHIPPINGCOSTS>
                                <PREPAYMENT>
                                    <xsl:value-of select="$Koszt_dostawy"/>
                                </PREPAYMENT>
                                <xsl:if test="$Koszt_dostawy_za_pobraniem != ''">
                                    <CASH_ON_DELIVERY>
                                        <xsl:value-of select="$Koszt_dostawy_za_pobraniem"/>
                                    </CASH_ON_DELIVERY>
                                </xsl:if>
                            </SHIPPINGCOSTS>
                        </xsl:otherwise>
                    </xsl:choose>
                    <!-- EAN PRODUKTU -->
                    <xsl:if test="sizes/size/@code_producer and sizes/size/@code_producer!=''">
                        <xsl:variable name="code_producer_variable">
                            <xsl:value-of select="sizes/size/@code_producer"/>
                        </xsl:variable>
                        <EAN>
                            <xsl:value-of select="substring-after($code_producer_variable, substring-before($code_producer_variable, substring(translate($code_producer_variable, '0', ''), 1, 1)))"/>
                        </EAN>
                    </xsl:if>
                    <!-- Marka -->
                    <MANUFACTURERNAME>
                        <xsl:value-of select="normalize-space(producer/@name)"/>
                    </MANUFACTURERNAME>

                    <!-- waga sizes/size/@weight-->
                    <xsl:variable name="weight_final_form">
                        <xsl:choose>
                            <xsl:when test="parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != ''">
                                <xsl:value-of select="format-number($mainPrice div translate(parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ',', '.'), '#.##')"/>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:variable name="volume_final_form">
                        <xsl:choose>
                            <xsl:when test="parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != ''">
                                <xsl:value-of select="format-number($mainPrice div translate(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ',', '.'), '#.##')"/>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:variable>
                    <BASEPRICE>
                        <xsl:choose>
                            <xsl:when test = "parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != '' and $weight_final_form != 'NaN'">
                                <xsl:value-of select="$weight_final_form"/>
                                <xsl:text><![CDATA[ EUR / g]]></xsl:text>
                            </xsl:when>
                            <xsl:when test = "parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != '' and $weight_final_form != 'NaN'">
                                <xsl:value-of select="$volume_final_form"/>
                                <xsl:text><![CDATA[ EUR / ml]]></xsl:text>
                            </xsl:when>
                        </xsl:choose>
                    </BASEPRICE>
                </ARTICLE>
            </xsl:for-each>
        </LIST>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:value-of select="substring-before($text, $delimiter)"/>
                <xsl:value-of select="$delimiter"/>
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                    <xsl:with-param name="delimiter" select="$delimiter"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
</xsl:stylesheet>