<xsl:stylesheet version="1.0"
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:iaiext="http://www.iai-shop.com/developers/iof/extensions.phtml"
    xmlns:php="http://php.net/xsl">
    <xsl:output method="xml" version="1.0" encoding="UTF-8" indent="yes" />

    <xsl:variable name="upperLetters" select="'AĄBCĆDEĘFGHIJKLŁMNŃOÓPQRSŚTUVWXYZŹŻ'"/>
    <xsl:variable name="lowerLetters" select="'aąbcćdeęfghijklłmnńoópqrsśtuvwxyzźż'"/>
    <!-- słowa formatowane do pisanych z dużej litery w tytule -->
    <xsl:variable name="corrected" select="'\lllll\'"/>
    <!-- kwoty stawek wysyłek do ustalenia -->
    <xsl:variable name='Kwota_za_darmo_wysylka'>39.00</xsl:variable>
    <xsl:variable name='Kwota_za_darmo_wysylka_large'>5.00</xsl:variable>
    <xsl:variable name="Kwota_wysylki">4.49</xsl:variable>
    <xsl:variable name="Kwota_wysylki_large">4.49</xsl:variable>

    <xsl:template match="/">
        <!-- <updated><xsl:value-of select="/offer/@generated"/></updated> -->
        <products>
            <xsl:for-each select="/offer/products/product">
                <product>
                    <!--Unikalny identyfikator produktu  -->
                    <aid>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <!-- <xsl:value-of select="sizes/size/@code"/> -->
                        <xsl:value-of select="sizes/size/@code"/>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </aid>
                    <!-- Tytuł -->
                    <name>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="description/name/." tunnel="yes"/>
                        </xsl:call-template>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </name>
                    <!-- Opis -->
                    <!-- short descr -->
                    <xsl:variable name="from_parameters_raw">
                        <xsl:for-each select="parameters/parameter[@hide = 'n' and value/@name != '']">
                            <xsl:text>&#xa;</xsl:text>
                            <xsl:value-of select="@name"/>
                            <xsl:text>: </xsl:text>
                            <xsl:for-each select="value">
                                <xsl:value-of select="@name"/>
                                <xsl:text>; </xsl:text>
                            </xsl:for-each>
                        </xsl:for-each>
                    </xsl:variable>
                    <xsl:variable name="from_parameters">
                        <xsl:choose>
                            <xsl:when test="$from_parameters_raw != ''">
                                <xsl:call-template name="tokenize">
                                    <xsl:with-param name="text" select="substring($from_parameters_raw, 1, 900)"/>
                                    <xsl:with-param name="delimeter" select="' '"/>
                                </xsl:call-template>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text></xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <desc>
                        <xsl:choose>
                            <xsl:when test="description/short_desc = '' and description/long_desc = ''">
                                <!-- nie jest git bo nie ma opisów  -->
                                <xsl:if test="$from_parameters != ''">
                                    <xsl:value-of select="description/name"/>
                                    <xsl:value-of select="$from_parameters"/>
                                </xsl:if>
                            </xsl:when>
                            <xsl:when test="description/short_desc = ''">
                                <xsl:variable name = "returned_value_without_html">
                                    <xsl:call-template name="strip-tags">
                                        <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:variable name="returned_value_2000_char" select="substring(normalize-space($returned_value_without_html),1,2000)"/>
                                <xsl:variable name="value_cut">
                                    <xsl:call-template name="tokenize">
                                        <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,2000)"/>
                                    </xsl:call-template>
                                </xsl:variable>
                                <xsl:variable name="last_char" select="substring($returned_value_2000_char, string-length($returned_value_2000_char), 1)"/>
                                <xsl:choose>
                                    <xsl:when test="$last_char != '.'">
                                        <!-- chodzi oto ze nie ma przed kropka nic  -->
                                        <xsl:choose>
                                            <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_2000_char), $value_cut)) = ''">
                                                <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$returned_value_2000_char"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- jest przed kropka text -->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_2000_char), $value_cut))"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <!-- Mamy kropke na koncu i jest git -->
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="$returned_value_2000_char"/>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:otherwise>
                                <!-- tutaj jeśli opis nie bedzie mial X znakow to zastapic go długim opisem mimo wszystko -->
                                <!-- załóżmy -->
                                <xsl:choose>
                                    <xsl:when test="string-length(description/short_desc) > 400">
                                        <!-- jest git bo ma wiecej niz  -->
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="description/short_desc"/>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:variable name = "returned_value_without_html">
                                            <xsl:call-template name="strip-tags">
                                                <xsl:with-param name="text" select="description/long_desc" tunnel="yes"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="returned_value_2000_char" select="substring(normalize-space($returned_value_without_html),1,2000)"/>
                                        <xsl:variable name="value_cut">
                                            <xsl:call-template name="tokenize">
                                                <xsl:with-param name="text" select="substring(normalize-space($returned_value_without_html),1,2000)"/>
                                            </xsl:call-template>
                                        </xsl:variable>
                                        <xsl:variable name="last_char" select="substring($returned_value_2000_char, string-length($returned_value_2000_char), 1)"/>
                                        <xsl:choose>
                                            <xsl:when test="$last_char != '.'">
                                                <!-- chodzi oto ze nie ma przed kropka nic  -->
                                                <xsl:choose>
                                                    <xsl:when test="normalize-space(substring-before(normalize-space($returned_value_2000_char), $value_cut)) = ''">
                                                        <!-- Nie ma przed kropka nic wiec podajemy co mamy bo mozliwe ze wgl nie ma kropki lool-->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="$returned_value_2000_char"/>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:when>
                                                    <xsl:otherwise>
                                                        <!-- jest przed kropka text -->
                                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                        <xsl:value-of select="normalize-space(substring-before(normalize-space($returned_value_2000_char), $value_cut))"/>
                                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                                    </xsl:otherwise>
                                                </xsl:choose>
                                            </xsl:when>
                                            <xsl:otherwise>
                                                <!-- Mamy kropke na koncu i jest git -->
                                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                                <xsl:value-of select="$returned_value_2000_char"/>
                                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                            </xsl:otherwise>
                                        </xsl:choose>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:otherwise>
                        </xsl:choose>
                    </desc>

                    <shop_cat>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="category/@name"/>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </shop_cat>
                    <!-- link do produktu -->
                    <!-- WYMAGANY: Link do produktu -->
                    <!-- pl zzamienic na jezyk ktory bedziemy realizować -->
                    <link>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="substring-before(card/@url, '.feed')"/>
                        <xsl:text disable-output-escaping="yes">.billiger.html]]&gt;</xsl:text>
                    </link>

                    <xsl:choose>
                        <xsl:when test="images/icons/auction_icon/@url">
                            <image>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="images/icons/auction_icon/@url"></xsl:value-of>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </image>
                        </xsl:when>
                        <xsl:otherwise>
                            <xsl:variable name="vLowest">
                                <xsl:for-each select="images/large/image/@iaiext:priority">
                                    <xsl:sort data-type="number"/>
                                    <xsl:if test="position()=1">
                                        <xsl:value-of select="."/>
                                    </xsl:if>
                                </xsl:for-each>
                            </xsl:variable>

                            <xsl:for-each select="images/large/image[position() = 1]">
                                <xsl:choose>
                                    <xsl:when test="@iaiext:priority = number($vLowest)">
                                        <image>
                                            <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                            <xsl:value-of select="@url"/>
                                            <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                        </image>
                                    </xsl:when>
                                </xsl:choose>
                            </xsl:for-each>
                        </xsl:otherwise>
                    </xsl:choose>

                    <xsl:variable name="cena_serwis">
                        <xsl:choose>
                            <xsl:when test="iaiext:pricecomparator_price/iaiext:site">
                                <xsl:value-of select="iaiext:pricecomparator_price/iaiext:site/@gross"/>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text>0</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:variable name="mainPrice">
                        <xsl:choose>
                            <!-- <xsl:when test="srp and 
                                srp/@gross > sizes/size/price/@gross and 
                                sizes/size/price/@gross = price/@gross">
                                    <xsl:choose>
                                        <xsl:when test="srp/@gross > sizes/size/price/@gross">
                                            <xsl:value-of select="srp/@gross"></xsl:value-of>
                                        </xsl:when>
                                        <xsl:otherwise>
                                            <xsl:value-of select="sizes/size/price/@gross"></xsl:value-of>
                                        </xsl:otherwise>
                                    </xsl:choose>
                                </xsl:when> -->
                            <xsl:when test="strikethrough_retail_price and  strikethrough_retail_price/@gross > 0 and
                                strikethrough_retail_price/@gross > sizes/size/price/@gross and 
                                price/@gross = sizes/size/price/@gross and 
                                strikethrough_retail_price/@gross > $cena_serwis">
                                <xsl:choose>
                                    <xsl:when test="strikethrough_retail_price/@gross > sizes/size/price/@gross">
                                        <xsl:value-of select="strikethrough_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="sizes/size/price/@gross"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:when test="iaiext:pricecomparator_price/iaiext:site and price/@gross = sizes/size/price/@gross">
                                <xsl:choose>
                                    <xsl:when test="promotion/price/normal_retail_price/@gross > iaiext:pricecomparator_price/iaiext:site[1]/@gross">
                                        <xsl:value-of select="promotion/price/normal_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="iaiext:pricecomparator_price/iaiext:site[1]/@gross"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                            <xsl:when test="sizes/size/price/@gross">
                                <xsl:choose>
                                    <xsl:when test="sizes/size/price/@gross != price/@gross and
                                            promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > sizes/size/price/@gross">
                                        <xsl:value-of select="promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross"/>
                                    </xsl:when>
                                    <xsl:when test="sizes/size/price/@gross = price/@gross and
                                            promotion/price/normal_retail_price/@gross > sizes/size/price/@gross">
                                        <xsl:value-of select="promotion/price/normal_retail_price/@gross"/>
                                    </xsl:when>
                                    <xsl:otherwise>
                                        <xsl:value-of select="sizes/size/price/@gross"/>
                                    </xsl:otherwise>
                                </xsl:choose>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:choose>
                        <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka">
                            <dlv_cost>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:text><![CDATA[0]]></xsl:text>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </dlv_cost>
                        </xsl:when>
                        <xsl:when test="$mainPrice >= $Kwota_za_darmo_wysylka_large">
                            <dlv_cost>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="$Kwota_wysylki_large"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </dlv_cost>
                        </xsl:when>
                        <xsl:otherwise>
                            <dlv_cost>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="$Kwota_wysylki"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </dlv_cost>
                        </xsl:otherwise>
                    </xsl:choose>
                    <!-- produkcja -->
                    <!-- jesli bedzie promocja lub przekreślona cena to od razu promocyjna cene większa od normalnej-->
                    <xsl:choose>
                        <xsl:when test="promotion/price/normal_retail_price or strikethrough_retail_price">
                            <xsl:choose>
                                <xsl:when test = "
                                      (strikethrough_retail_price and strikethrough_retail_price/@gross > sizes/size/price/@gross) or
                                      (promotion/price/normal_retail_price and promotion/price/normal_retail_price/@gross > sizes/size/price/@gross) or
                                      (promotion/price/normal_retail_price and price/@gross != sizes/size/price/@gross and 
                                      promotion/price/normal_retail_price/iaiext:site/iaiext:price_per_size[@id = ../../../../../sizes/size/@id]/@gross > sizes/size/price/@gross)">
                                    <price>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="sizes/size/price/@gross"/>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </price>
                                    <old_price>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="$mainPrice"/>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </old_price>
                                    <promo_text>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="promotion/@name"/>
                                        <xsl:text disable-output-escaping="yes"> (-</xsl:text>
                                        <xsl:value-of select="100 - format-number(100 * (sizes/size/price/@gross div $mainPrice), '#')"/>
                                        <xsl:text disable-output-escaping="yes">%)]]&gt;</xsl:text>
                                    </promo_text>
                                </xsl:when>
                                <xsl:otherwise>
                                    <price>
                                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                        <xsl:value-of select="sizes/size/price/@gross"/>
                                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                                    </price>
                                </xsl:otherwise>
                            </xsl:choose>
                        </xsl:when>
                        <xsl:otherwise>
                            <price>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="sizes/size/price/@gross"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </price>
                        </xsl:otherwise>
                    </xsl:choose>
                    <dlv_time>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[sofort lieferbar]]&gt;</xsl:text>
                    </dlv_time>

                    <!-- waga sizes/size/@weight-->
                    <xsl:variable name="weight_final_form">
                        <xsl:choose>
                            <xsl:when test="parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != ''">
                                <xsl:value-of select="format-number(sizes/size/price/@gross div translate(parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name, ',', '.'), '#.##')"/>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:variable>
                    <xsl:variable name="volume_final_form">
                        <xsl:choose>
                            <xsl:when test="parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != ''">
                                <xsl:value-of select="format-number(sizes/size/price/@gross div translate(../../parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name, ',', '.'), '#.##')"/>
                            </xsl:when>
                        </xsl:choose>
                    </xsl:variable>
                    <ppu>
                        <xsl:choose>
                            <xsl:when test = "parameters/parameter[@context_id='CONTEXT_STD_UNIT_WEIGHT']/value/@name != '' and $weight_final_form != 'NaN'">
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="$weight_final_form"/>
                                <xsl:text><![CDATA[ EUR / g]]></xsl:text>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </xsl:when>
                            <xsl:when test = "parameters/parameter[@context_id='CONTEXT_STD_UNIT_VOLUME']/value/@name != '' and $weight_final_form != 'NaN'">
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="$volume_final_form"/>
                                <xsl:text><![CDATA[ EUR / ml]]></xsl:text>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </xsl:when>
                        </xsl:choose>
                    </ppu>
                    <!--Versja 2.0  -->
                    <xsl:choose>
                        <xsl:when test="sizes/size/@code_producer and sizes/size/@code_producer!=''">
                            <!-- mamy kod producenta -->
                            <ean>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="sizes/size/@code_producer"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </ean>
                        </xsl:when>
                        <xsl:otherwise>
                            <!-- tutaj uzyjemy code on card -->
                            <ean>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="@code_on_card"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </ean>
                        </xsl:otherwise>
                    </xsl:choose>
                    <!-- Marka -->
                    <brand>
                        <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                        <xsl:value-of select="normalize-space(producer/@name)"/>
                        <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                    </brand>

                    <size>
                        <xsl:choose>
                            <xsl:when test = "sizes/size/@name = 'uniwersalny'">
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[universal]]&gt;</xsl:text>
                            </xsl:when>
                            <xsl:otherwise>
                                <xsl:text disable-output-escaping="yes">&lt;![CDATA[</xsl:text>
                                <xsl:value-of select="sizes/size/@name"/>
                                <xsl:text disable-output-escaping="yes">]]&gt;</xsl:text>
                            </xsl:otherwise>
                        </xsl:choose>
                    </size>
                </product>
            </xsl:for-each>
        </products>
    </xsl:template>

    <xsl:template name="strip-tags">
        <xsl:param name="text" />
        <xsl:param name="depth" select="0" />
        <xsl:choose>
            <xsl:when test="contains($text, '&lt;') and $depth &lt; 1000">
                <xsl:value-of select="substring-before($text, '&lt;')" />
                <xsl:call-template name="strip-tags">
                    <xsl:with-param name="text" select="substring-after((normalize-space($text)), '&gt;')" tunnel="true"/>
                    <xsl:with-param name="depth" select="$depth + 1" />
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="normalize-space($text)" tunnel="true"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="tokenize">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="'.'"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter)">
                <xsl:call-template name="tokenize">
                    <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="wordFormat">
        <xsl:param name="text"/>
        <xsl:param name="delimiter" select="' '"/>
        <xsl:choose>
            <xsl:when test="contains($text, $delimiter) and not(contains(substring-before($text, $delimiter),'/'))">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, $delimiter)"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:value-of select="$delimiter"/>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, $delimiter)"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:when test="contains($text, '/')">
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="substring-before($text, '/')"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                        <xsl:text><![CDATA[/]]></xsl:text>
                        <xsl:call-template name="wordFormat">
                            <xsl:with-param name="text" select="substring-after($text, '/')"/>
                        </xsl:call-template>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:when>
            <xsl:otherwise>
                <xsl:variable name="word">
                    <xsl:text><![CDATA[\]]></xsl:text>
                    <xsl:value-of select="$text"/>
                    <xsl:text><![CDATA[\]]></xsl:text>
                </xsl:variable>
                <xsl:choose>
                    <xsl:when test="contains($corrected, $word)">
                        <xsl:value-of select="substring(translate($word, '\', ''),1,1)"/>
                        <xsl:value-of select="translate(substring(translate($word, '\', ''),2), $upperLetters, $lowerLetters)"/>
                    </xsl:when>
                    <xsl:otherwise>
                        <xsl:value-of select="translate($word, '\', '')"/>
                    </xsl:otherwise>
                </xsl:choose>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>

    <xsl:template name="string-replace-all">
        <xsl:param name="text"/>
        <xsl:param name="replace"/>
        <xsl:param name="by"/>
        <xsl:choose>
            <xsl:when test="contains($text, $replace)">
                <xsl:value-of select="substring-before($text,$replace)"/>
                <xsl:value-of select="$by"/>
                <xsl:call-template name="string-replace-all">
                    <xsl:with-param name="text" select="substring-after($text,$replace)"/>
                    <xsl:with-param name="replace" select="$replace"/>
                    <xsl:with-param name="by" select="$by"/>
                </xsl:call-template>
            </xsl:when>
            <xsl:otherwise>
                <xsl:value-of select="$text"/>
            </xsl:otherwise>
        </xsl:choose>
    </xsl:template>
</xsl:stylesheet>